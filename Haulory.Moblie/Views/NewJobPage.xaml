<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.NewJobPage"
    BackgroundColor="{StaticResource BrandBackground}"
    IsVisible="{Binding IsAddJobVisible}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <!-- Page header -->
            <VerticalStackLayout Spacing="2">
                <Label Text="New job"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource BrandTitle}" />

                <Label Text="Enter pickup, delivery, assignment, and billing details"
                       FontSize="13"
                       Opacity="0.85"
                       TextColor="{StaticResource BrandInk}" />
            </VerticalStackLayout>

            <!-- CLIENT / BILL TO -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16">

                <VerticalStackLayout Spacing="12">
                    <Label Text="Client (Bill To)"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">

                        <VerticalStackLayout Spacing="10">

                            <Entry Placeholder="Company name"
                                   Text="{Binding ClientCompanyName}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Entry Placeholder="Contact name (optional)"
                                   Text="{Binding ClientContactName}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Entry Placeholder="Email (optional)"
                                   Keyboard="Email"
                                   Text="{Binding ClientEmail}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Entry Placeholder="Address line 1"
                                   Text="{Binding ClientAddressLine1}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12">

                                <Entry Grid.Column="0"
                                       Placeholder="City"
                                       Text="{Binding ClientCity}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />

                                <Entry Grid.Column="1"
                                       Placeholder="Country"
                                       Text="{Binding ClientCountry}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                    <Label Text="This is who the invoice will be billed to"
                           FontSize="12"
                           TextColor="{StaticResource BrandInk}"
                           Opacity="0.9" />
                </VerticalStackLayout>
            </Border>

            <!-- PICKUP -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16">

                <VerticalStackLayout Spacing="12">
                    <Label Text="Pickup"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">

                        <VerticalStackLayout Spacing="10">
                            <Entry Placeholder="Company name"
                                   Text="{Binding PickupCompany}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Entry Placeholder="Pickup address"
                                   Text="{Binding PickupAddress}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- DELIVERY -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16">

                <VerticalStackLayout Spacing="12">
                    <Label Text="Delivery"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">

                        <VerticalStackLayout Spacing="10">
                            <Entry Placeholder="Company name"
                                   Text="{Binding DeliveryCompany}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Entry Placeholder="Delivery address"
                                   Text="{Binding DeliveryAddress}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- LOAD DETAILS -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16">

                <VerticalStackLayout Spacing="12">
                    <Label Text="Load"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">

                        <VerticalStackLayout Spacing="10">
                            <Entry Placeholder="Reference number"
                                   Text="{Binding ReferenceNumber}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource BrandSurface}"
                                    Padding="10">
                                <Editor Placeholder="Load description"
                                        AutoSize="TextChanges"
                                        Text="{Binding LoadDescription}"
                                        HeightRequest="110"
                                        TextColor="{StaticResource BrandInk}"
                                        PlaceholderColor="{StaticResource Gray600}"
                                        BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ASSIGNMENT -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16">

                <VerticalStackLayout Spacing="12">
                    <Label Text="Assignment"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">

                        <VerticalStackLayout Spacing="10">

                            <Label Text="Driver"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandTitle}" />

                            <Picker Title="Select driver"
                                    ItemsSource="{Binding Drivers}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding SelectedDriver}"
                                    TitleColor="{StaticResource Gray600}"
                                    TextColor="{StaticResource BrandInk}" />

                            <Label Text="Vehicle"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandTitle}" />

                            <Picker Title="Select vehicle"
                                    ItemsSource="{Binding Vehicles}"
                                    ItemDisplayBinding="{Binding Rego}"
                                    SelectedItem="{Binding SelectedVehicle}"
                                    TitleColor="{StaticResource Gray600}"
                                    TextColor="{StaticResource BrandInk}" />

                            <Label Text="Trailer 1 (optional)"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandTitle}" />

                            <Picker Title="Select trailer 1"
                                    ItemsSource="{Binding Trailers}"
                                    ItemDisplayBinding="{Binding Rego}"
                                    SelectedItem="{Binding SelectedTrailer1}"
                                    TitleColor="{StaticResource Gray600}"
                                    TextColor="{StaticResource BrandInk}" />

                            <Label Text="Trailer 2 (optional)"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandTitle}" />

                            <Picker Title="Select trailer 2"
                                    ItemsSource="{Binding Trailers}"
                                    ItemDisplayBinding="{Binding Rego}"
                                    SelectedItem="{Binding SelectedTrailer2}"
                                    TitleColor="{StaticResource Gray600}"
                                    TextColor="{StaticResource BrandInk}" />

                            <Label Text="{Binding SelectedTrailerSummary}"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}"
                                   Opacity="0.85" />

                        </VerticalStackLayout>
                    </Border>

                    <Label Text="Assignment can be changed later"
                           FontSize="12"
                           TextColor="{StaticResource BrandInk}"
                           Opacity="0.9" />
                </VerticalStackLayout>
            </Border>

            <!-- BILLING -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16">

                <VerticalStackLayout Spacing="12">
                    <Label Text="Billing"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">

                        <VerticalStackLayout Spacing="10">

                            <Entry Placeholder="Invoice number"
                                   Text="{Binding InvoiceNumber}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Label Text="Rate type"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandTitle}" />

                            <Picker Title="Select rate type"
                                    ItemsSource="{Binding RateTypes}"
                                    SelectedItem="{Binding RateType}"
                                    TitleColor="{StaticResource Gray600}"
                                    TextColor="{StaticResource BrandInk}" />

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12">

                                <Entry Grid.Column="0"
                                       Placeholder="Rate"
                                       Keyboard="Numeric"
                                       Text="{Binding RateValue}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />

                                <Entry Grid.Column="1"
                                       Placeholder="{Binding QuantityLabel}"
                                       Keyboard="Numeric"
                                       Text="{Binding Quantity}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Grid>

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandSurface}"
                                    Padding="12">

                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <Label Text="Total"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}"
                                           VerticalTextAlignment="Center" />

                                    <Label Grid.Column="1"
                                           Text="{Binding Total, StringFormat='{0:N2}'}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandAccent}"
                                           VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>

                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- SAVE -->
            <Button Text="Save job"
                    Command="{Binding SaveJobCommand}"
                    IsVisible="{Binding IsAddJobVisible}"
                    IsEnabled="{Binding IsAddJobEnabled}"
                    HeightRequest="50"
                    CornerRadius="14"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{StaticResource White}" />

            <BoxView HeightRequest="6" Opacity="0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>