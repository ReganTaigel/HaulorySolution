<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.RegisterPage"
    xmlns:converters="clr-namespace:Haulory.Mobile.Converters"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource BrandBackground}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24"
                             Spacing="18"
                             VerticalOptions="Center">

            <!-- Header -->
            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                <Label Text="Create account"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="{StaticResource BrandTitle}" />

                <Label Text="Set up your Haulory profile"
                       FontSize="14"
                       TextColor="{StaticResource BrandInk}" />
            </VerticalStackLayout>

            <!-- Register Card -->
            <Border StrokeShape="RoundRectangle 20"
                    StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="18">

                <VerticalStackLayout Spacing="14">

                    <Label Text="Your details"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <!-- Names -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="First name"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}" />

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12,8">
                                <Entry Placeholder="First name"
                                       Text="{Binding FirstName}"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Last name"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}" />

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12,8">
                                <Entry Placeholder="Last name"
                                       Text="{Binding LastName}"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Border>
                        </VerticalStackLayout>

                    </Grid>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,8">
                            <Entry Placeholder="Email address"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   ClearButtonVisibility="WhileEditing"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Password"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,8">
                            <Entry Placeholder="Password"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,8">
                            <Entry Placeholder="Confirm password"
                                   Text="{Binding ConfirmPassword}"
                                   IsPassword="True"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />
                        </Border>

                        <!-- Match message -->
                        <Label Text="{Binding PasswordsMatchMessage}"
                               TextColor="{Binding PasswordsMatchColor}"
                               FontSize="12"
                               Opacity="0.95"
                               Margin="2,2,0,0"
                               IsVisible="{Binding ConfirmPassword, Converter={StaticResource StringNotEmptyConverter}}" />
                    </VerticalStackLayout>

                    <!-- Register Button -->
                    <Button Text="Create account"
                            Command="{Binding RegisterCommand}"
                            HeightRequest="48"
                            CornerRadius="14"
                            FontAttributes="Bold"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}" />

                </VerticalStackLayout>
            </Border>

            <!-- Footer -->
            <Label Text="By creating an account you agree to our terms"
                   FontSize="12"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource BrandInk}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>