<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.RegisterPage"
    xmlns:converters="clr-namespace:Haulory.Mobile.Converters"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource BrandBackground}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24"
                             Spacing="18"
                             VerticalOptions="Center">

            <!-- Header -->
            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                <Label Text="Create account"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="{StaticResource BrandTitle}" />

                <Label Text="Set up your Haulory profile"
                       FontSize="14"
                       TextColor="{StaticResource BrandInk}" />
            </VerticalStackLayout>

            <!-- Register Card -->
            <Border StrokeShape="RoundRectangle 20"
                    StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="18">

                <VerticalStackLayout Spacing="16">

                    <!-- ========================= -->
                    <!-- USER DETAILS -->
                    <!-- ========================= -->
                    <Label Text="Your details"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <!-- Names -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="First name"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}" />

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12,8">
                                <Entry Placeholder="First name"
                                       Text="{Binding FirstName}"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Last name"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}" />

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12,8">
                                <Entry Placeholder="Last name"
                                       Text="{Binding LastName}"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Border>
                        </VerticalStackLayout>

                    </Grid>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,8">
                            <Entry Placeholder="Email address"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   ClearButtonVisibility="WhileEditing"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Password"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,8">
                            <Entry Placeholder="Password"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,8">
                            <Entry Placeholder="Confirm password"
                                   Text="{Binding ConfirmPassword}"
                                   IsPassword="True"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />
                        </Border>

                        <!-- Match message -->
                        <Label Text="{Binding PasswordsMatchMessage}"
                               TextColor="{Binding PasswordsMatchColor}"
                               FontSize="12"
                               Opacity="0.95"
                               Margin="2,2,0,0"
                               IsVisible="{Binding ConfirmPassword, Converter={StaticResource StringNotEmptyConverter}}" />
                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource Gray200}"
                             Opacity="0.8"
                             Margin="0,4" />

                    <!-- ========================= -->
                    <!-- BUSINESS DETAILS -->
                    <!-- ========================= -->
                    <Label Text="Business details"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Label Text="Used for invoices and POD documents"
                           FontSize="12"
                           TextColor="{StaticResource BrandInk}"
                           Opacity="0.9" />

                    <!-- Business name -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Business name"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,8">
                            <Entry Placeholder="e.g., Haulory Logistics Ltd"
                                   Text="{Binding BusinessName}"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Business contact -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="Business email (optional)"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}" />

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12,8">
                                <Entry Placeholder="accounts@business.com"
                                       Text="{Binding BusinessEmail}"
                                       Keyboard="Email"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Business phone (optional)"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}" />

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12,8">
                                <Entry Placeholder="+64..."
                                       Text="{Binding BusinessPhone}"
                                       Keyboard="Telephone"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Border>
                        </VerticalStackLayout>

                    </Grid>

                    <!-- Business Address -->
                    <Label Text="Business address (optional)"
                           FontSize="12"
                           TextColor="{StaticResource BrandInk}"
                           Margin="0,6,0,0" />

                    <VerticalStackLayout Spacing="10">

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,8">
                            <Entry Placeholder="Address line 1"
                                   Text="{Binding BusinessAddress1}"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />
                        </Border>

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,8">
                            <Entry Placeholder="Address line 2"
                                   Text="{Binding BusinessAddress2}"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12,8">
                                <Entry Placeholder="Suburb"
                                       Text="{Binding BusinessSuburb}"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Border>

                            <Border Grid.Column="1"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12,8">
                                <Entry Placeholder="City"
                                       Text="{Binding BusinessCity}"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12,8">
                                <Entry Placeholder="Region"
                                       Text="{Binding BusinessRegion}"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Border>

                            <Border Grid.Column="1"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12,8">
                                <Entry Placeholder="Postcode"
                                       Text="{Binding BusinessPostcode}"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Border>
                        </Grid>

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,8">
                            <Entry Placeholder="Country"
                                   Text="{Binding BusinessCountry}"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />
                        </Border>

                    </VerticalStackLayout>

                    <!-- Tax / identifiers -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,4,0,0">

                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="GST number (optional)"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}" />

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12,8">
                                <Entry Placeholder="e.g., 123-456-789"
                                       Text="{Binding SupplierGstNumber}"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="NZBN (optional)"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}" />

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12,8">
                                <Entry Placeholder="e.g., 942904..."
                                       Text="{Binding SupplierNzbn}"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Border>
                        </VerticalStackLayout>

                    </Grid>

                    <!-- Register Button -->
                    <Button Text="Create account"
                            Command="{Binding RegisterCommand}"
                            HeightRequest="48"
                            CornerRadius="14"
                            FontAttributes="Bold"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            Margin="0,6,0,0" />

                </VerticalStackLayout>
            </Border>

            <!-- Footer -->
            <Label Text="By creating an account you agree to our terms"
                   FontSize="12"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource BrandInk}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>