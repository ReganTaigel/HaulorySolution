<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.RegisterPage"
    xmlns:converters="clr-namespace:Haulory.Mobile.Converters"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{AppThemeBinding Light=#F5F6FA, Dark=#121212}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24"
                             Spacing="18"
                             VerticalOptions="Center">

            <!-- Header -->
            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                <Label Text="Create account"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111827, Dark=White}" />

                <Label Text="Set up your Haulory profile"
                       FontSize="14"
                       Opacity="0.75"
                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
            </VerticalStackLayout>

            <!-- Register Card -->
            <Border StrokeShape="RoundRectangle 20"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#0B1220}"
                    Padding="18">

                <VerticalStackLayout Spacing="14">

                    <Label Text="Your details"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#111827, Dark=White}" />

                    <!-- Names -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="First name"
                                   FontSize="12"
                                   Opacity="0.7"
                                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />

                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#111827}"
                                    Padding="12,8">
                                <Entry Placeholder="First name"
                                       Text="{Binding FirstName}"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Last name"
                                   FontSize="12"
                                   Opacity="0.7"
                                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />

                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#111827}"
                                    Padding="12,8">
                                <Entry Placeholder="Last name"
                                       Text="{Binding LastName}"
                                       HeightRequest="44"
                                       BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                    </Grid>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email"
                               FontSize="12"
                               Opacity="0.7"
                               TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />

                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#111827}"
                                Padding="12,8">
                            <Entry Placeholder="Email address"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   ClearButtonVisibility="WhileEditing"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Password"
                               FontSize="12"
                               Opacity="0.7"
                               TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />

                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#111827}"
                                Padding="12,8">
                            <Entry Placeholder="Password"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#111827}"
                                Padding="12,8">
                            <Entry Placeholder="Confirm password"
                                   Text="{Binding ConfirmPassword}"
                                   IsPassword="True"
                                   HeightRequest="44"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <!-- Match message -->
                        <Label Text="{Binding PasswordsMatchMessage}"
                               TextColor="{Binding PasswordsMatchColor}"
                               FontSize="12"
                               Opacity="0.9"
                               Margin="2,2,0,0"
                               IsVisible="{Binding ConfirmPassword, Converter={StaticResource StringNotEmptyConverter}}" />
                    </VerticalStackLayout>

                    <!-- Register Button -->
                    <Button Text="Create account"
                            Command="{Binding RegisterCommand}"
                            HeightRequest="48"
                            CornerRadius="14"
                            FontAttributes="Bold"
                            BackgroundColor="{AppThemeBinding Light=#2563EB, Dark=#3B82F6}"
                            TextColor="White" />

                </VerticalStackLayout>
            </Border>

            <!-- Footer -->
            <Label Text="By creating an account you agree to our terms"
                   FontSize="12"
                   HorizontalOptions="Center"
                   Opacity="0.7"
                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>