<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Haulory.Mobile.Views.VehicleCollectionPage"
             BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*"
          Padding="20"
          RowSpacing="14"
          IsVisible="{Binding IsVehiclesVisible}">

        <VerticalStackLayout Grid.Row="0" Spacing="10">

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12"
                  VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Vehicles"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Label Text="Keep your fleet compliant and ready"
                           FontSize="13"
                           TextColor="{StaticResource BrandInk}" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Add"
                        Command="{Binding GoToNewVehicleCommand}"
                        IsVisible="{Binding IsAddVehicleVisible}"
                        IsEnabled="{Binding IsAddVehicleEnabled}"
                        HeightRequest="44"
                        Padding="16,0"
                        CornerRadius="14"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}"
                        VerticalOptions="Center" />
            </Grid>

            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="14">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Tip"
                           FontSize="12"
                           Opacity="0.85"
                           TextColor="{StaticResource BrandInk}" />

                    <Label Text="Pull down to refresh compliance status"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}"
                           IsVisible="{Binding IsMainUser}" />

                    <Label Text="These are the vehicles assigned to your active jobs"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}"
                           IsVisible="{Binding IsSubUser}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsBusy}"
                     IsEnabled="{Binding IsVehiclesEnabled}"
                     IsVisible="{Binding IsVehiclesVisible}">

            <CollectionView ItemsSource="{Binding Assets}"
                            SelectionMode="None"
                            Margin="0,2,0,0">

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24"
                                         Spacing="8"
                                         HorizontalOptions="Center">
                        <Label Text="No vehicles available"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="{StaticResource BrandTitle}"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Tap Add to create your first vehicle"
                               FontSize="13"
                               TextColor="{StaticResource BrandInk}"
                               HorizontalTextAlignment="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsMainUser}"
                                             Value="False">
                                    <Setter Property="IsVisible"
                                            Value="False" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsAddVehicleVisible}"
                                             Value="False">
                                    <Setter Property="IsVisible"
                                            Value="False" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>

                        <Label Text="No vehicles are assigned to your active jobs right now"
                               FontSize="13"
                               TextColor="{StaticResource BrandInk}"
                               HorizontalTextAlignment="Center"
                               IsVisible="{Binding IsSubUser}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray300}"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="{StaticResource BrandSurface}"
                                Padding="14"
                                Margin="0,0,0,12">

                            <VerticalStackLayout Spacing="12">

                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Year}"
                                           IsVisible="False" />

                                    <Label FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}"
                                           LineBreakMode="TailTruncation">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} {1} {2}">
                                                <Binding Path="Year" />
                                                <Binding Path="Make" />
                                                <Binding Path="Model" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>

                                    <Border StrokeThickness="1"
                                            Stroke="{StaticResource Gray200}"
                                            StrokeShape="RoundRectangle 12"
                                            BackgroundColor="{StaticResource BrandTileFill}"
                                            Padding="10,6">
                                        <Label Text="{Binding VehicleTypeDisplay}"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}" />
                                    </Border>
                                </VerticalStackLayout>

                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray200}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12">

                                    <VerticalStackLayout Spacing="8">

                                        <Label Text="Compliance"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}" />

                                        <Label Text="{Binding Rego, StringFormat='Rego: {0}'}"
                                               FontSize="13"
                                               TextColor="{StaticResource BrandTitle}" />

                                        <Label Text="{Binding RegoExpiryDisplay, StringFormat='Expires: {0}'}"
                                               FontSize="13"
                                               TextColor="{StaticResource BrandTitle}" />

                                        <Label Text="{Binding RegoStatusInlineDisplay}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandTitle}" />

                                        <Label Text="{Binding CertificateNameDisplay, StringFormat='{0} expiry'}"
                                               FontSize="13"
                                               TextColor="{StaticResource BrandTitle}" />

                                        <Label Text="{Binding CertificateExpiryDisplay}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandTitle}" />

                                        <Label Text="{Binding CertStatusInlineDisplay}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandTitle}" />

                                    </VerticalStackLayout>
                                </Border>

                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray200}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12">

                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="Odometer"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}" />

                                        <Label Text="{Binding OdometerFullDisplay, StringFormat='Current: {0}'}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandTitle}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray200}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12"
                                        IsVisible="{Binding IsRucApplicable}">

                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="RUC"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}" />

                                        <Label FontSize="13"
                                               TextColor="{StaticResource BrandTitle}">
                                            <Label.Text>
                                                <MultiBinding StringFormat="Licence: {0} to {1}">
                                                    <Binding Path="RucLicenceStartDisplay" />
                                                    <Binding Path="RucLicenceEndDisplay" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>

                                        <Label Text="{Binding RucRemainingDisplay, StringFormat='Remaining: {0}'}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandTitle}" />

                                        <Label Text="{Binding IsRucOverdueYesNo, StringFormat='Overdue: {0}'}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandTitle}" />
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

    </Grid>

</ContentPage>