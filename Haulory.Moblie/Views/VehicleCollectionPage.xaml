<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Haulory.Mobile.Views.VehicleCollectionPage">
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>
    <Grid RowDefinitions="Auto,*"
          Padding="20"
          RowSpacing="14">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="10">

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Vehicles"
                           FontSize="28"
                           FontAttributes="Bold" />
                    <Label Text="Keep your fleet compliant and ready"
                           FontSize="13"
                           Opacity="0.7" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Add"
                        Command="{Binding GoToNewVehicleCommand}"
                        HeightRequest="44"
                        Padding="16,0"
                        CornerRadius="14"
                        BackgroundColor="{AppThemeBinding Light='#111827', Dark='#E5E7EB'}"
                        TextColor="{AppThemeBinding Light='White', Dark='Black'}"
                        VerticalOptions="Center"/>
            </Grid>

            <!-- Optional guidance card -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#0B1220'}"
                    Padding="14">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Tip"
                           FontSize="12"
                           Opacity="0.7" />
                    <Label Text="Pull down to refresh compliance status"
                           FontSize="13"
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- List + Pull to refresh -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsBusy}">

            <CollectionView ItemsSource="{Binding Assets}"
                            SelectionMode="None"
                            Margin="0,2,0,0">

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24" Spacing="8" HorizontalOptions="Center">
                        <Label Text="No vehicles saved yet"
                               FontAttributes="Bold"
                               FontSize="16"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Tap Add to create your first vehicle"
                               FontSize="13"
                               Opacity="0.7"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border StrokeThickness="1"
                                Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#0B1220'}"
                                Padding="14"
                                Margin="0,0,0,12">

                            <VerticalStackLayout Spacing="12">

                                <!-- Title row -->
                                <VerticalStackLayout Spacing="4">
                                    <Label FontSize="16"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Year}" />
                                                <Span Text=" " />
                                                <Span Text="{Binding Make}" />
                                                <Span Text=" " />
                                                <Span Text="{Binding Model}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12"
                                            BackgroundColor="{AppThemeBinding Light='#F9FAFB', Dark='#111827'}"
                                            Padding="10,6">
                                        <Label Text="{Binding VehicleTypeDisplay}"
                                               FontSize="12"
                                               Opacity="0.75" />
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Compliance section -->
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{AppThemeBinding Light='#F9FAFB', Dark='#111827'}"
                                        Padding="12">

                                    <VerticalStackLayout Spacing="8">

                                        <Label Text="Compliance"
                                               FontSize="12"
                                               Opacity="0.7" />

                                        <!-- Rego -->
                                        <Label FontSize="13" Opacity="0.9" LineBreakMode="TailTruncation">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Rego: " />
                                                    <Span Text="{Binding Rego}" FontAttributes="Bold" />
                                                    <Span Text="  " />
                                                    <Span Text="Expires: " />
                                                    <Span Text="{Binding RegoExpiryDisplay}" FontAttributes="Bold" />
                                                    <Span Text=" " />
                                                    <Span Text="{Binding RegoStatusInlineDisplay}" FontAttributes="Bold" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>

                                        <!-- WOF / COF -->
                                        <Label FontSize="13" Opacity="0.9" LineBreakMode="TailTruncation">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding CertificateNameDisplay}" />
                                                    <Span Text=" expiry: " />
                                                    <Span Text="{Binding CertificateExpiryDisplay}" FontAttributes="Bold" />
                                                    <Span Text=" " />
                                                    <Span Text="{Binding CertStatusInlineDisplay}" FontAttributes="Bold" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>

                                    </VerticalStackLayout>
                                </Border>

                                <!-- RUC section -->
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{AppThemeBinding Light='#F9FAFB', Dark='#111827'}"
                                        Padding="12"
                                        IsVisible="{Binding IsRucApplicable}">

                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="RUC"
                                               FontSize="12"
                                               Opacity="0.7" />

                                        <Label FontSize="13" Opacity="0.9" LineBreakMode="TailTruncation">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Licence: " />
                                                    <Span Text="{Binding RucLicenceStartDisplay}" FontAttributes="Bold" />
                                                    <Span Text=" to " />
                                                    <Span Text="{Binding RucLicenceEndDisplay}" FontAttributes="Bold" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>

                                        <Label FontSize="13" Opacity="0.9" LineBreakMode="TailTruncation">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Remaining: " />
                                                    <Span Text="{Binding RucRemainingDisplay}" FontAttributes="Bold" />
                                                    <Span Text="  " />
                                                    <Span Text="Overdue: " />
                                                    <Span Text="{Binding IsRucOverdueYesNo}" FontAttributes="Bold" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>