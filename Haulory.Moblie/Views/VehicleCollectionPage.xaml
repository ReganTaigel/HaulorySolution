<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Haulory.Mobile.Views.VehicleCollectionPage"
             BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*"
          Padding="20"
          RowSpacing="14">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="10">

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Vehicles"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />
                    <Label Text="Keep your fleet compliant and ready"
                           FontSize="13"
                           TextColor="{StaticResource BrandInk}" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Add"
                        Command="{Binding GoToNewVehicleCommand}"
                        IsVisible="{Binding IsMainUser}"
                        HeightRequest="44"
                        Padding="16,0"
                        CornerRadius="14"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}"
                        VerticalOptions="Center"/>
            </Grid>

            <!-- Guidance -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="14">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Tip"
                           FontSize="12"
                           Opacity="0.85"
                           TextColor="{StaticResource BrandInk}" />

                    <Label Text="Pull down to refresh compliance status"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}"
                           IsVisible="{Binding IsMainUser}" />

                    <Label Text="These are the vehicles assigned to your active jobs"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}"
                           IsVisible="{Binding IsSubUser}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- List + Pull to refresh -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsBusy}">

            <CollectionView ItemsSource="{Binding Assets}"
                            SelectionMode="None"
                            Margin="0,2,0,0">

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24"
                                         Spacing="8"
                                         HorizontalOptions="Center">
                        <Label Text="No vehicles available"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="{StaticResource BrandTitle}"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="Tap Add to create your first vehicle"
                               FontSize="13"
                               TextColor="{StaticResource BrandInk}"
                               HorizontalTextAlignment="Center"
                               IsVisible="{Binding IsMainUser}"/>

                        <Label Text="No vehicles are assigned to your active jobs right now"
                               FontSize="13"
                               TextColor="{StaticResource BrandInk}"
                               HorizontalTextAlignment="Center"
                               IsVisible="{Binding IsSubUser}"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray300}"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="{StaticResource BrandSurface}"
                                Padding="14"
                                Margin="0,0,0,12">

                            <VerticalStackLayout Spacing="12">

                                <!-- Title row -->
                                <VerticalStackLayout Spacing="4">
                                    <Label FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}"
                                           LineBreakMode="TailTruncation">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Year}" />
                                                <Span Text=" " />
                                                <Span Text="{Binding Make}" />
                                                <Span Text=" " />
                                                <Span Text="{Binding Model}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <Border StrokeThickness="1"
                                            Stroke="{StaticResource Gray200}"
                                            StrokeShape="RoundRectangle 12"
                                            BackgroundColor="{StaticResource BrandTileFill}"
                                            Padding="10,6">
                                        <Label Text="{Binding VehicleTypeDisplay}"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}" />
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Compliance section -->
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray200}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12">

                                    <VerticalStackLayout Spacing="8">

                                        <Label Text="Compliance"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}" />

                                        <!-- Rego -->
                                        <Label FontSize="13"
                                               TextColor="{StaticResource BrandTitle}"
                                               LineBreakMode="TailTruncation">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Rego: " />
                                                    <Span Text="{Binding Rego}" FontAttributes="Bold" />
                                                    <Span Text="  " />
                                                    <Span Text="Expires: " />
                                                    <Span Text="{Binding RegoExpiryDisplay}" FontAttributes="Bold" />
                                                    <Span Text=" " />
                                                    <Span Text="{Binding RegoStatusInlineDisplay}" FontAttributes="Bold" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>

                                        <!-- WOF / COF -->
                                        <Label FontSize="13"
                                               TextColor="{StaticResource BrandTitle}"
                                               LineBreakMode="TailTruncation">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding CertificateNameDisplay}" />
                                                    <Span Text=" expiry: " />
                                                    <Span Text="{Binding CertificateExpiryDisplay}" FontAttributes="Bold" />
                                                    <Span Text=" " />
                                                    <Span Text="{Binding CertStatusInlineDisplay}" FontAttributes="Bold" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>

                                    </VerticalStackLayout>
                                </Border>
                                <!-- Odometer section -->
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray200}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12">

                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="Odometer"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}" />

                                        <Label FontSize="13"
                                               TextColor="{StaticResource BrandTitle}"
                                               LineBreakMode="TailTruncation">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Current: " />
                                                    <Span Text="{Binding OdometerKm, StringFormat='{0:N0}'}"
                                                           FontAttributes="Bold" />
                                                    <Span Text=" km" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </VerticalStackLayout>
                                </Border>
                                
                                <!-- RUC section -->
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray200}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12"
                                        IsVisible="{Binding IsRucApplicable}">

                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="RUC"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}" />

                                        <Label FontSize="13"
                                               TextColor="{StaticResource BrandTitle}"
                                               LineBreakMode="TailTruncation">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Licence: " />
                                                    <Span Text="{Binding RucLicenceStartDisplay}" FontAttributes="Bold" />
                                                    <Span Text=" to " />
                                                    <Span Text="{Binding RucLicenceEndDisplay}" FontAttributes="Bold" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>

                                        <Label FontSize="13"
                                               TextColor="{StaticResource BrandTitle}"
                                               LineBreakMode="TailTruncation">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Remaining: " />
                                                    <Span Text="{Binding RucRemainingDisplay}" FontAttributes="Bold" />
                                                    <Span Text="  " />
                                                    <Span Text="Overdue: " />
                                                    <Span Text="{Binding IsRucOverdueYesNo}" FontAttributes="Bold" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage> 