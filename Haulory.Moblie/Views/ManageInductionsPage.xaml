<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Haulory.Mobile.Views.ManageInductionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid Padding="16" RowDefinitions="Auto,Auto,*" RowSpacing="12">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="10"
              RowDefinitions="Auto">

            <Border Grid.Column="0"
                    StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="{StaticResource BrandTileFill}"
                    Padding="12,8">
                <Picker Title="Select Driver"
                        ItemsSource="{Binding Drivers}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        SelectedItem="{Binding SelectedDriver}"
                        TitleColor="{StaticResource Gray600}"
                        TextColor="{StaticResource BrandInk}" />
            </Border>

            <Button Grid.Column="1"
                    Text="Templates"
                    Padding="14,0"
                    HeightRequest="44"
                    CornerRadius="12"
                    BackgroundColor="{StaticResource Gray200}"
                    TextColor="{StaticResource BrandInk}"
                    Command="{Binding GoToTemplatesCommand}" />

            <Button Grid.Column="2"
                    Text="Add"
                    Padding="14,0"
                    HeightRequest="44"
                    CornerRadius="12"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{StaticResource White}"
                    Command="{Binding AddInductionCommand}" />
        </Grid>

        <Label Grid.Row="1"
               Text="Tap Edit to update status. Attach PDF or document proof to each induction."
               FontSize="12"
               TextColor="{StaticResource BrandInk}" />

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Inductions}"
                        EmptyView="No inductions for this driver yet. Tap 'Add'.">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray300}"
                            BackgroundColor="{StaticResource BrandSurface}"
                            StrokeShape="RoundRectangle 12"
                            Padding="12"
                            Margin="0,0,0,10">

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnDefinitions="*,Auto"
                              RowSpacing="6"
                              ColumnSpacing="10">

                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Text="{Binding WorkSiteName}"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}" />

                            <Border Grid.Row="0"
                                    Grid.Column="1"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="10,4"
                                    BackgroundColor="{StaticResource BrandTileFill}">
                                <Label Text="{Binding StatusDisplay}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource BrandInk}" />
                            </Border>

                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding RequirementTitle}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandTitle}"
                                   LineBreakMode="TailTruncation" />

                            <Label Grid.Row="2"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding CompanyName, StringFormat='Company: {0}'}"
                                   FontSize="13"
                                   TextColor="{StaticResource BrandInk}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding CompanyName}"
                                                 Value="{x:Null}">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding CompanyName}"
                                                 Value="">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <Label Grid.Row="3"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding PpeRequired, StringFormat='PPE: {0}'}"
                                   FontSize="13"
                                   TextColor="{StaticResource BrandInk}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding PpeRequired}"
                                                 Value="">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding PpeRequired}"
                                                 Value="{x:Null}">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <VerticalStackLayout Grid.Row="4"
                                                 Grid.Column="0"
                                                 Grid.ColumnSpan="2"
                                                 Spacing="3">

                                <Label Text="{Binding CompletedOnUtc, StringFormat='Completed: {0:yyyy-MM-dd}'}"
                                       FontSize="13"
                                       TextColor="{StaticResource BrandInk}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding CompletedOnUtc}"
                                                     Value="{x:Null}">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <Label Text="{Binding ExpiresOnUtc, StringFormat='Due/Expires: {0:yyyy-MM-dd}'}"
                                       FontSize="13"
                                       TextColor="{StaticResource BrandInk}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding ExpiresOnUtc}"
                                                     Value="{x:Null}">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <Label Text="{Binding DaysLeft, StringFormat='Days left: {0}'}"
                                       FontSize="13"
                                       TextColor="{StaticResource BrandInk}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding DaysLeft}"
                                                     Value="{x:Null}">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>

                            <Border Grid.Row="5"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Padding="10"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource BrandTileFill}">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Proof document"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandInk}" />

                                    <Label Text="{Binding EvidenceFileName}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding EvidenceFileName}"
                                                         Value="{x:Null}">
                                                <Setter Property="Text" Value="No proof attached" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding EvidenceFileName}"
                                                         Value="">
                                                <Setter Property="Text" Value="No proof attached" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Label Text="{Binding EvidenceUploadedOnUtc, StringFormat='Uploaded: {0:yyyy-MM-dd}'}"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray600}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding EvidenceUploadedOnUtc}"
                                                         Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </VerticalStackLayout>
                            </Border>

                            <Grid Grid.Row="6"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  ColumnDefinitions="Auto,Auto,Auto,*"
                                  ColumnSpacing="8">

                                <Button Grid.Column="0"
                                        Text="Edit"
                                        Padding="14,0"
                                        HeightRequest="36"
                                        CornerRadius="10"
                                        BackgroundColor="{StaticResource Gray200}"
                                        TextColor="{StaticResource BrandInk}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCommand}"
                                        CommandParameter="{Binding}" />

                                <Button Grid.Column="1"
                                        Text="Attach"
                                        Padding="14,0"
                                        HeightRequest="36"
                                        CornerRadius="10"
                                        BackgroundColor="{StaticResource Primary}"
                                        TextColor="{StaticResource White}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.UploadProofCommand}"
                                        CommandParameter="{Binding}" />

                                <Button Grid.Column="2"
                                        Text="Open"
                                        Padding="14,0"
                                        HeightRequest="36"
                                        CornerRadius="10"
                                        BackgroundColor="{StaticResource Gray200}"
                                        TextColor="{StaticResource BrandInk}"
                                        IsVisible="{Binding HasEvidence}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenProofCommand}"
                                        CommandParameter="{Binding}" />

                                <Button Grid.Column="3"
                                        HorizontalOptions="End"
                                        Text="Remove"
                                        Padding="14,0"
                                        HeightRequest="36"
                                        CornerRadius="10"
                                        BackgroundColor="{StaticResource Gray200}"
                                        TextColor="{StaticResource BrandInk}"
                                        IsVisible="{Binding HasEvidence}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveProofCommand}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>