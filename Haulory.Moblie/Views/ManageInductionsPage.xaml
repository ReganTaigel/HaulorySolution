<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Haulory.Mobile.Views.ManageInductionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>
    <Grid Padding="16" RowDefinitions="Auto,Auto,*" RowSpacing="12">

        <!-- Top row: Driver picker + actions -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="10"
              RowDefinitions="Auto">

            <!-- Driver picker -->
            <Picker Grid.Column="0"
                    Title="Select Driver"
                    ItemsSource="{Binding Drivers}"
                    ItemDisplayBinding="{Binding DisplayName}"
                    SelectedItem="{Binding SelectedDriver}" />

            <!-- Templates -->
            <Button Grid.Column="1"
                    Text="Templates"
                    Padding="14,0"
                    HeightRequest="44"
                    CornerRadius="12"
                    Command="{Binding GoToTemplatesCommand}" />

            <!-- Add Induction -->
            <Button Grid.Column="2"
                    Text="Add"
                    Padding="14,0"
                    HeightRequest="44"
                    CornerRadius="12"
                    Command="{Binding AddInductionCommand}" />
        </Grid>

        <!-- Hint -->
        <Label Grid.Row="1"
               Text="Tap an item to update status, completion date and expiry (per driver)."
               FontSize="12"
               Opacity="0.7" />

        <!-- Inductions list -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Inductions}"
                        EmptyView="No inductions for this driver yet. Tap 'Add'.">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                            StrokeShape="RoundRectangle 12"
                            Padding="12"
                            Margin="0,0,0,10">

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                              ColumnDefinitions="*,Auto"
                              RowSpacing="6"
                              ColumnSpacing="10">

                            <!-- Worksite -->
                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Text="{Binding WorkSiteName}"
                                   FontSize="12"
                                   Opacity="0.7" />

                            <!-- Status (top-right) -->
                            <Border Grid.Row="0"
                                    Grid.Column="1"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="10,4"
                                    BackgroundColor="{AppThemeBinding Light='#F3F4F6', Dark='#111827'}">
                                <Label Text="{Binding StatusDisplay}"
                                       FontSize="12"
                                       FontAttributes="Bold" />
                            </Border>

                            <!-- Requirement title -->
                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding RequirementTitle}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />

                            <!-- PPE (only if not empty) -->
                            <Label Grid.Row="2"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding PpeRequired, StringFormat='PPE: {0}'}"
                                   FontSize="13"
                                   Opacity="0.85">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding PpeRequired}" Value="">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding PpeRequired}" Value="{x:Null}">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <!-- Dates + days-left -->
                            <VerticalStackLayout Grid.Row="3"
                                                 Grid.Column="0"
                                                 Spacing="3">

                                <!-- CompletedOnUtc visible only if has value -->
                                <Label Text="{Binding CompletedOnUtc, StringFormat='Completed: {0:yyyy-MM-dd}'}"
                                       FontSize="13"
                                       Opacity="0.85">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding CompletedOnUtc}" Value="{x:Null}">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <!-- ExpiresOnUtc visible only if has value -->
                                <Label Text="{Binding ExpiresOnUtc, StringFormat='Due/Expires: {0:yyyy-MM-dd}'}"
                                       FontSize="13"
                                       Opacity="0.85">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding ExpiresOnUtc}" Value="{x:Null}">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <!-- DaysLeft visible only if has value -->
                                <Label Text="{Binding DaysLeft, StringFormat='Days left: {0}'}"
                                       FontSize="13"
                                       Opacity="0.85">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding DaysLeft}" Value="{x:Null}">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                            </VerticalStackLayout>

                            <!-- Edit button (bottom-right) -->
                            <Button Grid.Row="3"
                                    Grid.Column="1"
                                    Text="Edit"
                                    Padding="14,0"
                                    HeightRequest="36"
                                    CornerRadius="10"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCommand}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>