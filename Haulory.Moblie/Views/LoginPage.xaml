<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.LoginPage"
    BackgroundColor="{StaticResource BrandBackground}"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout
            Padding="24"
            Spacing="18"
            VerticalOptions="Center">

            <!-- Header -->
            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                <Label Text="Haulory"
                       FontSize="34"
                       FontAttributes="Bold"
                       TextColor="{StaticResource BrandTitle}" />

                <Label Text="Welcome back"
                       FontSize="14"
                       TextColor="{StaticResource BrandInk}" />
            </VerticalStackLayout>

            <!-- Login Card -->
            <Border StrokeShape="RoundRectangle 20"
                    StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="18">

                <VerticalStackLayout Spacing="14">

                    <Label Text="Sign in"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,8">

                            <Entry Placeholder="Email address"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   ClearButtonVisibility="WhileEditing"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Password"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,8">

                            <Entry Placeholder="Password"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Login Button -->
                    <Button Text="Login"
                            Command="{Binding LoginCommand}"
                            HeightRequest="48"
                            CornerRadius="14"
                            FontAttributes="Bold"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}" />

                </VerticalStackLayout>
            </Border>

            <!-- Create account link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">

                <Label Text="Need an account"
                       FontSize="12"
                       TextColor="{StaticResource BrandInk}" />

                <Label Text="Create one"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <!-- Footer -->
            <Label Text="Secure transport and compliance management"
                   FontSize="12"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource BrandInk}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>