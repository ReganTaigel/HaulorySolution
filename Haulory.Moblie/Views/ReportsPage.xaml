<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.ReportsPage"
    BackgroundColor="{AppThemeBinding Light={StaticResource BgPageLight}, Dark={StaticResource BgPageDark}}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">

            <!-- Header -->
            <VerticalStackLayout Spacing="2">
                <Label Text="Reports"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                <Label Text="Delivered jobs and totals for the selected date"
                       Style="{StaticResource Subtle}" />
            </VerticalStackLayout>

            <!-- Stats row -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                <Border Grid.Column="0"
                        Style="{StaticResource Card}"
                        Padding="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Delivered"
                               FontSize="12"
                               Opacity="0.7"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                        <Label Text="{Binding DeliveredCount}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <Label Text="Completed deliveries"
                               FontSize="12"
                               Opacity="0.6"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource Card}"
                        Padding="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Revenue"
                               FontSize="12"
                               Opacity="0.7"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />

                        <Label Text="{Binding TotalRevenue, StringFormat='{0:N2}'}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <Label Text="Total for date"
                               FontSize="12"
                               Opacity="0.6"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- Controls card -->
            <Border Style="{StaticResource Card}"
                    Padding="16">

                <VerticalStackLayout Spacing="12">

                    <Label Text="Report date"
                           Style="{StaticResource FieldLabel}" />

                    <Border Style="{StaticResource InputContainer}">
                        <DatePicker Date="{Binding SelectedDate}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                    </Border>

                    <Button Text="Refresh"
                            Command="{Binding RefreshCommand}"
                            HeightRequest="46"
                            Style="{StaticResource PrimaryButton}" />

                </VerticalStackLayout>
            </Border>

            <!-- Receipts list -->
            <CollectionView ItemsSource="{Binding Receipts}"
                            SelectionMode="None"
                            Margin="0,2,0,0">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="6"
                                         Margin="0,18,0,0">
                        <Label Text="No delivery receipts yet"
                               FontSize="16"
                               FontAttributes="Bold"
                               Opacity="0.85"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

                        <Label Text="Complete a delivery to see receipts here"
                               FontSize="12"
                               Opacity="0.7"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border Style="{StaticResource Card}"
                                Padding="14"
                                Margin="0,0,0,12">

                            <VerticalStackLayout Spacing="10">

                                <!-- Top row -->
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding ReferenceNumber}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                               LineBreakMode="TailTruncation" />

                                        <Label Text="{Binding DeliveryCompany}"
                                               FontSize="13"
                                               Opacity="0.75"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>

                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource FieldLight}, Dark={StaticResource FieldDark}}"
                                            Padding="10,6"
                                            VerticalOptions="Start">
                                        <Label Text="{Binding Total, StringFormat='{0:N2}'}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                               HorizontalTextAlignment="Center" />
                                    </Border>
                                </Grid>

                                <!-- Details -->
                                <Border Style="{StaticResource InputContainer}">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding ReceiverName, StringFormat='Signed by {0}'}"
                                               FontSize="12"
                                               Opacity="0.8"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                               LineBreakMode="TailTruncation" />

                                        <Label Text="{Binding DeliveredAtUtc, StringFormat='Delivered {0:dd MMM yyyy HH:mm}'}"
                                               FontSize="12"
                                               Opacity="0.75"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Actions -->
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                    <Label Text="{Binding InvoiceNumber, StringFormat='Invoice #{0}'}"
                                           FontSize="12"
                                           Opacity="0.7"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                                           VerticalOptions="Center" />

                                    <!-- Invoice PDF (dark pill) -->
                                    <Button Grid.Column="1"
                                            Text="Invoice"
                                            HeightRequest="38"
                                            Padding="14,0"
                                            CornerRadius="12"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource BorderLight}}"
                                            TextColor="{AppThemeBinding Light=White, Dark=Black}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ExportInvoiceCommand}"
                                            CommandParameter="{Binding Id}" />

                                    <!-- POD PDF (primary) -->
                                    <Button Grid.Column="2"
                                            Text="POD"
                                            HeightRequest="38"
                                            Padding="14,0"
                                            CornerRadius="12"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryDark}}"
                                            TextColor="White"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ExportPodCommand}"
                                            CommandParameter="{Binding Id}" />
                                </Grid>
                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <BoxView HeightRequest="6" Opacity="0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>