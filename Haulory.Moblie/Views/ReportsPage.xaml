<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.ReportsPage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">

            <!-- Header -->
            <VerticalStackLayout Spacing="2"
                                 IsVisible="{Binding IsReportsVisible}">
                <Label Text="Reports"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource BrandTitle}" />

                <Label Text="Delivered jobs and totals for the selected date"
                       FontSize="13"
                       Opacity="0.85"
                       TextColor="{StaticResource BrandInk}" />
            </VerticalStackLayout>

            <!-- Stats row -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  IsVisible="{Binding IsReportsVisible}">

                <Border Grid.Column="0"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray300}"
                        StrokeShape="RoundRectangle 18"
                        BackgroundColor="{StaticResource BrandSurface}"
                        Padding="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Delivered"
                               FontSize="12"
                               Opacity="0.85"
                               TextColor="{StaticResource BrandInk}" />

                        <Label Text="{Binding DeliveredCount}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />

                        <Label Text="Completed deliveries"
                               FontSize="12"
                               Opacity="0.75"
                               TextColor="{StaticResource Gray600}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray300}"
                        StrokeShape="RoundRectangle 18"
                        BackgroundColor="{StaticResource BrandSurface}"
                        Padding="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Revenue"
                               FontSize="12"
                               Opacity="0.85"
                               TextColor="{StaticResource BrandInk}" />

                        <Label Text="{Binding TotalRevenue, StringFormat='{0:N2}'}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandAccent}" />

                        <Label Text="Total for date"
                               FontSize="12"
                               Opacity="0.75"
                               TextColor="{StaticResource Gray600}" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- Controls card -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16"
                    IsVisible="{Binding IsReportsVisible}">

                <VerticalStackLayout Spacing="12">

                    <Label Text="Report date"
                           FontSize="12"
                           Opacity="0.9"
                           TextColor="{StaticResource BrandInk}" />

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12,8">
                        <DatePicker Date="{Binding SelectedDate}"
                                    TextColor="{StaticResource BrandInk}"
                                    BackgroundColor="Transparent" />
                    </Border>

                    <Button Text="Refresh"
                            Command="{Binding RefreshCommand}"
                            IsEnabled="{Binding IsReportsEnabled}"
                            HeightRequest="46"
                            CornerRadius="14"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}" />

                </VerticalStackLayout>
            </Border>

            <!-- Receipts list -->
            <CollectionView ItemsSource="{Binding Receipts}"
                            SelectionMode="None"
                            Margin="0,2,0,0"
                            IsVisible="{Binding IsReportsVisible}">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="6"
                                         Margin="0,18,0,0">
                        <Label Text="No delivery receipts yet"
                               FontSize="16"
                               FontAttributes="Bold"
                               Opacity="0.9"
                               TextColor="{StaticResource BrandTitle}" />

                        <Label Text="Complete a delivery to see receipts here"
                               FontSize="12"
                               Opacity="0.8"
                               HorizontalTextAlignment="Center"
                               TextColor="{StaticResource BrandInk}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray300}"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="{StaticResource BrandSurface}"
                                Padding="14"
                                Margin="0,0,0,12">

                            <VerticalStackLayout Spacing="10">

                                <!-- Top row -->
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <VerticalStackLayout Grid.Column="0"
                                                         Spacing="2">
                                        <Label Text="{Binding ReferenceNumber}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandTitle}"
                                               LineBreakMode="TailTruncation" />

                                        <Label Text="{Binding DeliveryCompany}"
                                               FontSize="13"
                                               TextColor="{StaticResource BrandInk}"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>

                                    <Border Grid.Column="1"
                                            StrokeThickness="1"
                                            Stroke="{StaticResource Gray200}"
                                            StrokeShape="RoundRectangle 14"
                                            BackgroundColor="{StaticResource BrandTileFill}"
                                            Padding="10,6"
                                            VerticalOptions="Start">
                                        <Label Text="{Binding Total, StringFormat='{0:N2}'}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandTitle}"
                                               HorizontalTextAlignment="Center" />
                                    </Border>
                                </Grid>

                                <!-- Details -->
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray200}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12">
                                    <VerticalStackLayout Spacing="6">

                                        <Label Text="{Binding ReceiverName, StringFormat='Signed by {0}'}"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandTitle}"
                                               LineBreakMode="TailTruncation">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding ReceiverName}"
                                                             Value="{x:Null}">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding ReceiverName}"
                                                             Value="">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Label Text="{Binding DeliveredAtUtc, StringFormat='Delivered {0:dd MMM yyyy HH:mm}'}"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Actions -->
                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="10">

                                    <Label Text="{Binding InvoiceNumber, StringFormat='Invoice #{0}'}"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray600}"
                                           VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding InvoiceNumber}"
                                                         Value="{x:Null}">
                                                <Setter Property="IsVisible"
                                                        Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding InvoiceNumber}"
                                                         Value="">
                                                <Setter Property="IsVisible"
                                                        Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Button Grid.Column="1"
                                            Text="Invoice"
                                            HeightRequest="38"
                                            Padding="14,0"
                                            CornerRadius="12"
                                            BackgroundColor="{StaticResource BrandTitle}"
                                            TextColor="{StaticResource White}"
                                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsExportInvoiceVisible}"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsExportInvoiceEnabled}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ExportInvoiceCommand}"
                                            CommandParameter="{Binding Id}" />

                                    <Button Grid.Column="2"
                                            Text="POD"
                                            HeightRequest="38"
                                            Padding="14,0"
                                            CornerRadius="12"
                                            BackgroundColor="{StaticResource Primary}"
                                            TextColor="{StaticResource White}"
                                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsExportPodVisible}"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsExportPodEnabled}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ExportPodCommand}"
                                            CommandParameter="{Binding Id}" />
                                </Grid>

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <BoxView HeightRequest="6"
                     Opacity="0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>