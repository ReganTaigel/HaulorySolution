<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.AddWorkSitePage"
    Title="Add Work Site">

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="20">

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#111827'}"
                    Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Work Site"
                           FontAttributes="Bold"
                           FontSize="16"/>

                    <Entry Placeholder="Site name (e.g. Port Tauranga)"
                           Text="{Binding Name}" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        HeightRequest="42"
                        CornerRadius="12"
                        BackgroundColor="{AppThemeBinding Light='#F3F4F6', Dark='#1F2937'}"
                        TextColor="{AppThemeBinding Light='#111827', Dark='#E5E7EB'}"/>

                <Button Grid.Column="1"
                        Text="Save"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding CanSave}"
                        HeightRequest="42"
                        CornerRadius="12"
                        BackgroundColor="{AppThemeBinding Light='#2563EB', Dark='#3B82F6'}"
                        TextColor="White"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
