<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.AddWorkSitePage">
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>
    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="20">

            <!-- Page header -->
            <VerticalStackLayout Spacing="2">
                <Label Text="Add work site"
                       FontSize="24"
                       FontAttributes="Bold" />
                <Label Text="Create a work site for inductions and compliance"
                       FontSize="13"
                       Opacity="0.7" />
            </VerticalStackLayout>

            <!-- Form card -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#0B1220'}"
                    Padding="16">

                <VerticalStackLayout Spacing="14">

                    <!-- Name -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Site name"
                               FontSize="12"
                               Opacity="0.7" />

                        <Entry Placeholder="Port Tauranga"
                               Text="{Binding Name}"
                               HeightRequest="44" />

                        <Label Text="Use the common name used by your drivers"
                               FontSize="12"
                               Opacity="0.6" />
                    </VerticalStackLayout>

                    <!-- Optional future fields placeholder (keeps layout scalable) -->
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light='#F9FAFB', Dark='#111827'}"
                            Padding="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Next"
                                   FontSize="12"
                                   Opacity="0.7" />
                            <Label Text="You can add more site details later if needed"
                                   FontSize="12"
                                   Opacity="0.6" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- Actions -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        HeightRequest="46"
                        CornerRadius="14"
                        BackgroundColor="{AppThemeBinding Light='#F3F4F6', Dark='#111827'}"
                        TextColor="{AppThemeBinding Light='#111827', Dark='#E5E7EB'}"/>

                <Button Grid.Column="1"
                        Text="Save"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding CanSave}"
                        HeightRequest="46"
                        CornerRadius="14"
                        BackgroundColor="{AppThemeBinding Light='#2563EB', Dark='#3B82F6'}"
                        TextColor="White"/>
            </Grid>

            <BoxView HeightRequest="6" Opacity="0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>