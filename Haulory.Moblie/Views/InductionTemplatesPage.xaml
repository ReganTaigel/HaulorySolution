<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Haulory.Mobile.Views.InductionTemplatesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>
    <Grid Padding="20" RowDefinitions="Auto,Auto,*" RowSpacing="14">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="Work site templates"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="Create work sites and define induction requirements"
                   FontSize="13"
                   Opacity="0.7" />
        </VerticalStackLayout>

        <!-- Selector and actions -->
        <Border Grid.Row="1"
                StrokeThickness="1"
                Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                StrokeShape="RoundRectangle 18"
                BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#0B1220'}"
                Padding="16">

            <VerticalStackLayout Spacing="12">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Work site"
                           FontSize="12"
                           Opacity="0.7" />

                    <Picker Title="Select work site"
                            ItemsSource="{Binding WorkSites}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedSite}" />

                    <Label Text="Select a site to view and manage its requirements"
                           FontSize="12"
                           Opacity="0.6" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Text="Add site"
                            Command="{Binding AddSiteCommand}"
                            HeightRequest="46"
                            CornerRadius="14"
                            BackgroundColor="{AppThemeBinding Light='#F3F4F6', Dark='#111827'}"
                            TextColor="{AppThemeBinding Light='#111827', Dark='#E5E7EB'}"/>

                    <Button Grid.Column="1"
                            Text="Add requirement"
                            Command="{Binding AddRequirementCommand}"
                            HeightRequest="46"
                            CornerRadius="14"
                            BackgroundColor="{AppThemeBinding Light='#2563EB', Dark='#3B82F6'}"
                            TextColor="White"/>
                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- Requirements list -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Requirements}"
                        EmptyView="No requirements for this site yet. Tap Add requirement."
                        Margin="0,2,0,0">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#0B1220'}"
                            Padding="14"
                            Margin="0,0,0,12">

                        <VerticalStackLayout Spacing="10">

                            <!-- Title -->
                            <Label Text="{Binding Title}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />

                            <!-- Details section -->
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{AppThemeBinding Light='#F9FAFB', Dark='#111827'}"
                                    Padding="12">

                                <VerticalStackLayout Spacing="6">

                                    <!-- PPE (hide if empty) -->
                                    <Label Text="{Binding PpeRequired, StringFormat='PPE required: {0}'}"
                                           FontSize="13"
                                           Opacity="0.9"
                                           LineBreakMode="WordWrap">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding PpeRequired}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding PpeRequired}" Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- Validity -->
                                    <Label Text="{Binding ValidForDisplay}"
                                           FontSize="13"
                                           Opacity="0.9" />

                                </VerticalStackLayout>
                            </Border>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>