<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Haulory.Mobile.Views.InductionTemplatesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Templates">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label Text="Work Site Templates"
                   FontSize="22"
                   FontAttributes="Bold" />

            <Label Text="Create work sites and define their induction requirements."
                   Opacity="0.7" />
        </VerticalStackLayout>

        <Border Grid.Row="1"
                StrokeThickness="1"
                Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                StrokeShape="RoundRectangle 16"
                BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#111827'}"
                Padding="12">
            <VerticalStackLayout Spacing="10">

                <Picker Title="Select Work Site"
                        ItemsSource="{Binding WorkSites}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedSite}" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="Add Work Site"
                            Command="{Binding AddSiteCommand}"
                            HeightRequest="42"
                            CornerRadius="12"
                            BackgroundColor="{AppThemeBinding Light='#F3F4F6', Dark='#1F2937'}"
                            TextColor="{AppThemeBinding Light='#111827', Dark='#E5E7EB'}"/>

                    <Button Grid.Column="1"
                            Text="Add Requirement"
                            Command="{Binding AddRequirementCommand}"
                            HeightRequest="42"
                            CornerRadius="12"
                            BackgroundColor="{AppThemeBinding Light='#2563EB', Dark='#3B82F6'}"
                            TextColor="White"/>
                </Grid>

            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Requirements}"
                        EmptyView="No requirements for this site yet. Tap 'Add Requirement'.">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#111827'}"
                            Padding="12"
                            Margin="0,0,0,10">

                        <VerticalStackLayout Spacing="6">

                            <Label Text="{Binding Title}"
                                   FontSize="16"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding PpeRequired, StringFormat='PPE: {0}'}"
                                   FontSize="13"
                                   Opacity="0.85"
                                   IsVisible="{Binding PpeRequired}" />

                            <!-- Use a computed property instead of triggers -->
                            <Label Text="{Binding ValidForDisplay}"
                                   FontSize="13"
                                   Opacity="0.85" />

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>
