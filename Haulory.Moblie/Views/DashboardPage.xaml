<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.DashboardPage"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <!-- HEADER -->
            <VerticalStackLayout Spacing="2">
                <Label Text="Haulory"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="{StaticResource BrandTitle}" />
                <Label Text="Business overview"
                       FontSize="13"
                       TextColor="{StaticResource BrandInk}" />
            </VerticalStackLayout>

            <!-- HERO SUMMARY -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16">

                <VerticalStackLayout Spacing="10">
                    <Label Text="Today at a glance"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Label Text="{Binding CurrentJobSummary}"
                           FontSize="13"
                           TextColor="{StaticResource BrandInk}"
                           LineBreakMode="WordWrap" />

                    <Label Text="Day Status"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Label Text="{Binding AssignedVehicleDisplay}"
                           FontSize="13"
                           TextColor="{StaticResource BrandInk}" />

                    <Label Text="{Binding DayStatusText}"
                           FontSize="13"
                           TextColor="{StaticResource BrandInk}" />

                    <Button Text="Start Day"
                            Command="{Binding StartDayCommand}"
                            IsVisible="{Binding IsStartDayVisible}"
                            IsEnabled="{Binding CanStartDayAction}"
                            HeightRequest="44"
                            CornerRadius="14"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}" />

                    <Button Text="End Day"
                            Command="{Binding EndDayCommand}"
                            IsVisible="{Binding IsEndDayVisible}"
                            IsEnabled="{Binding CanEndDayAction}"
                            HeightRequest="44"
                            CornerRadius="14"
                            BackgroundColor="{StaticResource BrandTitle}"
                            TextColor="{StaticResource White}" />
                </VerticalStackLayout>

            </Border>

            <!-- STATS (Main only) -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16"
                    IsVisible="{Binding IsMainUser}">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Quick stats"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <!-- Delivered -->
                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Delivered"
                                       FontSize="12"
                                       TextColor="{StaticResource BrandInk}" />
                                <Label Text="Jobs completed today"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray600}" />
                            </VerticalStackLayout>

                            <Label Grid.Column="1"
                                   Text="{Binding CompletedTodayCount}"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Revenue -->
                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Revenue today"
                                       FontSize="12"
                                       TextColor="{StaticResource BrandInk}" />
                                <Label Text="Track earnings and trends"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray600}" />
                            </VerticalStackLayout>

                            <Label Grid.Column="1"
                                   Text="{Binding RevenueToday, StringFormat='{0:N2}'}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandAccent}"
                                   VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Latest completed -->
                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Latest completed"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}" />
                            <Label Text="{Binding LatestCompletedSummary}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandTitle}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />
                            <Label Text="Open Reports for details"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToReportsCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- ACTIONS -->
            <Label Text="Manage"
                   FontSize="16"
                   FontAttributes="Bold"
                   Margin="2,4,0,0"
                   TextColor="{StaticResource BrandTitle}" />

            <!-- Jobs -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="14"
                    IsVisible="{Binding IsJobsVisible}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Jobs"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />
                        <Label Text="Create, allocate, and track deliveries"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Open"
                            Command="{Binding GoToJobsCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            CornerRadius="14"
                            HeightRequest="44"
                            Padding="16,0"
                            IsEnabled="{Binding IsJobsEnabled}" />
                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToJobsCommand}" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Vehicles -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="14"
                    IsVisible="{Binding IsVehiclesVisible}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Vehicles"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />
                        <Label Text="Manage units, configurations, and assets"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Open"
                            Command="{Binding GoToVehiclesCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            CornerRadius="14"
                            HeightRequest="44"
                            Padding="16,0"
                            IsEnabled="{Binding IsVehiclesEnabled}" />
                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToVehiclesCommand}" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Drivers (Main only) -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="14"
                    IsVisible="{Binding IsDriversVisible}">
                <Border.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding IsMainUser}"
                                 Value="False">
                        <Setter Property="IsVisible"
                                Value="False" />
                    </DataTrigger>
                </Border.Triggers>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Drivers"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />
                        <Label Text="Profiles, licences, compliance, and contacts"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Open"
                            Command="{Binding GoToDriversCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            CornerRadius="14"
                            HeightRequest="44"
                            Padding="16,0"
                            IsEnabled="{Binding IsDriversEnabled}" />
                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToDriversCommand}" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Reports (Main only) -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="14"
                    IsVisible="{Binding IsReportsVisible}">
                <Border.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding IsMainUser}"
                                 Value="False">
                        <Setter Property="IsVisible"
                                Value="False" />
                    </DataTrigger>
                </Border.Triggers>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Reports"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />
                        <Label Text="Revenue, delivered jobs, and performance"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Open"
                            Command="{Binding GoToReportsCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            CornerRadius="14"
                            HeightRequest="44"
                            Padding="16,0"
                            IsEnabled="{Binding IsReportsEnabled}" />
                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToReportsCommand}" />
                </Border.GestureRecognizers>
            </Border>

            <!-- LOGOUT -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource BrandDanger}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandDeep}"
                    Padding="12"
                    Margin="0,6,0,10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Logout"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource White}" />
                        <Label Text="Sign out of Haulory on this device"
                               FontSize="12"
                               TextColor="{StaticResource Gray200}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Sign out"
                            Command="{Binding LogoutCommand}"
                            BackgroundColor="{StaticResource BrandDanger}"
                            TextColor="{StaticResource White}"
                            CornerRadius="14"
                            HeightRequest="44"
                            Padding="16,0" />
                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                </Border.GestureRecognizers>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>