<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.AddInductionRequirementPage"
    Title="Add Requirement">

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="20">

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#111827'}"
                    Padding="14">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Requirement"
                           FontAttributes="Bold"
                           FontSize="16"/>

                    <Label Text="{Binding WorkSiteName, StringFormat='For: {0}'}"
                           FontSize="12"
                           TextColor="Gray"
                           IsVisible="{Binding WorkSiteName}" />

                    <Entry Placeholder="Title (e.g. Safety Induction)"
                           Text="{Binding Title}" />
                    
                    <Label Text="PPE Required (optional)" />
                    <Entry Text="{Binding PpeRequired}"
                           FontSize="12"
                           Placeholder="e.g. Hi-vis, hard hat, steel caps" />

                    <Entry Placeholder="Valid for days (optional, e.g. 365)"
                           Keyboard="Numeric"
                           Text="{Binding ValidForDaysText}" />

                    <Label Text="Leave Valid for days blank if it never expires."
                           FontSize="12"
                           TextColor="Gray"/>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        HeightRequest="42"
                        CornerRadius="12"
                        BackgroundColor="{AppThemeBinding Light='#F3F4F6', Dark='#1F2937'}"
                        TextColor="{AppThemeBinding Light='#111827', Dark='#E5E7EB'}"/>

                <Button Grid.Column="1"
                        Text="Save"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding CanSave}"
                        HeightRequest="42"
                        CornerRadius="12"
                        BackgroundColor="{AppThemeBinding Light='#2563EB', Dark='#3B82F6'}"
                        TextColor="White"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
