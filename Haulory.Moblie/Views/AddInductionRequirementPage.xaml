<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.AddInductionRequirementPage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="20">

            <!-- Page header -->
            <VerticalStackLayout Spacing="2">
                <Label Text="Add requirement"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource BrandTitle}" />

                <Label Text="Create a requirement for a work site template"
                       FontSize="13"
                       TextColor="{StaticResource BrandInk}" />
            </VerticalStackLayout>

            <!-- Form card -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16">

                <VerticalStackLayout Spacing="14">

                    <!-- Context -->
                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Work site"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandTitle}" />

                            <Label Text="{Binding WorkSiteName}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandInk}"
                                   LineBreakMode="TailTruncation">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding WorkSiteName}" Value="{x:Null}">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding WorkSiteName}" Value="">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <Label Text="This requirement will be added to the selected work site"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Title -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Title"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,10">
                            <Entry Placeholder="Safety induction"
                                   Text="{Binding Title}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <Label Text="Keep it short and clear"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}"
                               Opacity="0.9" />
                    </VerticalStackLayout>

                    <!-- PPE -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="PPE required"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,10">
                            <Entry Text="{Binding PpeRequired}"
                                   Placeholder="Hi vis, hard hat, steel caps"
                                   FontSize="13"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <Label Text="Optional"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}"/>
                    </VerticalStackLayout>

                    <!-- Validity -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Valid for days"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,10">
                            <Entry Placeholder="365"
                                   Keyboard="Numeric"
                                   Text="{Binding ValidForDaysText}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <Label Text="Leave blank if it never expires"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Actions -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        HeightRequest="46"
                        CornerRadius="14"
                        BackgroundColor="{StaticResource Gray200}"
                        TextColor="{StaticResource BrandInk}" />

                <Button Grid.Column="1"
                        Text="Save"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding CanSave}"
                        HeightRequest="46"
                        CornerRadius="14"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}" />
            </Grid>

            <!-- Bottom spacing -->
            <BoxView HeightRequest="6" Opacity="0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>