<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.AddInductionRequirementPage">
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>
    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="20">

            <!-- Page header -->
            <VerticalStackLayout Spacing="2">
                <Label Text="Add requirement"
                       FontSize="24"
                       FontAttributes="Bold" />
                <Label Text="Create a requirement for a work site template"
                       FontSize="13"
                       Opacity="0.7" />
            </VerticalStackLayout>

            <!-- Form card -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#0B1220'}"
                    Padding="16">

                <VerticalStackLayout Spacing="14">

                    <!-- Context -->
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light='#F9FAFB', Dark='#111827'}"
                            Padding="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Work site"
                                   FontSize="12"
                                   Opacity="0.7" />

                            <Label Text="{Binding WorkSiteName}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding WorkSiteName}" Value="{x:Null}">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding WorkSiteName}" Value="">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <Label Text="This requirement will be added to the selected work site"
                                   FontSize="12"
                                   Opacity="0.6" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Title -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Title"
                               FontSize="12"
                               Opacity="0.7" />
                        <Entry Placeholder="Safety induction"
                               Text="{Binding Title}"
                               HeightRequest="44" />
                        <Label Text="Keep it short and clear"
                               FontSize="12"
                               Opacity="0.6" />
                    </VerticalStackLayout>

                    <!-- PPE -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="PPE required"
                               FontSize="12"
                               Opacity="0.7" />
                        <Entry Text="{Binding PpeRequired}"
                               Placeholder="Hi vis, hard hat, steel caps"
                               FontSize="13"
                               HeightRequest="44" />
                        <Label Text="Optional"
                               FontSize="12"
                               Opacity="0.6" />
                    </VerticalStackLayout>

                    <!-- Validity -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Valid for days"
                               FontSize="12"
                               Opacity="0.7" />
                        <Entry Placeholder="365"
                               Keyboard="Numeric"
                               Text="{Binding ValidForDaysText}"
                               HeightRequest="44" />
                        <Label Text="Leave blank if it never expires"
                               FontSize="12"
                               Opacity="0.6" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Actions -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        HeightRequest="46"
                        CornerRadius="14"
                        BackgroundColor="{AppThemeBinding Light='#F3F4F6', Dark='#111827'}"
                        TextColor="{AppThemeBinding Light='#111827', Dark='#E5E7EB'}"/>

                <Button Grid.Column="1"
                        Text="Save"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding CanSave}"
                        HeightRequest="46"
                        CornerRadius="14"
                        BackgroundColor="{AppThemeBinding Light='#2563EB', Dark='#3B82F6'}"
                        TextColor="White"/>
            </Grid>

            <!-- Bottom spacing -->
            <BoxView HeightRequest="6" Opacity="0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>