<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.NewDriverPage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <!-- Page header -->
            <VerticalStackLayout Spacing="2">
                <Label Text="Add People"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource BrandTitle}" />
                <Label Text="Create a driver profile and emergency contact"
                       FontSize="13"
                       TextColor="{StaticResource BrandInk}" />
            </VerticalStackLayout>

            <!-- DRIVER DETAILS -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16">

                <VerticalStackLayout Spacing="12">
                    <Label Text="Driver details"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">
                        <VerticalStackLayout Spacing="10">

                            <Entry Placeholder="First name"
                                   Text="{Binding FirstName}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Entry Placeholder="Last name"
                                   Text="{Binding LastName}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Entry Placeholder="Email"
                                   Keyboard="Email"
                                   Text="{Binding Email}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Entry Placeholder="Licence number (optional)"
                                   Text="{Binding LicenceNumber}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <!-- ✅ NEW: Optional login account -->
                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandSurface}"
                                    Padding="12"
                                    Margin="0,4,0,0">
                                <VerticalStackLayout Spacing="10">

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Create login for this driver"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource BrandTitle}" />
                                            <Label Text="Allows this driver to sign in on their phone"
                                                   FontSize="12"
                                                   TextColor="{StaticResource BrandInk}"
                                                   Opacity="0.85" />
                                        </VerticalStackLayout>

                                        <Switch Grid.Column="1"
                                                IsToggled="{Binding CreateLoginAccount}"
                                                VerticalOptions="Center" />
                                    </Grid>

                                    <!-- Password row (only visible when CreateLoginAccount = true) -->
                                    <VerticalStackLayout Spacing="6">
                                        <VerticalStackLayout.Triggers>
                                            <DataTrigger TargetType="VerticalStackLayout"
                                                         Binding="{Binding CreateLoginAccount}"
                                                         Value="False">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </VerticalStackLayout.Triggers>

                                        <Label Text="Temporary password"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandTitle}" />

                                        <Entry Placeholder="Password"
                                               Text="{Binding Password}"
                                               IsPassword="True"
                                               HeightRequest="44"
                                               TextColor="{StaticResource BrandInk}"
                                               PlaceholderColor="{StaticResource Gray600}" />

                                        <Label Text="You can reset this later in Manage Users."
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}"
                                               Opacity="0.85" />
                                    </VerticalStackLayout>

                                </VerticalStackLayout>
                            </Border>

                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- CONTACT AND LICENCE -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16">

                <VerticalStackLayout Spacing="12">
                    <Label Text="Contact and licence"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">

                        <VerticalStackLayout Spacing="12">

                            <!-- Phone -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Phone number"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource BrandTitle}" />
                                <Entry Placeholder="Optional"
                                       Keyboard="Telephone"
                                       Text="{Binding PhoneNumber}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </VerticalStackLayout>

                            <!-- DOB + Licence Expiry -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="6">
                                    <Label Text="Date of birth"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}" />
                                    <Border StrokeThickness="1"
                                            Stroke="{StaticResource Gray200}"
                                            StrokeShape="RoundRectangle 12"
                                            BackgroundColor="{StaticResource BrandSurface}"
                                            Padding="10,6">
                                        <DatePicker Date="{Binding DateOfBirthLocal}"
                                                    TextColor="{StaticResource BrandInk}" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="6">
                                    <Label Text="Licence expiry"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}" />
                                    <Border StrokeThickness="1"
                                            Stroke="{StaticResource Gray200}"
                                            StrokeShape="RoundRectangle 12"
                                            BackgroundColor="{StaticResource BrandSurface}"
                                            Padding="10,6">
                                        <DatePicker Date="{Binding LicenceExpiryLocal}"
                                                    TextColor="{StaticResource BrandInk}" />
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Licence Version -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Licence version"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource BrandTitle}" />
                                <Entry Placeholder="e.g., V3 / Card version"
                                       Text="{Binding LicenceVersion}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </VerticalStackLayout>

                            <!-- Class / endorsements -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Class / endorsements"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource BrandTitle}" />
                                <Entry Placeholder="e.g., Class 5, D, F"
                                       Text="{Binding LicenceClassOrEndorsements}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </VerticalStackLayout>

                            <!-- Issued date -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Issued date"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource BrandTitle}" />
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray200}"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{StaticResource BrandSurface}"
                                        Padding="10,6">
                                    <DatePicker Date="{Binding LicenceIssuedLocal}"
                                                TextColor="{StaticResource BrandInk}" />
                                </Border>
                            </VerticalStackLayout>

                            <!-- Conditions / notes -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Conditions / notes"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource BrandTitle}" />
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray200}"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{StaticResource BrandSurface}"
                                        Padding="10,8">
                                    <Editor Placeholder="e.g., Must wear corrective lenses, restricted hours..."
                                            Text="{Binding LicenceConditionsNotes}"
                                            AutoSize="TextChanges"
                                            HeightRequest="110"
                                            TextColor="{StaticResource BrandInk}" />
                                </Border>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ADDRESS -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16">

                <VerticalStackLayout Spacing="12">
                    <Label Text="Address"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Label Text="Optional"
                           FontSize="12"
                           TextColor="{StaticResource BrandInk}"/>

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">

                        <VerticalStackLayout Spacing="10">

                            <Entry Placeholder="Address line 1"
                                   Text="{Binding Line1}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Entry Placeholder="Address line 2"
                                   Text="{Binding Line2}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Entry Grid.Column="0"
                                       Placeholder="Suburb"
                                       Text="{Binding Suburb}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                                <Entry Grid.Column="1"
                                       Placeholder="City"
                                       Text="{Binding City}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Entry Grid.Column="0"
                                       Placeholder="Region"
                                       Text="{Binding Region}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                                <Entry Grid.Column="1"
                                       Placeholder="Postcode"
                                       Text="{Binding Postcode}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Grid>

                            <Entry Placeholder="Country"
                                   Text="{Binding Country}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- EMERGENCY CONTACT -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16">

                <VerticalStackLayout Spacing="12">
                    <Label Text="Emergency contact"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Label Text="Required for compliance and safety"
                           FontSize="12"
                           TextColor="{StaticResource BrandInk}"/>

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12">

                        <VerticalStackLayout Spacing="10">

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Entry Grid.Column="0"
                                       Placeholder="First name"
                                       Text="{Binding EmergencyFirstName}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />

                                <Entry Grid.Column="1"
                                       Placeholder="Last name"
                                       Text="{Binding EmergencyLastName}"
                                       HeightRequest="44"
                                       TextColor="{StaticResource BrandInk}"
                                       PlaceholderColor="{StaticResource Gray600}" />
                            </Grid>

                            <Entry Placeholder="Relationship"
                                   Text="{Binding EmergencyRelationship}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Entry Placeholder="Email"
                                   Keyboard="Email"
                                   Text="{Binding EmergencyEmail}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Entry Placeholder="Phone number"
                                   Keyboard="Telephone"
                                   Text="{Binding EmergencyPhoneNumber}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                            <Entry Placeholder="Secondary phone number (optional)"
                                   Keyboard="Telephone"
                                   Text="{Binding EmergencySecondaryPhoneNumber}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}" />

                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- SAVE -->
            <Button Text="Save driver"
                    Command="{Binding SaveDriverCommand}"
                    IsEnabled="{Binding CanSave}"
                    HeightRequest="50"
                    CornerRadius="14"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{StaticResource White}"
                    Margin="0,4,0,8" />

            <BoxView HeightRequest="6" Opacity="0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>