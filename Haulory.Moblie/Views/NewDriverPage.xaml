<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.NewDriverPage"
    Title="Add Driver">

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="20">

            <!-- DRIVER DETAILS -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#111827'}"
                    Padding="14">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Driver Details"
                           FontAttributes="Bold"
                           FontSize="16"/>

                    <Entry Placeholder="First name"
                           Text="{Binding FirstName}" />

                    <Entry Placeholder="Last name"
                           Text="{Binding LastName}" />

                    <Entry Placeholder="Email"
                           Keyboard="Email"
                           Text="{Binding Email}" />

                    <Entry Placeholder="Licence number (optional)"
                           Text="{Binding LicenceNumber}" />

                </VerticalStackLayout>
            </Border>

            <!-- CONTACT + LICENCE + ADDRESS -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#111827'}"
                    Padding="14">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Contact and Licence"
                           FontAttributes="Bold"
                           FontSize="16"/>

                    <Entry Placeholder="Phone number (optional)"
                           Keyboard="Telephone"
                           Text="{Binding PhoneNumber}" />

                    <Label Text="Date of birth (optional)"
                           FontSize="12"
                           Opacity="0.7" />
                    <DatePicker Date="{Binding DateOfBirthLocal}" />

                    <Label Text="Licence expiry (optional)"
                           FontSize="12"
                           Opacity="0.7" />
                    <DatePicker Date="{Binding LicenceExpiryLocal}" />

                    <Label Text="Address (optional)"
                           FontSize="12"
                           Opacity="0.7" />

                    <Entry Placeholder="Address line 1"
                           Text="{Binding Line1}" />

                    <Entry Placeholder="Address line 2"
                           Text="{Binding Line2}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Entry Grid.Column="0"
                               Placeholder="Suburb"
                               Text="{Binding Suburb}" />
                        <Entry Grid.Column="1"
                               Placeholder="City"
                               Text="{Binding City}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Entry Grid.Column="0"
                               Placeholder="Region"
                               Text="{Binding Region}" />
                        <Entry Grid.Column="1"
                               Placeholder="Postcode"
                               Text="{Binding Postcode}" />
                    </Grid>

                    <Entry Placeholder="Country"
                           Text="{Binding Country}" />

                </VerticalStackLayout>
            </Border>

            <!-- EMERGENCY CONTACT -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#111827'}"
                    Padding="14">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Emergency Contact"
                           FontAttributes="Bold"
                           FontSize="16"/>

                    <Entry Placeholder="First name"
                           Text="{Binding EmergencyFirstName}" />

                    <Entry Placeholder="Last name"
                           Text="{Binding EmergencyLastName}" />

                    <Entry Placeholder="Relationship"
                           Text="{Binding EmergencyRelationship}" />

                    <Entry Placeholder="Email"
                           Keyboard="Email"
                           Text="{Binding EmergencyEmail}" />

                    <Entry Placeholder="Phone number"
                           Keyboard="Telephone"
                           Text="{Binding EmergencyPhoneNumber}" />

                    <Entry Placeholder="Secondary phone number (optional)"
                           Keyboard="Telephone"
                           Text="{Binding EmergencySecondaryPhoneNumber}" />

                </VerticalStackLayout>
            </Border>

            <Button Text="Save Driver"
                    Command="{Binding SaveDriverCommand}"
                    IsEnabled="{Binding CanSave}"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
