<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.JobsCollectionPage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*"
          Padding="20"
          RowSpacing="14"
          IsVisible="{Binding IsJobsVisible}">

        <!-- HEADER -->
        <VerticalStackLayout Grid.Row="0" Spacing="10">

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12"
                  VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Jobs"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Label Text="Active deliveries"
                           FontSize="13"
                           TextColor="{StaticResource BrandInk}" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Add"
                        Command="{Binding AddJobCommand}"
                        IsVisible="{Binding IsAddJobVisible}"
                        IsEnabled="{Binding IsAddJobEnabled}"
                        HeightRequest="44"
                        Padding="16,0"
                        CornerRadius="14"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}" />
            </Grid>

            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="14">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Tip"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Label Text="Tap Sign delivery when complete"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandInk}"
                           IsVisible="{Binding IsMainUser}" />

                    <Label Text="Tap Sign delivery to complete your assigned job"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandInk}"
                           IsVisible="{Binding IsSubUser}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- SUB USER FLAT LIST -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Jobs}"
                        SelectionMode="None"
                        Margin="0,2,0,0"
                        IsVisible="{Binding IsSubUser}">

            <CollectionView.EmptyView>
                <Grid>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="6"
                                         Padding="24">
                        <Label Text="No assigned jobs right now"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray300}"
                            BackgroundColor="{StaticResource BrandSurface}"
                            StrokeShape="RoundRectangle 18"
                            Padding="14"
                            Margin="0,0,0,12">

                        <VerticalStackLayout Spacing="12">

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12"
                                  VerticalOptions="Center">

                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding ReferenceNumber}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="{Binding LoadDescription}"
                                           FontSize="12"
                                           TextColor="{StaticResource BrandInk}"
                                           Opacity="0.9"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2" />
                                </VerticalStackLayout>
                            </Grid>

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12">
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10"
                                      RowSpacing="8">

                                    <Label Text="Driver"
                                           Grid.Row="0"
                                           Grid.Column="0"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}" />

                                    <Label Text="{Binding DriverName}"
                                           Grid.Row="0"
                                           Grid.Column="1"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandInk}"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="Truck"
                                           Grid.Row="1"
                                           Grid.Column="0"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}" />

                                    <Label Text="{Binding TruckDisplay}"
                                           Grid.Row="1"
                                           Grid.Column="1"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}"
                                           LineBreakMode="TailTruncation" />
                                </Grid>
                            </Border>

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12">
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10"
                                      RowSpacing="10">

                                    <Label Text="Pickup"
                                           Grid.Row="0"
                                           Grid.Column="0"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}" />

                                    <VerticalStackLayout Grid.Row="0"
                                                         Grid.Column="1"
                                                         Spacing="2">
                                        <Label Text="{Binding PickupCompany}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandInk}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding PickupAddress}"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                    </VerticalStackLayout>

                                    <Label Text="Drop"
                                           Grid.Row="1"
                                           Grid.Column="0"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}" />

                                    <VerticalStackLayout Grid.Row="1"
                                                         Grid.Column="1"
                                                         Spacing="2">
                                        <Label Text="{Binding DeliveryCompany}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandInk}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding DeliveryAddress}"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>

                            <Button Text="Sign delivery"
                                    HeightRequest="46"
                                    CornerRadius="14"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource White}"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsDeliverySignatureVisible}"
                                    IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsDeliverySignatureEnabled}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SignDeliveryCommand}"
                                    CommandParameter="{Binding .}" />

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- MAIN USER GROUPED LIST -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding JobGroups}"
                        SelectionMode="None"
                        Margin="0,2,0,0"
                        IsVisible="{Binding IsMainUser}">

            <CollectionView.EmptyView>
                <Grid>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="6"
                                         Padding="24">
                        <Label Text="No jobs yet"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Use Add to create your first job."
                               FontSize="13"
                               TextColor="{StaticResource BrandInk}"
                               HorizontalTextAlignment="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsAddJobVisible}"
                                             Value="False">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>
                </Grid>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray300}"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{StaticResource BrandSurface}"
                            Padding="14"
                            Margin="0,0,0,12">

                        <VerticalStackLayout Spacing="12">

                            <!-- GROUP HEADER -->
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">

                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Title}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}" />

                                    <Label Text="{Binding Jobs.Count, StringFormat='Jobs: {0}'}"
                                           FontSize="12"
                                           TextColor="{StaticResource BrandInk}" />
                                </VerticalStackLayout>

                                <Button Grid.Column="1"
                                        Text="{Binding ExpandCollapseGlyph}"
                                        Command="{Binding ToggleExpandedCommand}"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        CornerRadius="12"
                                        Padding="0"
                                        BackgroundColor="{StaticResource Gray200}"
                                        TextColor="{StaticResource BrandInk}" />
                            </Grid>

                            <!-- GROUP JOBS -->
                            <CollectionView ItemsSource="{Binding Jobs}"
                                            SelectionMode="None"
                                            IsVisible="{Binding IsExpanded}">

                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border StrokeThickness="1"
                                                Stroke="{StaticResource Gray200}"
                                                BackgroundColor="{StaticResource BrandTileFill}"
                                                StrokeShape="RoundRectangle 16"
                                                Padding="14"
                                                Margin="0,0,0,10">

                                            <VerticalStackLayout Spacing="12">

                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="12"
                                                      VerticalOptions="Center">

                                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                        <Label Text="{Binding ReferenceNumber}"
                                                               FontSize="16"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource BrandTitle}"
                                                               LineBreakMode="TailTruncation" />

                                                        <Label Text="{Binding LoadDescription}"
                                                               FontSize="12"
                                                               TextColor="{StaticResource BrandInk}"
                                                               Opacity="0.9"
                                                               LineBreakMode="TailTruncation"
                                                               MaxLines="2" />
                                                    </VerticalStackLayout>

                                                    <VerticalStackLayout Grid.Column="1"
                                                                         Spacing="8"
                                                                         VerticalOptions="Center">
                                                        <Button Text="Up"
                                                                FontSize="13"
                                                                WidthRequest="56"
                                                                HeightRequest="34"
                                                                CornerRadius="12"
                                                                Padding="0"
                                                                BackgroundColor="{StaticResource Gray200}"
                                                                TextColor="{StaticResource BrandInk}"
                                                                IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsJobsEnabled}"
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MoveUpCommand}"
                                                                CommandParameter="{Binding .}" />

                                                        <Button Text="Down"
                                                                FontSize="13"
                                                                WidthRequest="56"
                                                                HeightRequest="34"
                                                                CornerRadius="12"
                                                                Padding="0"
                                                                BackgroundColor="{StaticResource Gray200}"
                                                                TextColor="{StaticResource BrandInk}"
                                                                IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsJobsEnabled}"
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MoveDownCommand}"
                                                                CommandParameter="{Binding .}" />
                                                    </VerticalStackLayout>
                                                </Grid>

                                                <Border StrokeThickness="1"
                                                        Stroke="{StaticResource Gray200}"
                                                        StrokeShape="RoundRectangle 14"
                                                        BackgroundColor="{StaticResource BrandSurface}"
                                                        Padding="12">
                                                    <Grid RowDefinitions="Auto,Auto"
                                                          ColumnDefinitions="Auto,*"
                                                          ColumnSpacing="10"
                                                          RowSpacing="8">

                                                        <Label Text="Driver"
                                                               Grid.Row="0"
                                                               Grid.Column="0"
                                                               FontSize="12"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource BrandTitle}" />

                                                        <Label Text="{Binding DriverName}"
                                                               Grid.Row="0"
                                                               Grid.Column="1"
                                                               FontSize="13"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource BrandInk}"
                                                               LineBreakMode="TailTruncation" />

                                                        <Label Text="Truck"
                                                               Grid.Row="1"
                                                               Grid.Column="0"
                                                               FontSize="12"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource BrandTitle}" />

                                                        <Label Text="{Binding TruckDisplay}"
                                                               Grid.Row="1"
                                                               Grid.Column="1"
                                                               FontSize="13"
                                                               TextColor="{StaticResource BrandInk}"
                                                               LineBreakMode="TailTruncation" />
                                                    </Grid>
                                                </Border>

                                                <Border StrokeThickness="1"
                                                        Stroke="{StaticResource Gray200}"
                                                        StrokeShape="RoundRectangle 14"
                                                        BackgroundColor="{StaticResource BrandSurface}"
                                                        Padding="12">
                                                    <Grid RowDefinitions="Auto,Auto"
                                                          ColumnDefinitions="Auto,*"
                                                          ColumnSpacing="10"
                                                          RowSpacing="10">

                                                        <Label Text="Pickup"
                                                               Grid.Row="0"
                                                               Grid.Column="0"
                                                               FontSize="12"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource BrandTitle}" />

                                                        <VerticalStackLayout Grid.Row="0"
                                                                             Grid.Column="1"
                                                                             Spacing="2">
                                                            <Label Text="{Binding PickupCompany}"
                                                                   FontSize="13"
                                                                   FontAttributes="Bold"
                                                                   TextColor="{StaticResource BrandInk}"
                                                                   LineBreakMode="TailTruncation" />
                                                            <Label Text="{Binding PickupAddress}"
                                                                   FontSize="12"
                                                                   TextColor="{StaticResource BrandInk}"
                                                                   LineBreakMode="TailTruncation"
                                                                   MaxLines="2" />
                                                        </VerticalStackLayout>

                                                        <Label Text="Drop"
                                                               Grid.Row="1"
                                                               Grid.Column="0"
                                                               FontSize="12"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource BrandTitle}" />

                                                        <VerticalStackLayout Grid.Row="1"
                                                                             Grid.Column="1"
                                                                             Spacing="2">
                                                            <Label Text="{Binding DeliveryCompany}"
                                                                   FontSize="13"
                                                                   FontAttributes="Bold"
                                                                   TextColor="{StaticResource BrandInk}"
                                                                   LineBreakMode="TailTruncation" />
                                                            <Label Text="{Binding DeliveryAddress}"
                                                                   FontSize="12"
                                                                   TextColor="{StaticResource BrandInk}"
                                                                   LineBreakMode="TailTruncation"
                                                                   MaxLines="2" />
                                                        </VerticalStackLayout>
                                                    </Grid>
                                                </Border>

                                                <Border StrokeThickness="1"
                                                        Stroke="{StaticResource Gray200}"
                                                        StrokeShape="RoundRectangle 14"
                                                        BackgroundColor="{StaticResource BrandSurface}"
                                                        Padding="12">
                                                    <VerticalStackLayout Spacing="4">
                                                        <Label Text="{Binding RateLine}"
                                                               FontSize="12"
                                                               TextColor="{StaticResource BrandInk}" />
                                                        <Label Text="{Binding TotalLine}"
                                                               FontSize="12"
                                                               TextColor="{StaticResource BrandInk}" />
                                                    </VerticalStackLayout>
                                                </Border>

                                                <Button Text="Sign delivery"
                                                        HeightRequest="46"
                                                        CornerRadius="14"
                                                        BackgroundColor="{StaticResource Primary}"
                                                        TextColor="{StaticResource White}"
                                                        IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsDeliverySignatureVisible}"
                                                        IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsDeliverySignatureEnabled}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SignDeliveryCommand}"
                                                        CommandParameter="{Binding .}" />

                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>