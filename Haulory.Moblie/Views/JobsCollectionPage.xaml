<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.JobsCollectionPage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*"
          Padding="20"
          RowSpacing="14">

        <!-- HEADER -->
        <VerticalStackLayout Grid.Row="0" Spacing="10">

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Jobs"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Label Text="Active deliveries"
                           FontSize="13"
                           TextColor="{StaticResource BrandInk}" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Add"
                        Command="{Binding AddJobCommand}"
                        HeightRequest="44"
                        Padding="16,0"
                        CornerRadius="14"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}" />
            </Grid>

            <!-- Optional summary strip -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="14">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Tip"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />
                    <Label Text="Tap Sign Delivery when complete"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandInk}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- JOB LIST -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Jobs}"
                        SelectionMode="None"
                        Margin="0,2,0,0">

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="6"
                                     Padding="24">
                    <Label Text="No jobs yet"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />
                    <Label Text="Tap Add to create your first job."
                           FontSize="13"
                           TextColor="{StaticResource BrandInk}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray300}"
                            BackgroundColor="{StaticResource BrandSurface}"
                            StrokeShape="RoundRectangle 18"
                            Padding="14"
                            Margin="0,0,0,12">

                        <VerticalStackLayout Spacing="12">

                            <!-- TOP ROW: Reference + reorder -->
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12"
                                  VerticalOptions="Center">

                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding ReferenceNumber}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="{Binding LoadDescription}"
                                           FontSize="12"
                                           TextColor="{StaticResource BrandInk}"
                                           Opacity="0.9"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2" />
                                </VerticalStackLayout>

                                <!-- Reorder controls -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                    <Button Text="Up"
                                            FontSize="13"
                                            WidthRequest="56"
                                            HeightRequest="34"
                                            CornerRadius="12"
                                            Padding="0"
                                            BackgroundColor="{StaticResource Gray200}"
                                            TextColor="{StaticResource BrandInk}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MoveUpCommand}"
                                            CommandParameter="{Binding .}" />

                                    <Button Text="Down"
                                            FontSize="13"
                                            WidthRequest="56"
                                            HeightRequest="34"
                                            CornerRadius="12"
                                            Padding="0"
                                            BackgroundColor="{StaticResource Gray200}"
                                            TextColor="{StaticResource BrandInk}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MoveDownCommand}"
                                            CommandParameter="{Binding .}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- ASSIGNMENT SUMMARY -->
                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12">
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10"
                                      RowSpacing="8">

                                    <Label Text="Driver"
                                           Grid.Row="0" Grid.Column="0"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}" />

                                    <Label Text="{Binding DriverName}"
                                           Grid.Row="0" Grid.Column="1"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandInk}"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="Truck"
                                           Grid.Row="1" Grid.Column="0"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}" />

                                    <Label Text="{Binding TruckDisplay}"
                                           Grid.Row="1" Grid.Column="1"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}"
                                           LineBreakMode="TailTruncation" />
                                </Grid>
                            </Border>

                            <!-- PICKUP AND DROP -->
                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12">
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10"
                                      RowSpacing="10">

                                    <Label Text="Pickup"
                                           Grid.Row="0" Grid.Column="0"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}" />

                                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding PickupCompany}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandInk}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding PickupAddress}"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                    </VerticalStackLayout>

                                    <Label Text="Drop"
                                           Grid.Row="1" Grid.Column="0"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}" />

                                    <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding DeliveryCompany}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandInk}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding DeliveryAddress}"
                                               FontSize="12"
                                               TextColor="{StaticResource BrandInk}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>

                            <!-- PRICING -->
                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding RateLine}"
                                           FontSize="12"
                                           TextColor="{StaticResource BrandInk}"/>
                                    <Label Text="{Binding TotalLine}"
                                           FontSize="12"
                                           TextColor="{StaticResource BrandInk}"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- PRIMARY ACTION -->
                            <Button Text="Sign delivery"
                                    HeightRequest="46"
                                    CornerRadius="14"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource White}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SignDeliveryCommand}"
                                    CommandParameter="{Binding .}" />

                        </VerticalStackLayout>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>