<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.DeliverySignaturePage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="*,Auto"
          Padding="0"
          RowSpacing="0">

        <!-- SCROLLABLE DETAILS -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="14">

                <!-- Page header -->
                <VerticalStackLayout Spacing="2">
                    <Label Text="Delivery signature"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />
                    <Label Text="Confirm receiver and capture signature"
                           FontSize="13"
                           TextColor="{StaticResource BrandInk}" />
                </VerticalStackLayout>

                <!-- Job details card -->
                <Border StrokeThickness="1"
                        Stroke="{StaticResource Gray300}"
                        StrokeShape="RoundRectangle 18"
                        BackgroundColor="{StaticResource BrandSurface}"
                        Padding="16">

                    <VerticalStackLayout Spacing="10">

                        <Label Text="Delivery details"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12">
                            <VerticalStackLayout Spacing="6">

                                <Label Text="{Binding ReferenceNumber}"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       TextColor="{StaticResource BrandTitle}"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding PickupCompany}"
                                       FontSize="13"
                                       TextColor="{StaticResource BrandInk}"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding DeliveryCompany}"
                                       FontSize="13"
                                       TextColor="{StaticResource BrandInk}"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding LoadDescription}"
                                       FontSize="13"
                                       TextColor="{StaticResource BrandInk}"
                                       LineBreakMode="WordWrap"
                                       MaxLines="3" />

                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- Receiver card -->
                <Border StrokeThickness="1"
                        Stroke="{StaticResource Gray300}"
                        StrokeShape="RoundRectangle 18"
                        BackgroundColor="{StaticResource BrandSurface}"
                        Padding="16">

                    <VerticalStackLayout Spacing="12">

                        <Label Text="Receiver"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />

                        <Label Text="Full name as shown on the delivery"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}"/>

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,10">

                            <Entry Placeholder="Receiver full name"
                                   Text="{Binding ReceiverName}"
                                   HeightRequest="44"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}"
                                   BackgroundColor="Transparent" />
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- Breathing room so last card is not hidden behind panel -->
                <BoxView HeightRequest="10" Opacity="0" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- FIXED SIGNATURE PANEL -->
        <Border Grid.Row="1"
                StrokeThickness="1"
                Stroke="{StaticResource Gray300}"
                StrokeShape="RoundRectangle 20"
                BackgroundColor="{StaticResource BrandSurface}"
                Padding="14"
                Margin="12,8,12,12">

            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                  RowSpacing="10">

                <!-- Title -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Signature"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />
                        <Label Text="Sign in the area below"
                               FontSize="12"
                               TextColor="{StaticResource BrandInk}"/>
                    </VerticalStackLayout>

                    <!-- Optional signature state text -->
                    <Label Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           FontSize="12"
                           TextColor="{StaticResource BrandInk}"
                           VerticalTextAlignment="Center"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />
                </Grid>

                <!-- Signature surface -->
                <Border Grid.Row="1"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray200}"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="{StaticResource BrandTileFill}"
                        Padding="10">

                    <GraphicsView x:Name="SignatureView"
                                  HeightRequest="180"
                                  Drawable="{Binding SignatureDrawable}"
                                  StartInteraction="OnStartInteraction"
                                  DragInteraction="OnDragInteraction"
                                  EndInteraction="OnEndInteraction" />
                </Border>

                <!-- Buttons -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12">

                    <Button Grid.Column="0"
                            Text="Clear"
                            HeightRequest="46"
                            CornerRadius="14"
                            BackgroundColor="{StaticResource Gray200}"
                            TextColor="{StaticResource BrandInk}"
                            Command="{Binding ClearSignatureCommand}" />

                    <Button Grid.Column="1"
                            Text="Save delivery"
                            HeightRequest="46"
                            CornerRadius="14"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            Command="{Binding SaveCommand}" />
                </Grid>

                <!-- Secondary status line -->
                <Label Grid.Row="3"
                       Text="{Binding StatusMessage}"
                       FontSize="12"
                       TextColor="{StaticResource BrandInk}"
                       LineBreakMode="TailTruncation"
                       MaxLines="2" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>