<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Haulory.Mobile.Views.DriverCollectionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Drivers">

    <Grid RowDefinitions="Auto,*"
          Padding="16"
          RowSpacing="12">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="10"
              VerticalOptions="Center">

            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Drivers"
                       FontSize="26"
                       FontAttributes="Bold" />

                <Label Text="Tap a driver to edit details"
                       FontSize="13"
                       TextColor="Gray" />
            </VerticalStackLayout>

            <!-- Manage Inductions (main account admin) -->
            <Button Grid.Column="1"
                    Text="Inductions"
                    HeightRequest="40"
                    Padding="14,0"
                    CornerRadius="12"
                    BackgroundColor="{AppThemeBinding Light='#111827', Dark='#E5E7EB'}"
                    TextColor="{AppThemeBinding Light='White', Dark='Black'}"
                    Command="{Binding ManageInductionsCommand}" />

            <!-- Add Driver -->
            <Button Grid.Column="2"
                    Text="Add Driver"
                    HeightRequest="40"
                    Padding="14,0"
                    CornerRadius="12"
                    BackgroundColor="{AppThemeBinding Light='#2563EB', Dark='#3B82F6'}"
                    TextColor="White"
                    Command="{Binding AddDriverCommand}"
                    IsVisible="{Binding ShowAddDriver}" />
        </Grid>

        <!-- DRIVER LIST -->
        <Border Grid.Row="1"
                StrokeThickness="1"
                Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                StrokeShape="RoundRectangle 16"
                BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#111827'}"
                Padding="12">

            <CollectionView ItemsSource="{Binding Drivers}"
                            SelectionMode="Single"
                            SelectionChanged="OnDriverSelected"
                            EmptyView="No drivers added yet.">

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border StrokeThickness="1"
                                Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#111827'}"
                                Padding="12"
                                Margin="0,0,0,10">

                            <VerticalStackLayout Spacing="8">

                                <!-- Name + badges -->
                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="8"
                                      VerticalOptions="Center">

                                    <!-- Name -->
                                    <Label Grid.Column="0"
                                           Text="{Binding Driver.DisplayName}"
                                           FontAttributes="Bold"
                                           FontSize="16" />

                                    <!-- MAIN badge -->
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light='#F3F4F6', Dark='#1F2937'}"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="10,4"
                                            IsVisible="{Binding Driver.IsMainProfile}">
                                        <Label Text="MAIN"
                                               FontSize="12"
                                               Opacity="0.85" />
                                    </Border>

                                    <!-- Warning badge (shows if any expiring/expired) -->
                                    <Border Grid.Column="2"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light='#FEF3C7', Dark='#78350F'}"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="10,4"
                                            IsVisible="{Binding HasWarnings}">
                                        <Label Text="INDUCTIONS"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light='#92400E', Dark='White'}"
                                               Opacity="0.95" />
                                    </Border>

                                </Grid>

                                <!-- Expiry counts row -->
                                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
                                      ColumnSpacing="10"
                                      IsVisible="{Binding HasWarnings}">

                                    <!-- Expired -->
                                    <Border Grid.Column="0"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light='#FEE2E2', Dark='#7F1D1D'}"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="10,4"
                                            IsVisible="{Binding ExpiredCount}">
                                        <Label Text="{Binding ExpiredCount, StringFormat='Expired: {0}'}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light='#991B1B', Dark='White'}" />
                                    </Border>

                                    <!-- Expiring soon -->
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light='#FFEDD5', Dark='#7C2D12'}"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="10,4"
                                            IsVisible="{Binding ExpiringSoonCount}">
                                        <Label Text="{Binding ExpiringSoonCount, StringFormat='Expiring: {0}'}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light='#9A3412', Dark='White'}" />
                                    </Border>

                                    <!-- helper text -->
                                    <Label Grid.Column="2"
                                           Text="(within 30 days)"
                                           FontSize="12"
                                           Opacity="0.7"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding ExpiringSoonCount}" />
                                </Grid>

                                <!-- Email -->
                                <Label Text="{Binding Driver.Email}"
                                       FontSize="13"
                                       Opacity="0.85"
                                       IsVisible="{Binding Driver.Email}" />

                                <!-- Licence -->
                                <Label Text="{Binding Driver.LicenceNumber, StringFormat='Licence: {0}'}"
                                       FontSize="13"
                                       Opacity="0.85"
                                       IsVisible="{Binding Driver.LicenceNumber}" />
                                
                                <!-- Phone -->
                                <Label Text="{Binding Driver.PhoneNumber, StringFormat='Phone: {0}'}"
                                       FontSize="13"
                                       Opacity="0.85"
                                       IsVisible="{Binding Driver.PhoneNumber}" />

                                <!-- Date of Birth -->
                                <Label Text="{Binding Driver.DateOfBirthUtc, StringFormat='DOB: {0:yyyy-MM-dd}'}"
                                       FontSize="13"
                                       Opacity="0.85"
                                       IsVisible="{Binding Driver.DateOfBirthUtc}" />

                                <!-- Licence expiry -->
                                <Label Text="{Binding Driver.LicenceExpiresOnUtc, StringFormat='Licence expires: {0:yyyy-MM-dd}'}"
                                       FontSize="13"
                                       Opacity="0.85"
                                       IsVisible="{Binding Driver.LicenceExpiresOnUtc}" />

                                <!-- Address (summary) -->
                                <Label Text="{Binding Driver.AddressSummary}"
                                       FontSize="13"
                                       Opacity="0.85"
                                       IsVisible="{Binding Driver.AddressSummary}" />

                                <!-- Emergency contact details show only if fully set -->
                                <Border StrokeThickness="1"
                                        Stroke="{AppThemeBinding Light='#EEF2F7', Dark='#374151'}"
                                        StrokeShape="RoundRectangle 10"
                                        Padding="10"
                                        IsVisible="{Binding Driver.EmergencyContact.IsSet}">
                                    <VerticalStackLayout Spacing="3">
                                        <Label Text="Emergency Contact"
                                               FontSize="12"
                                               Opacity="0.7" />

                                        <Label FontSize="13"
                                               Text="{Binding Driver.EmergencyContact.FirstName, StringFormat='Name: {0}'}" />

                                        <Label FontSize="13"
                                               Text="{Binding Driver.EmergencyContact.PhoneNumber, StringFormat='Phone: {0}'}" />

                                        <Label FontSize="13"
                                               Text="{Binding Driver.EmergencyContact.Email, StringFormat='Email: {0}'}" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Status -->
                                <Label Text="{Binding Driver.EmergencyStatus}"
                                       FontSize="12"
                                       Opacity="0.7" />

                            </VerticalStackLayout>
                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </Border>

    </Grid>
</ContentPage>
