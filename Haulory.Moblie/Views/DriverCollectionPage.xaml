<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Haulory.Mobile.Views.DriverCollectionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*"
          Padding="20"
          RowSpacing="14">

        <!-- HEADER -->
        <VerticalStackLayout Grid.Row="0" Spacing="10">

            <VerticalStackLayout Spacing="2">
                <Label Text="Drivers"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{StaticResource BrandTitle}" />

                <Label Text="Tap a driver to edit details"
                       FontSize="13"
                       TextColor="{StaticResource BrandInk}" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">

                <Button Grid.Column="0"
                        Text="Inductions"
                        HeightRequest="44"
                        CornerRadius="14"
                        Padding="14,0"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}"
                        Command="{Binding ManageInductionsCommand}" />

                <Button Grid.Column="1"
                        Text="Add"
                        HeightRequest="44"
                        CornerRadius="14"
                        Padding="14,0"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}"
                        Command="{Binding AddDriverCommand}"
                        IsVisible="{Binding ShowAddDriver}" />
            </Grid>

        </VerticalStackLayout>

        <!-- DRIVER LIST -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Drivers}"
                        SelectionMode="Single"
                        SelectionChanged="OnDriverSelected"
                        EmptyView="No drivers added yet."
                        Margin="0,2,0,0">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray300}"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{StaticResource BrandSurface}"
                            Padding="14"
                            Margin="0,0,0,12">

                        <VerticalStackLayout Spacing="10">

                            <!-- Top row: Name + badges -->
                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8"
                                  VerticalOptions="Center">

                                <Label Grid.Column="0"
                                       Text="{Binding Driver.DisplayName}"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       TextColor="{StaticResource BrandTitle}"
                                       LineBreakMode="TailTruncation" />

                                <Border Grid.Column="1"
                                        StrokeThickness="1"
                                        Stroke="{StaticResource Gray200}"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10,4"
                                        IsVisible="{Binding Driver.IsMainProfile}">
                                    <Label Text="MAIN"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandInk}" />
                                </Border>

                                <Border Grid.Column="2"
                                        StrokeThickness="1"
                                        Stroke="{StaticResource BrandAccent}"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10,4"
                                        IsVisible="{Binding HasWarnings}">
                                    <Label Text="INDUCTIONS"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandAccent}"/>
                                </Border>

                            </Grid>

                            <!-- Warning detail chips -->
                            <Grid ColumnDefinitions="Auto,Auto,Auto"
                                  ColumnSpacing="10"
                                  IsVisible="{Binding HasWarnings}">

                                <Border Grid.Column="0"
                                        StrokeThickness="1"
                                        Stroke="{StaticResource BrandDanger}"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10,4">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding ExpiredCount}" Value="0">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding ExpiredCount, StringFormat='Expired: {0}'}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandDanger}" />
                                </Border>

                                <Border Grid.Column="1"
                                        StrokeThickness="1"
                                        Stroke="{StaticResource BrandAccent}"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10,4">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding ExpiringSoonCount}" Value="0">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding ExpiringSoonCount, StringFormat='Expiring: {0}'}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandAccent}" />
                                </Border>

                                <Label Grid.Column="2"
                                       Text="Within 30 days"
                                       FontSize="12"
                                       TextColor="{StaticResource BrandInk}"
                                       VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding ExpiringSoonCount}" Value="0">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                            </Grid>

                            <!-- Details card -->
                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12">

                                <VerticalStackLayout Spacing="6">

                                    <!-- Email -->
                                    <Label Text="{Binding Driver.Email, StringFormat='Email: {0}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.Email}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.Email}" Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- Licence number -->
                                    <Label Text="{Binding Driver.LicenceNumber, StringFormat='Licence: {0}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.LicenceNumber}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.LicenceNumber}" Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- NEW: Class / endorsements -->
                                    <Label Text="{Binding Driver.LicenceClassOrEndorsements, StringFormat='Class/Endorsements: {0}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.LicenceClassOrEndorsements}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.LicenceClassOrEndorsements}" Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- NEW: Version (optional) -->
                                    <Label Text="{Binding Driver.LicenceVersion, StringFormat='Version: {0}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.LicenceVersion}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.LicenceVersion}" Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- NEW: Issued date (optional) -->
                                    <Label Text="{Binding Driver.LicenceIssuedOnUtc, StringFormat='Issued: {0:yyyy-MM-dd}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.LicenceIssuedOnUtc}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- Phone -->
                                    <Label Text="{Binding Driver.PhoneNumber, StringFormat='Phone: {0}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.PhoneNumber}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.PhoneNumber}" Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- DOB -->
                                    <Label Text="{Binding Driver.DateOfBirthUtc, StringFormat='DOB: {0:yyyy-MM-dd}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.DateOfBirthUtc}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- Licence expiry -->
                                    <Label Text="{Binding Driver.LicenceExpiresOnUtc, StringFormat='Licence expires: {0:yyyy-MM-dd}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.LicenceExpiresOnUtc}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- Address -->
                                    <Label Text="{Binding Driver.AddressSummary, StringFormat='Address: {0}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.AddressSummary}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.AddressSummary}" Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                </VerticalStackLayout>
                            </Border>

                            <!-- Emergency contact -->
                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12"
                                    IsVisible="{Binding Driver.EmergencyContact.IsSet}">

                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Emergency contact"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}" />

                                    <Label Text="{Binding Driver.EmergencyContact.FirstName, StringFormat='Name: {0}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}" />

                                    <Label Text="{Binding Driver.EmergencyContact.PhoneNumber, StringFormat='Phone: {0}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}" />

                                    <Label Text="{Binding Driver.EmergencyContact.Email, StringFormat='Email: {0}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Status -->
                            <Label Text="{Binding Driver.EmergencyStatus}"
                                   FontSize="12"
                                   TextColor="{StaticResource BrandInk}"/>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage> 