<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Haulory.Mobile.Views.DriverCollectionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>
    <Grid RowDefinitions="Auto,*"
          Padding="20"
          RowSpacing="14">

        <!-- HEADER -->
        <VerticalStackLayout Grid.Row="0" Spacing="10">

            <!-- Title + subtitle -->
            <VerticalStackLayout Spacing="2">
                <Label Text="Drivers"
                       FontSize="28"
                       FontAttributes="Bold" />

                <Label Text="Tap a driver to edit details"
                       FontSize="13"
                       Opacity="0.7" />
            </VerticalStackLayout>

            <!-- Actions (stacked for mobile comfort) -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">

                <Button Grid.Column="0"
                        Text="Inductions"
                        HeightRequest="44"
                        CornerRadius="14"
                        Padding="14,0"
                        BackgroundColor="{AppThemeBinding Light='#111827', Dark='#E5E7EB'}"
                        TextColor="{AppThemeBinding Light='White', Dark='Black'}"
                        Command="{Binding ManageInductionsCommand}" />

                <Button Grid.Column="1"
                        Text="Add"
                        HeightRequest="44"
                        CornerRadius="14"
                        Padding="14,0"
                        BackgroundColor="{AppThemeBinding Light='#2563EB', Dark='#3B82F6'}"
                        TextColor="White"
                        Command="{Binding AddDriverCommand}"
                        IsVisible="{Binding ShowAddDriver}" />
            </Grid>

        </VerticalStackLayout>

        <!-- DRIVER LIST -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Drivers}"
                        SelectionMode="Single"
                        SelectionChanged="OnDriverSelected"
                        EmptyView="No drivers added yet."
                        Margin="0,2,0,0">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light='#E5E7EB', Dark='#374151'}"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light='#FFFFFF', Dark='#0B1220'}"
                            Padding="14"
                            Margin="0,0,0,12">

                        <VerticalStackLayout Spacing="10">

                            <!-- Top row: Name + badges -->
                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8"
                                  VerticalOptions="Center">

                                <Label Grid.Column="0"
                                       Text="{Binding Driver.DisplayName}"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       LineBreakMode="TailTruncation" />

                                <!-- MAIN badge -->
                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light='#F3F4F6', Dark='#111827'}"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10,4"
                                        IsVisible="{Binding Driver.IsMainProfile}">
                                    <Label Text="MAIN"
                                           FontSize="12"
                                           Opacity="0.9" />
                                </Border>

                                <!-- Warning badge -->
                                <Border Grid.Column="2"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light='#FEF3C7', Dark='#78350F'}"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10,4"
                                        IsVisible="{Binding HasWarnings}">
                                    <Label Text="INDUCTIONS"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light='#92400E', Dark='White'}"
                                           Opacity="0.95" />
                                </Border>

                            </Grid>

                            <!-- Warning detail chips -->
                            <Grid ColumnDefinitions="Auto,Auto,Auto"
                                  ColumnSpacing="10"
                                  IsVisible="{Binding HasWarnings}">

                                <!-- Expired -->
                                <Border Grid.Column="0"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light='#FEE2E2', Dark='#7F1D1D'}"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10,4">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding ExpiredCount}" Value="0">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding ExpiredCount, StringFormat='Expired: {0}'}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light='#991B1B', Dark='White'}" />
                                </Border>

                                <!-- Expiring soon -->
                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light='#FFEDD5', Dark='#7C2D12'}"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10,4">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding ExpiringSoonCount}" Value="0">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding ExpiringSoonCount, StringFormat='Expiring: {0}'}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light='#9A3412', Dark='White'}" />
                                </Border>

                                <Label Grid.Column="2"
                                       Text="Within 30 days"
                                       FontSize="12"
                                       Opacity="0.7"
                                       VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding ExpiringSoonCount}" Value="0">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                            </Grid>

                            <!-- Details card -->
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{AppThemeBinding Light='#F9FAFB', Dark='#111827'}"
                                    Padding="12">

                                <VerticalStackLayout Spacing="6">

                                    <!-- Email -->
                                    <Label Text="{Binding Driver.Email, StringFormat='Email: {0}'}"
                                           FontSize="13"
                                           Opacity="0.9">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.Email}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.Email}" Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- Licence -->
                                    <Label Text="{Binding Driver.LicenceNumber, StringFormat='Licence: {0}'}"
                                           FontSize="13"
                                           Opacity="0.9">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.LicenceNumber}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.LicenceNumber}" Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- Phone -->
                                    <Label Text="{Binding Driver.PhoneNumber, StringFormat='Phone: {0}'}"
                                           FontSize="13"
                                           Opacity="0.9">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.PhoneNumber}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.PhoneNumber}" Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- DOB -->
                                    <Label Text="{Binding Driver.DateOfBirthUtc, StringFormat='DOB: {0:yyyy-MM-dd}'}"
                                           FontSize="13"
                                           Opacity="0.9">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.DateOfBirthUtc}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- Licence expiry -->
                                    <Label Text="{Binding Driver.LicenceExpiresOnUtc, StringFormat='Licence expires: {0:yyyy-MM-dd}'}"
                                           FontSize="13"
                                           Opacity="0.9">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.LicenceExpiresOnUtc}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- Address -->
                                    <Label Text="{Binding Driver.AddressSummary, StringFormat='Address: {0}'}"
                                           FontSize="13"
                                           Opacity="0.9"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.AddressSummary}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Driver.AddressSummary}" Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                </VerticalStackLayout>
                            </Border>

                            <!-- Emergency contact (only if set) -->
                            <Border StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light='#EEF2F7', Dark='#374151'}"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12"
                                    IsVisible="{Binding Driver.EmergencyContact.IsSet}">

                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Emergency contact"
                                           FontSize="12"
                                           Opacity="0.7" />

                                    <Label Text="{Binding Driver.EmergencyContact.FirstName, StringFormat='Name: {0}'}"
                                           FontSize="13" />

                                    <Label Text="{Binding Driver.EmergencyContact.PhoneNumber, StringFormat='Phone: {0}'}"
                                           FontSize="13" />

                                    <Label Text="{Binding Driver.EmergencyContact.Email, StringFormat='Email: {0}'}"
                                           FontSize="13" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Status -->
                            <Label Text="{Binding Driver.EmergencyStatus}"
                                   FontSize="12"
                                   Opacity="0.7" />

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>