<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- ===== Your full palette (named so you can use them anywhere) ===== -->
    <Color x:Key="P_RedOxide">#781E1E</Color>
    <Color x:Key="P_Clay">#AA6432</Color>
    <Color x:Key="P_Sand">#A08C50</Color>
    <Color x:Key="P_OliveGold">#6E5A0A</Color>
    <Color x:Key="P_DarkOlive">#3C3200</Color>
    <Color x:Key="P_Bronze">#786E3C</Color>
    <Color x:Key="P_NearBlack">#14140A</Color>
    <Color x:Key="P_MossGray">#505032</Color>
    <Color x:Key="P_Paper">#D2D2C8</Color>
    <Color x:Key="P_Stone">#A0A096</Color>
    <Color x:Key="P_Slate">#5A6464</Color>
    <Color x:Key="P_InkTeal">#1E323C</Color>
    <Color x:Key="P_Ice">#DCF0FA</Color>
    <Color x:Key="P_TitleTeal">#285064</Color>
    <Color x:Key="P_SkySoft">#AAD2F0</Color>
    <Color x:Key="P_BlueGray">#A0B4C8</Color>
    <Color x:Key="P_Steel">#6E8296</Color>
    <Color x:Key="P_PrimaryBlue">#3C6EAA</Color>
    <Color x:Key="P_BlueBright">#6E96C8</Color>
    <Color x:Key="P_Wine">#46000A</Color>

    <!-- ===== Map your palette into the DEFAULT MAUI keys your styles already reference ===== -->

    <!-- Brand “roles” (easy mental model) -->
    <Color x:Key="BrandBackground">#A0A096</Color>
    <!-- P_Paper -->
    <Color x:Key="BrandSurface">#FFFFFF</Color>
    <!-- P_Ice -->
    <Color x:Key="BrandInk">#1E323C</Color>
    <!-- P_InkTeal -->
    <Color x:Key="BrandTitle">#285064</Color>
    <!-- P_TitleTeal -->
    <Color x:Key="BrandAccent">#AA6432</Color>
    <!-- P_Clay -->
    <Color x:Key="BrandDanger">#781E1E</Color>
    <!-- P_RedOxide -->
    <Color x:Key="BrandDeep">#46000A</Color>
    <!-- P_Wine -->
    <Color x:Key="BrandTileFill">#FFFFFF</Color>
    <!-- Keep these keys because your Styles.xaml uses them everywhere -->
    <Color x:Key="Primary">#3C6EAA</Color>
    <!-- P_PrimaryBlue -->
    <Color x:Key="PrimaryDark">#285064</Color>
    <!-- P_TitleTeal -->
    <Color x:Key="PrimaryDarkText">#14140A</Color>
    <!-- P_NearBlack -->

    <Color x:Key="Secondary">#AAD2F0</Color>
    <!-- P_SkySoft -->
    <Color x:Key="SecondaryDarkText">#1E323C</Color>
    <!-- P_InkTeal -->
    <Color x:Key="Tertiary">#6E96C8</Color>
    <!-- P_BlueBright -->

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#14140A</Color>
    <!-- P_NearBlack -->
    <Color x:Key="Magenta">#AA6432</Color>
    <!-- reuse as accent -->
    <Color x:Key="MidnightBlue">#285064</Color>
    <!-- title -->
    <Color x:Key="OffBlack">#14140A</Color>

    <!-- Grays re-mapped to your palette (soft → dark) -->
    <Color x:Key="Gray100">#DCF0FA</Color>
    <!-- ice -->
    <Color x:Key="Gray200">#D2D2C8</Color>
    <!-- paper -->
    <Color x:Key="Gray300">#A0A096</Color>
    <!-- stone -->
    <Color x:Key="Gray400">#A0B4C8</Color>
    <!-- blue-gray -->
    <Color x:Key="Gray500">#6E8296</Color>
    <!-- steel -->
    <Color x:Key="Gray600">#5A6464</Color>
    <!-- slate -->
    <Color x:Key="Gray900">#1E323C</Color>
    <!-- ink -->
    <Color x:Key="Gray950">#14140A</Color>
    <!-- near-black -->

    <!-- Brushes (kept) -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

</ResourceDictionary>