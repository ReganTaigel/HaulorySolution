<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.JobsCollectionPage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid
        RowDefinitions="Auto,*"
        Padding="20"
        RowSpacing="14"
        IsVisible="{Binding IsJobsVisible}">

        <!-- HEADER -->
        <VerticalStackLayout Grid.Row="0" Spacing="12">

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12"
                  VerticalOptions="Center">

                <Grid Grid.Column="0"
                      ColumnDefinitions="Auto,*"
                      ColumnSpacing="12"
                      VerticalOptions="Center">

                    <Border
                        Grid.Column="0"
                        BackgroundColor="{StaticResource Gray100}"
                        Stroke="{StaticResource Gray300}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="10"
                        VerticalOptions="Center">

                        <Image
                            Source="jobs.svg"
                            HeightRequest="22"
                            WidthRequest="22" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                        <Label
                            Text="Jobs"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="{StaticResource BrandTitle}" />

                        <Label
                            Text="Active deliveries"
                            FontSize="14"
                            TextColor="{StaticResource Gray600}" />
                    </VerticalStackLayout>
                </Grid>

                <Button
                    Grid.Column="1"
                    Text="Add"
                    Command="{Binding AddJobCommand}"
                    IsVisible="{Binding IsAddJobVisible}"
                    IsEnabled="{Binding IsAddJobEnabled}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HeightRequest="44"
                    Padding="16,0" />
            </Grid>

            <!-- TIP CARD -->
            <Border
                Style="{StaticResource CardBorderStyle}"
                Stroke="{StaticResource Gray300}"
                StrokeShape="RoundRectangle 18"
                Padding="14">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

                    <Border
                        BackgroundColor="{StaticResource BrandTileFill}"
                        Stroke="{StaticResource Gray300}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="8"
                        VerticalOptions="Start">

                        <Image
                            Source="warning.svg"
                            HeightRequest="18"
                            WidthRequest="18" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label
                            Text="Tip"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="{StaticResource BrandTitle}" />

                        <Label
                            Text="Tap Sign delivery when complete"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="{StaticResource BrandInk}"
                            IsVisible="{Binding IsMainUser}" />

                        <Label
                            Text="Tap Sign delivery to complete your assigned job"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="{StaticResource BrandInk}"
                            IsVisible="{Binding IsSubUser}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

        </VerticalStackLayout>

        <!-- SUB USER FLAT LIST -->
        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding Jobs}"
            SelectionMode="None"
            Margin="0,2,0,0"
            IsVisible="{Binding IsSubUser}">

            <CollectionView.EmptyView>
                <Grid>
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="6"
                        Padding="24">

                        <Label
                            Text="No assigned jobs right now"
                            FontSize="17"
                            FontAttributes="Bold"
                            TextColor="{StaticResource BrandTitle}"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Style="{StaticResource CardBorderStyle}"
                        Stroke="{StaticResource Gray300}"
                        StrokeShape="RoundRectangle 18"
                        Padding="14"
                        Margin="0,0,0,12">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditJobCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="12">

                            <!-- JOB HEADER -->
                            <VerticalStackLayout Spacing="3">
                                <Label
                                    Text="{Binding ReferenceNumber}"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource BrandTitle}"
                                    LineBreakMode="TailTruncation" />

                                <Label
                                    Text="{Binding LoadDescription}"
                                    FontSize="13"
                                    LineHeight="1.15"
                                    TextColor="{StaticResource BrandInk}"
                                    Opacity="0.95"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="2" />
                            </VerticalStackLayout>

                            <!-- DRIVER / TRUCK -->
                            <Border
                                StrokeThickness="1"
                                Stroke="{StaticResource Gray300}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12">

                                <VerticalStackLayout Spacing="8">

                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Image
                                            Source="driver.svg"
                                            HeightRequest="16"
                                            WidthRequest="16"
                                            VerticalOptions="Center" />

                                        <Label
                                            Grid.Column="1"
                                            Text="Driver / Truck"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandTitle}" />
                                    </Grid>

                                    <Grid
                                        RowDefinitions="Auto,Auto"
                                        ColumnDefinitions="Auto,*"
                                        ColumnSpacing="10"
                                        RowSpacing="8">

                                        <Label
                                            Text="Driver"
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandTitle}" />

                                        <Label
                                            Text="{Binding DriverName}"
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandInk}"
                                            LineBreakMode="TailTruncation" />

                                        <Label
                                            Text="Truck"
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandTitle}" />

                                        <Label
                                            Text="{Binding TruckDisplay}"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            FontSize="14"
                                            TextColor="{StaticResource BrandInk}"
                                            LineBreakMode="TailTruncation" />
                                    </Grid>

                                </VerticalStackLayout>
                            </Border>

                            <!-- PICKUP / DROP -->
                            <Border
                                StrokeThickness="1"
                                Stroke="{StaticResource Gray300}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12">

                                <VerticalStackLayout Spacing="8">

                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Image
                                            Source="location.svg"
                                            HeightRequest="16"
                                            WidthRequest="16"
                                            VerticalOptions="Center" />

                                        <Label
                                            Grid.Column="1"
                                            Text="Pickup / Drop"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandTitle}" />
                                    </Grid>

                                    <Grid
                                        RowDefinitions="Auto,Auto"
                                        ColumnDefinitions="Auto,*"
                                        ColumnSpacing="10"
                                        RowSpacing="10">

                                        <Label
                                            Text="Pickup"
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandTitle}" />

                                        <VerticalStackLayout
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Spacing="3">

                                            <Label
                                                Text="{Binding PickupCompany}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource BrandInk}"
                                                LineBreakMode="TailTruncation" />

                                            <Label
                                                Text="{Binding PickupAddress}"
                                                FontSize="13"
                                                LineHeight="1.15"
                                                TextColor="{StaticResource Gray600}"
                                                LineBreakMode="TailTruncation"
                                                MaxLines="2" />
                                        </VerticalStackLayout>

                                        <Label
                                            Text="Drop"
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandTitle}" />

                                        <VerticalStackLayout
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Spacing="3">

                                            <Label
                                                Text="{Binding DeliveryCompany}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource BrandInk}"
                                                LineBreakMode="TailTruncation" />

                                            <Label
                                                Text="{Binding DeliveryAddress}"
                                                FontSize="13"
                                                LineHeight="1.15"
                                                TextColor="{StaticResource Gray600}"
                                                LineBreakMode="TailTruncation"
                                                MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Grid>

                                </VerticalStackLayout>
                            </Border>

                            <Button
                                Text="Sign delivery"
                                HeightRequest="46"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SignDeliveryCommand}"
                                CommandParameter="{Binding .}"
                                IsVisible="{Binding CanShowSignDelivery}"
                                IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsDeliverySignatureEnabled}"
                                Style="{StaticResource PrimaryButtonStyle}" />

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- MAIN USER GROUPED LIST -->
        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding JobGroups}"
            SelectionMode="None"
            Margin="0,2,0,0"
            IsVisible="{Binding IsMainUser}">

            <CollectionView.EmptyView>
                <Grid>
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="6"
                        Padding="24">

                        <Label
                            Text="No jobs yet"
                            FontSize="17"
                            FontAttributes="Bold"
                            TextColor="{StaticResource BrandTitle}"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="Use Add to create your first job."
                            FontSize="14"
                            TextColor="{StaticResource Gray600}"
                            HorizontalTextAlignment="Center">
                            <Label.Triggers>
                                <DataTrigger
                                    TargetType="Label"
                                    Binding="{Binding IsAddJobVisible}"
                                    Value="False">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>
                </Grid>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Style="{StaticResource CardBorderStyle}"
                        Stroke="{StaticResource Gray300}"
                        StrokeShape="RoundRectangle 18"
                        Padding="14"
                        Margin="0,0,0,12">

                        <VerticalStackLayout Spacing="12">

                            <!-- GROUP HEADER -->
                            <Grid
                                ColumnDefinitions="*,Auto"
                                ColumnSpacing="12">

                                <VerticalStackLayout Spacing="3">
                                    <Label
                                        Text="{Binding Title}"
                                        FontSize="17"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />

                                    <Label
                                        Text="{Binding Jobs.Count, StringFormat='Jobs: {0}'}"
                                        FontSize="13"
                                        TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <Button
                                    Grid.Column="1"
                                    Text="{Binding ExpandCollapseGlyph}"
                                    Command="{Binding ToggleExpandedCommand}"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    CornerRadius="12"
                                    Padding="0"
                                    BackgroundColor="{StaticResource Gray200}"
                                    TextColor="{StaticResource BrandInk}" />
                            </Grid>

                            <!-- GROUP JOBS -->
                            <CollectionView
                                ItemsSource="{Binding Jobs}"
                                SelectionMode="None"
                                IsVisible="{Binding IsExpanded}">

                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            StrokeThickness="1"
                                            Stroke="{StaticResource Gray300}"
                                            BackgroundColor="{StaticResource BrandTileFill}"
                                            StrokeShape="RoundRectangle 16"
                                            Padding="14"
                                            Margin="0,0,0,10">

                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditJobCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>

                                            <VerticalStackLayout Spacing="12">

                                                <Label
                                                    Text="Tap anywhere on this card to edit"
                                                    FontSize="12"
                                                    TextColor="{StaticResource Gray600}" />

                                                <Grid
                                                    ColumnDefinitions="*,Auto"
                                                    ColumnSpacing="12"
                                                    VerticalOptions="Center">

                                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                                        <Label
                                                            Text="{Binding ReferenceNumber}"
                                                            FontSize="17"
                                                            FontAttributes="Bold"
                                                            TextColor="{StaticResource BrandTitle}"
                                                            LineBreakMode="TailTruncation" />

                                                        <Label
                                                            Text="{Binding LoadDescription}"
                                                            FontSize="13"
                                                            LineHeight="1.15"
                                                            TextColor="{StaticResource BrandInk}"
                                                            Opacity="0.95"
                                                            LineBreakMode="TailTruncation"
                                                            MaxLines="2" />
                                                    </VerticalStackLayout>

                                                    <VerticalStackLayout
                                                        Grid.Column="1"
                                                        Spacing="8"
                                                        VerticalOptions="Center">

                                                        <Button
                                                            Text="Up"
                                                            FontSize="13"
                                                            WidthRequest="56"
                                                            HeightRequest="34"
                                                            CornerRadius="12"
                                                            Padding="0"
                                                            BackgroundColor="{StaticResource Gray200}"
                                                            TextColor="{StaticResource BrandInk}"
                                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsJobsEnabled}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MoveUpCommand}"
                                                            CommandParameter="{Binding .}" />

                                                        <Button
                                                            Text="Down"
                                                            FontSize="13"
                                                            WidthRequest="56"
                                                            HeightRequest="34"
                                                            CornerRadius="12"
                                                            Padding="0"
                                                            BackgroundColor="{StaticResource Gray200}"
                                                            TextColor="{StaticResource BrandInk}"
                                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsJobsEnabled}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MoveDownCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </VerticalStackLayout>
                                                </Grid>

                                                <!-- DRIVER / TRUCK -->
                                                <Border
                                                    StrokeThickness="1"
                                                    Stroke="{StaticResource Gray300}"
                                                    StrokeShape="RoundRectangle 14"
                                                    BackgroundColor="{StaticResource BrandSurface}"
                                                    Padding="12">

                                                    <VerticalStackLayout Spacing="8">

                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                            <Image
                                                                Source="driver.svg"
                                                                HeightRequest="16"
                                                                WidthRequest="16"
                                                                VerticalOptions="Center" />

                                                            <Label
                                                                Grid.Column="1"
                                                                Text="Driver / Truck"
                                                                FontSize="13"
                                                                FontAttributes="Bold"
                                                                TextColor="{StaticResource BrandTitle}" />
                                                        </Grid>

                                                        <Grid
                                                            RowDefinitions="Auto,Auto"
                                                            ColumnDefinitions="Auto,*"
                                                            ColumnSpacing="10"
                                                            RowSpacing="8">

                                                            <Label
                                                                Text="Driver"
                                                                Grid.Row="0"
                                                                Grid.Column="0"
                                                                FontSize="13"
                                                                FontAttributes="Bold"
                                                                TextColor="{StaticResource BrandTitle}" />

                                                            <Label
                                                                Text="{Binding DriverName}"
                                                                Grid.Row="0"
                                                                Grid.Column="1"
                                                                FontSize="14"
                                                                FontAttributes="Bold"
                                                                TextColor="{StaticResource BrandInk}"
                                                                LineBreakMode="TailTruncation" />

                                                            <Label
                                                                Text="Truck"
                                                                Grid.Row="1"
                                                                Grid.Column="0"
                                                                FontSize="13"
                                                                FontAttributes="Bold"
                                                                TextColor="{StaticResource BrandTitle}" />

                                                            <Label
                                                                Text="{Binding TruckDisplay}"
                                                                Grid.Row="1"
                                                                Grid.Column="1"
                                                                FontSize="14"
                                                                TextColor="{StaticResource BrandInk}"
                                                                LineBreakMode="TailTruncation" />
                                                        </Grid>

                                                    </VerticalStackLayout>
                                                </Border>

                                                <!-- PICKUP / DROP -->
                                                <Border
                                                    StrokeThickness="1"
                                                    Stroke="{StaticResource Gray300}"
                                                    StrokeShape="RoundRectangle 14"
                                                    BackgroundColor="{StaticResource BrandSurface}"
                                                    Padding="12">

                                                    <VerticalStackLayout Spacing="8">

                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                            <Image
                                                                Source="location.svg"
                                                                HeightRequest="16"
                                                                WidthRequest="16"
                                                                VerticalOptions="Center" />

                                                            <Label
                                                                Grid.Column="1"
                                                                Text="Pickup / Drop"
                                                                FontSize="13"
                                                                FontAttributes="Bold"
                                                                TextColor="{StaticResource BrandTitle}" />
                                                        </Grid>

                                                        <Grid
                                                            RowDefinitions="Auto,Auto"
                                                            ColumnDefinitions="Auto,*"
                                                            ColumnSpacing="10"
                                                            RowSpacing="10">

                                                            <Label
                                                                Text="Pickup"
                                                                Grid.Row="0"
                                                                Grid.Column="0"
                                                                FontSize="13"
                                                                FontAttributes="Bold"
                                                                TextColor="{StaticResource BrandTitle}" />

                                                            <VerticalStackLayout
                                                                Grid.Row="0"
                                                                Grid.Column="1"
                                                                Spacing="3">

                                                                <Label
                                                                    Text="{Binding PickupCompany}"
                                                                    FontSize="14"
                                                                    FontAttributes="Bold"
                                                                    TextColor="{StaticResource BrandInk}"
                                                                    LineBreakMode="TailTruncation" />

                                                                <Label
                                                                    Text="{Binding PickupAddress}"
                                                                    FontSize="13"
                                                                    LineHeight="1.15"
                                                                    TextColor="{StaticResource Gray600}"
                                                                    LineBreakMode="TailTruncation"
                                                                    MaxLines="2" />
                                                            </VerticalStackLayout>

                                                            <Label
                                                                Text="Drop"
                                                                Grid.Row="1"
                                                                Grid.Column="0"
                                                                FontSize="13"
                                                                FontAttributes="Bold"
                                                                TextColor="{StaticResource BrandTitle}" />

                                                            <VerticalStackLayout
                                                                Grid.Row="1"
                                                                Grid.Column="1"
                                                                Spacing="3">

                                                                <Label
                                                                    Text="{Binding DeliveryCompany}"
                                                                    FontSize="14"
                                                                    FontAttributes="Bold"
                                                                    TextColor="{StaticResource BrandInk}"
                                                                    LineBreakMode="TailTruncation" />

                                                                <Label
                                                                    Text="{Binding DeliveryAddress}"
                                                                    FontSize="13"
                                                                    LineHeight="1.15"
                                                                    TextColor="{StaticResource Gray600}"
                                                                    LineBreakMode="TailTruncation"
                                                                    MaxLines="2" />
                                                            </VerticalStackLayout>
                                                        </Grid>

                                                    </VerticalStackLayout>
                                                </Border>

                                                <!-- PRICING -->
                                                <Border
                                                    StrokeThickness="1"
                                                    Stroke="{StaticResource Gray300}"
                                                    StrokeShape="RoundRectangle 14"
                                                    BackgroundColor="{StaticResource BrandSurface}"
                                                    Padding="12"
                                                    IsVisible="{Binding HasPricingDisplay}">

                                                    <VerticalStackLayout Spacing="8">

                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                            <Image
                                                                Source="dollar.svg"
                                                                HeightRequest="16"
                                                                WidthRequest="16"
                                                                VerticalOptions="Center" />

                                                            <Label
                                                                Grid.Column="1"
                                                                Text="Pricing"
                                                                FontSize="13"
                                                                FontAttributes="Bold"
                                                                TextColor="{StaticResource BrandTitle}" />
                                                        </Grid>

                                                        <VerticalStackLayout Spacing="4">
                                                            <Label
                                                                Text="{Binding RateLine}"
                                                                FontSize="13"
                                                                TextColor="{StaticResource BrandInk}" />

                                                            <Label
                                                                Text="{Binding TotalLine}"
                                                                FontSize="14"
                                                                FontAttributes="Bold"
                                                                TextColor="{StaticResource BrandTitle}" />
                                                        </VerticalStackLayout>

                                                    </VerticalStackLayout>
                                                </Border>

                                                <Button
                                                    Text="Sign delivery"
                                                    HeightRequest="46"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SignDeliveryCommand}"
                                                    CommandParameter="{Binding .}"
                                                    IsVisible="{Binding CanShowSignDelivery}"
                                                    IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsDeliverySignatureEnabled}"
                                                    Style="{StaticResource PrimaryButtonStyle}" />

                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>