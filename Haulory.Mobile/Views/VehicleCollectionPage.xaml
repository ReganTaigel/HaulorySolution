<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.VehicleCollectionPage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="True" />
    </Shell.BackButtonBehavior>

    <Grid
        RowDefinitions="Auto,*"
        Padding="20"
        RowSpacing="14"
        IsVisible="{Binding IsVehiclesVisible}">
        <Border
                Style="{StaticResource CardBorderStyle}"
                Stroke="{StaticResource Gray200}"
                StrokeShape="RoundRectangle 18"
                Padding="14">

            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="12"
                  VerticalOptions="Center">

                <Border
                    Grid.Column="0"
                    BackgroundColor="{StaticResource BrandTileFill}"
                    Stroke="{StaticResource Gray200}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="8"
                    VerticalOptions="Center">

                    <Image
                        Source="vehicle.svg"
                        HeightRequest="20"
                        WidthRequest="20" />
                </Border>

                <Label
                    Grid.Column="1"
                    Text="Add and manage vehicles, trailers, and fleet assets."
                    FontSize="14"
                    TextColor="{StaticResource Gray600}"
                    VerticalTextAlignment="Center" />

                <Button
                    Grid.Column="2"
                    Text="Add Vehicle"
                    Command="{Binding GoToNewVehicleCommand}"
                    IsVisible="{Binding IsAddVehicleVisible}"
                    IsEnabled="{Binding IsAddVehicleEnabled}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HeightRequest="44"
                    Padding="16,0" />

            </Grid>
        </Border>

        <!-- LIST -->
        <RefreshView
            Grid.Row="1"
            Command="{Binding RefreshCommand}"
            IsRefreshing="{Binding IsRefreshing}"
            IsEnabled="{Binding IsVehiclesEnabled}">

            <CollectionView
                ItemsSource="{Binding Assets}"
                SelectionMode="None"
                Margin="0,2,0,0">

                <CollectionView.EmptyView>
                    <Border
                            Stroke="{StaticResource Gray200}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 20"
                            BackgroundColor="{StaticResource White}"
                            Padding="18">

                        <VerticalStackLayout
                                Padding="24"
                                Spacing="10"
                                HorizontalOptions="Center">

                            <Border
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Stroke="{StaticResource Gray300}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="12">

                                <Image
                                        Source="vehicle.svg"
                                        HeightRequest="28"
                                        WidthRequest="28" />
                            </Border>

                            <Label
                                    Text="No vehicles available"
                                    FontAttributes="Bold"
                                    FontSize="17"
                                    TextColor="{StaticResource BrandTitle}"
                                    HorizontalTextAlignment="Center"/>

                            <Label
                                    Text="Tap Add to create your first vehicle"
                                    FontSize="14"
                                    TextColor="{StaticResource Gray600}"
                                    HorizontalTextAlignment="Center">

                                <Label.Triggers>

                                    <DataTrigger
                                                TargetType="Label"
                                                Binding="{Binding IsMainUser}"
                                                Value="False">
                                        <Setter Property="IsVisible" Value="False"/>
                                    </DataTrigger>

                                    <DataTrigger
                                                TargetType="Label"
                                                Binding="{Binding IsAddVehicleVisible}"
                                                Value="False">
                                        <Setter Property="IsVisible" Value="False"/>
                                    </DataTrigger>

                                </Label.Triggers>
                            </Label>

                            <Label
                                    Text="No vehicles are assigned to your active jobs right now"
                                    FontSize="14"
                                    TextColor="{StaticResource Gray600}"
                                    HorizontalTextAlignment="Center"
                                    IsVisible="{Binding IsSubUser}"/>

                        </VerticalStackLayout>

                    </Border>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Style="{StaticResource CardBorderStyle}"
                            Padding="14"
                            Margin="0,0,0,12">

                            <VerticalStackLayout Spacing="14">

                                <!-- tappable header -->
                                <Grid ColumnDefinitions="*"
                                        ColumnSpacing="12">

                                    <!-- Make the WHOLE header tappable -->
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleVehicleExpandedCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                    <VerticalStackLayout Spacing="8">

                                        <!-- TOP ROW -->
                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                                ColumnSpacing="10">

                                            <!-- Icon -->
                                            <Border
                                                BackgroundColor="{StaticResource Gray100}"
                                                Stroke="{StaticResource Gray300}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 12"
                                                Padding="8"
                                                VerticalOptions="Center">

                                                <Image
                                                    Source="vehicle.svg"
                                                    HeightRequest="18"
                                                    WidthRequest="18" />
                                            </Border>

                                            <!-- Vehicle info -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="6">

                                                <Label
                                                    FontSize="17"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource BrandTitle}">

                                                    <Label.Text>
                                                        <MultiBinding StringFormat="{}{0} {1} {2}">
                                                            <Binding Path="Year" />
                                                            <Binding Path="Make" />
                                                            <Binding Path="Model" />
                                                        </MultiBinding>
                                                    </Label.Text>

                                                </Label>

                                                <HorizontalStackLayout Spacing="8">

                                                    <Border
                                                            StrokeThickness="1"
                                                            Stroke="{StaticResource Gray300}"
                                                            StrokeShape="RoundRectangle 12"
                                                            BackgroundColor="{StaticResource BrandTileFill}"
                                                            Padding="10,6">

                                                        <Label
                                                                Text="{Binding VehicleTypeDisplay}"
                                                                FontSize="13"
                                                                TextColor="{StaticResource BrandInk}" />
                                                    </Border>

                                                    <Border
                                                            StrokeThickness="1"
                                                            Stroke="{StaticResource Gray300}"
                                                            StrokeShape="RoundRectangle 12"
                                                            BackgroundColor="{StaticResource Gray100}"
                                                            Padding="10,6">

                                                        <Label
                                                            Text="{Binding Rego}"
                                                            FontSize="13"
                                                            FontAttributes="Bold"
                                                            TextColor="{StaticResource BrandTitle}" />
                                                    </Border>

                                                </HorizontalStackLayout>

                                            </VerticalStackLayout>

                                        </Grid>

                                        <!-- EXPAND TEXT + CHEVRON INLINE -->
                                        <HorizontalStackLayout Spacing="6">

                                            <Label
                                                    Text="{Binding ExpandText}"
                                                    FontSize="13"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource Primary}" />

                                            <Label
                                                    Text="{Binding ExpandIcon}"
                                                    FontSize="14"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource Gray600}" />

                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>

                                </Grid>

                                <!-- expandable details -->
                                <VerticalStackLayout
                                            Spacing="10"
                                            IsVisible="{Binding IsExpanded}">

                                    <!-- COMPLIANCE -->
                                    <Border
                                            StrokeThickness="1"
                                            Stroke="{StaticResource Gray200}"
                                            StrokeShape="RoundRectangle 14"
                                            BackgroundColor="{StaticResource Gray100}"
                                            Padding="12">

                                        <VerticalStackLayout Spacing="10">

                                            <Grid ColumnDefinitions="Auto,*"
                                                    ColumnSpacing="8">
                                                <Image
                                                    Source="warning.svg"
                                                    HeightRequest="16"
                                                    WidthRequest="16"
                                                    VerticalOptions="Center" />

                                                <Label
                                                    Grid.Column="1"
                                                    Text="Compliance"
                                                    FontSize="13"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource BrandTitle}" />
                                            </Grid>

                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  RowDefinitions="Auto,Auto"
                                                  ColumnSpacing="10"
                                                  RowSpacing="8">

                                                <Label
                                                    Text="Rego"
                                                    FontSize="13"
                                                    TextColor="{StaticResource Gray600}" />

                                                <Label
                                                        Grid.Column="1"
                                                        Text="{Binding Rego}"
                                                        FontSize="14"
                                                        FontAttributes="Bold"
                                                        TextColor="{StaticResource BrandInk}" />

                                                <Border
                                                        Grid.Column="2"
                                                        StrokeThickness="1"
                                                        Stroke="{StaticResource BrandAccent}"
                                                        StrokeShape="RoundRectangle 10"
                                                        BackgroundColor="{StaticResource BrandTileFill}"
                                                        Padding="8,3">
                                                    <Label
                                                        Text="{Binding RegoStatusInlineDisplay}"
                                                        FontSize="12"
                                                        FontAttributes="Bold"
                                                        TextColor="{StaticResource BrandAccent}" />
                                                </Border>

                                                <Label
                                                        Grid.Row="1"
                                                        Text="Expires"
                                                        FontSize="13"
                                                        TextColor="{StaticResource Gray600}" />

                                                <Label
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Text="{Binding RegoExpiryDisplay}"
                                                    FontSize="14"
                                                    TextColor="{StaticResource BrandInk}" />
                                            </Grid>

                                            <BoxView HeightRequest="1"
                                                     BackgroundColor="{StaticResource Gray300}" />

                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                      RowDefinitions="Auto,Auto"
                                                      ColumnSpacing="10"
                                                      RowSpacing="8">

                                                <Label
                                                    Text="{Binding CertificateNameDisplay}"
                                                    FontSize="13"
                                                    TextColor="{StaticResource Gray600}" />

                                                <Label
                                                    Grid.Column="1"
                                                    Text="{Binding CertificateExpiryDisplay}"
                                                    FontSize="14"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource BrandInk}" />

                                                <Border
                                                        Grid.Column="2"
                                                        StrokeThickness="1"
                                                        Stroke="{StaticResource BrandAccent}"
                                                        StrokeShape="RoundRectangle 10"
                                                        BackgroundColor="{StaticResource BrandTileFill}"
                                                        Padding="8,3">
                                                    <Label
                                                        Text="{Binding CertStatusInlineDisplay}"
                                                        FontSize="12"
                                                        FontAttributes="Bold"
                                                        TextColor="{StaticResource BrandAccent}" />
                                                </Border>

                                                <Label
                                                    Grid.Row="1"
                                                    Text="Type"
                                                    FontSize="13"
                                                    TextColor="{StaticResource Gray600}" />

                                                <Label
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Text="{Binding CertificateNameDisplay, StringFormat='{}{0} expiry'}"
                                                    FontSize="14"
                                                    TextColor="{StaticResource BrandInk}" />
                                            </Grid>

                                        </VerticalStackLayout>
                                    </Border>

                                    <!-- ODOMETER -->
                                    <Border
                                            StrokeThickness="1"
                                            Stroke="{StaticResource Gray200}"
                                            StrokeShape="RoundRectangle 14"
                                            BackgroundColor="{StaticResource Gray100}"
                                            Padding="12">

                                        <VerticalStackLayout Spacing="8">

                                            <Grid ColumnDefinitions="Auto,*"
                                                     ColumnSpacing="8">
                                                <Image
                                                    Source="odometer.svg"
                                                    HeightRequest="16"
                                                    WidthRequest="16"
                                                    VerticalOptions="Center" />

                                                <Label
                                                    Grid.Column="1"
                                                    Text="Odometer"
                                                    FontSize="13"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource BrandTitle}" />
                                            </Grid>

                                            <Grid ColumnDefinitions="Auto,*"
                                                     ColumnSpacing="10">
                                                <Label
                                                    Text="Current"
                                                    FontSize="13"
                                                    TextColor="{StaticResource Gray600}" />

                                                <Label
                                                    Grid.Column="1"
                                                    Text="{Binding OdometerFullDisplay}"
                                                    FontSize="14"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource BrandInk}" />
                                            </Grid>

                                        </VerticalStackLayout>
                                    </Border>

                                    <!-- RUC -->
                                    <Border
                                            StrokeThickness="1"
                                            Stroke="{StaticResource Gray200}"
                                            StrokeShape="RoundRectangle 14"
                                            BackgroundColor="{StaticResource Gray100}"
                                            Padding="12"
                                            IsVisible="{Binding IsRucApplicable}">

                                        <VerticalStackLayout Spacing="10">

                                            <Grid ColumnDefinitions="Auto,*"
                                                    ColumnSpacing="8">
                                                <Image
                                                    Source="receipt.svg"
                                                    HeightRequest="16"
                                                    WidthRequest="16"
                                                    VerticalOptions="Center" />

                                                <Label
                                                    Grid.Column="1"
                                                    Text="RUC"
                                                    FontSize="13"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource BrandTitle}" />
                                            </Grid>

                                            <Grid ColumnDefinitions="Auto,*"
                                                     ColumnSpacing="10">
                                                <Label
                                                    Text="Licence"
                                                    FontSize="13"
                                                    TextColor="{StaticResource Gray600}" />

                                                <Label
                                                        Grid.Column="1"
                                                        FontSize="14"
                                                        TextColor="{StaticResource BrandInk}">
                                                    <Label.Text>
                                                        <MultiBinding StringFormat="{}{0} to {1}">
                                                            <Binding Path="RucLicenceStartDisplay" />
                                                            <Binding Path="RucLicenceEndDisplay" />
                                                        </MultiBinding>
                                                    </Label.Text>
                                                </Label>
                                            </Grid>

                                            <Grid ColumnDefinitions="Auto,*"
                                                    ColumnSpacing="10">
                                                <Label
                                                        Text="Remaining"
                                                        FontSize="13"
                                                        TextColor="{StaticResource Gray600}" />

                                                <Label
                                                    Grid.Column="1"
                                                    Text="{Binding RucRemainingDisplay}"
                                                    FontSize="14"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource BrandTitle}" />
                                            </Grid>

                                            <Grid ColumnDefinitions="Auto,*"
                                                    ColumnSpacing="10">
                                                <Label
                                                    Text="Overdue"
                                                    FontSize="13"
                                                    TextColor="{StaticResource Gray600}" />

                                                <Label
                                                    Grid.Column="1"
                                                    Text="{Binding IsRucOverdueYesNo}"
                                                    FontSize="14"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource BrandTitle}" />
                                            </Grid>

                                        </VerticalStackLayout>
                                    </Border>

                                    <!-- ACTIONS -->
                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="10"
                                          Margin="0,4,0,0">

                                        <Button
                                                Grid.Column="0"
                                                Text="Edit"
                                                HeightRequest="44"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditVehicleCommand}"
                                                CommandParameter="{Binding .}" />

                                        <Button
                                                Grid.Column="1"
                                                Text="Delete"
                                                HeightRequest="44"
                                                BackgroundColor="{StaticResource White}"
                                                TextColor="{StaticResource BrandDanger}"
                                                BorderColor="{StaticResource BrandDanger}"
                                                BorderWidth="1"
                                                CornerRadius="12"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteVehicleCommand}"
                                                CommandParameter="{Binding .}" />

                                    </Grid>

                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </RefreshView>

    </Grid>

</ContentPage>