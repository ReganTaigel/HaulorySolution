<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.VehicleCollectionPage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid
        RowDefinitions="Auto,*"
        Padding="20"
        RowSpacing="14"
        IsVisible="{Binding IsVehiclesVisible}">

        <!-- HEADER -->
        <VerticalStackLayout Grid.Row="0" Spacing="12">

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">

                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12"
                      VerticalOptions="Center">

                    <Border
                        Grid.Column="0"
                        BackgroundColor="{StaticResource Gray100}"
                        Stroke="{StaticResource Gray300}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="10"
                        VerticalOptions="Center">

                        <Image
                            Source="vehicle.svg"
                            HeightRequest="22"
                            WidthRequest="22" />
                    </Border>

                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="3"
                        VerticalOptions="Center">

                        <Label
                            Text="Vehicles"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="{StaticResource BrandTitle}" />

                        <Label
                            Text="Keep your fleet compliant and ready"
                            FontSize="14"
                            TextColor="{StaticResource Gray600}" />
                    </VerticalStackLayout>
                </Grid>

                <Button
                    Grid.Column="1"
                    Text="Add"
                    Command="{Binding GoToNewVehicleCommand}"
                    IsVisible="{Binding IsAddVehicleVisible}"
                    IsEnabled="{Binding IsAddVehicleEnabled}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HeightRequest="44"
                    Padding="16,0" />
            </Grid>

            <Border
                Style="{StaticResource CardBorderStyle}"
                Stroke="{StaticResource Gray300}"
                Padding="14">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

                    <Border
                        BackgroundColor="{StaticResource BrandTileFill}"
                        Stroke="{StaticResource Gray300}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="8"
                        VerticalOptions="Start">

                        <Image
                            Source="warning.svg"
                            HeightRequest="18"
                            WidthRequest="18" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="4">

                        <Label
                            Text="Tip"
                            FontSize="13"
                            TextColor="{StaticResource Gray600}" />

                        <Label
                            Text="Tap a vehicle card to show or hide details"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="{StaticResource BrandTitle}" />

                    </VerticalStackLayout>
                </Grid>
            </Border>

        </VerticalStackLayout>

        <!-- LIST -->
        <RefreshView
            Grid.Row="1"
            Command="{Binding RefreshCommand}"
            IsRefreshing="{Binding IsBusy}"
            IsEnabled="{Binding IsVehiclesEnabled}">

            <CollectionView
                ItemsSource="{Binding Assets}"
                SelectionMode="None"
                Margin="0,2,0,0">

                <CollectionView.EmptyView>
                    <VerticalStackLayout
                        Padding="24"
                        Spacing="10"
                        HorizontalOptions="Center">

                        <Border
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Stroke="{StaticResource Gray300}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="12">

                            <Image
                                Source="vehicle.svg"
                                HeightRequest="28"
                                WidthRequest="28" />
                        </Border>

                        <Label
                            Text="No vehicles available"
                            FontAttributes="Bold"
                            FontSize="17"
                            TextColor="{StaticResource BrandTitle}"
                            HorizontalTextAlignment="Center"/>

                        <Label
                            Text="Tap Add to create your first vehicle"
                            FontSize="14"
                            TextColor="{StaticResource Gray600}"
                            HorizontalTextAlignment="Center">

                            <Label.Triggers>

                                <DataTrigger
                                    TargetType="Label"
                                    Binding="{Binding IsMainUser}"
                                    Value="False">
                                    <Setter Property="IsVisible" Value="False"/>
                                </DataTrigger>

                                <DataTrigger
                                    TargetType="Label"
                                    Binding="{Binding IsAddVehicleVisible}"
                                    Value="False">
                                    <Setter Property="IsVisible" Value="False"/>
                                </DataTrigger>

                            </Label.Triggers>
                        </Label>

                        <Label
                            Text="No vehicles are assigned to your active jobs right now"
                            FontSize="14"
                            TextColor="{StaticResource Gray600}"
                            HorizontalTextAlignment="Center"
                            IsVisible="{Binding IsSubUser}"/>

                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Style="{StaticResource CardBorderStyle}"
                            Padding="14"
                            Margin="0,0,0,12">

                            <VerticalStackLayout Spacing="14">

                                <!-- tappable header -->
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleVehicleExpandedCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                    <VerticalStackLayout Grid.Column="0" Spacing="8">

                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

                                            <Border
                                                BackgroundColor="{StaticResource Gray100}"
                                                Stroke="{StaticResource Gray300}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 12"
                                                Padding="8"
                                                VerticalOptions="Start">

                                                <Image
                                                    Source="vehicle.svg"
                                                    HeightRequest="18"
                                                    WidthRequest="18" />
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1" Spacing="6">

                                                <Label
                                                    FontSize="17"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource BrandTitle}">

                                                    <Label.Text>
                                                        <MultiBinding StringFormat="{}{0} {1} {2}">
                                                            <Binding Path="Year"/>
                                                            <Binding Path="Make"/>
                                                            <Binding Path="Model"/>
                                                        </MultiBinding>
                                                    </Label.Text>

                                                </Label>

                                                <Border
                                                    StrokeThickness="1"
                                                    Stroke="{StaticResource Gray300}"
                                                    StrokeShape="RoundRectangle 12"
                                                    BackgroundColor="{StaticResource BrandTileFill}"
                                                    Padding="10,6">

                                                    <Label
                                                        Text="{Binding VehicleTypeDisplay}"
                                                        FontSize="13"
                                                        TextColor="{StaticResource BrandInk}" />

                                                </Border>

                                            </VerticalStackLayout>
                                        </Grid>

                                        <Label
                                            Text="{Binding ExpandText}"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource Primary}" />
                                    </VerticalStackLayout>

                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding ExpandIcon}"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource Gray600}"
                                        VerticalOptions="Start" />
                                </Grid>

                                <!-- expandable details -->
                                <VerticalStackLayout
                                    Spacing="14"
                                    IsVisible="{Binding IsExpanded}">

                                    <!-- COMPLIANCE -->
                                    <Border
                                        StrokeThickness="1"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12">

                                        <VerticalStackLayout Spacing="8">

                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                <Image
                                                    Source="warning.svg"
                                                    HeightRequest="16"
                                                    WidthRequest="16"
                                                    VerticalOptions="Center" />

                                                <Label
                                                    Grid.Column="1"
                                                    Text="Compliance"
                                                    FontSize="13"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource BrandTitle}" />
                                            </Grid>

                                            <Label
                                                Text="{Binding Rego, StringFormat='Rego: {0}'}"
                                                FontSize="14"
                                                TextColor="{StaticResource BrandInk}" />

                                            <Label
                                                Text="{Binding RegoExpiryDisplay, StringFormat='Expires: {0}'}"
                                                FontSize="14"
                                                TextColor="{StaticResource BrandInk}" />

                                            <Label
                                                Text="{Binding RegoStatusInlineDisplay}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource BrandTitle}" />

                                            <Label
                                                Text="{Binding CertificateNameDisplay, StringFormat='{0} expiry'}"
                                                FontSize="14"
                                                TextColor="{StaticResource BrandInk}" />

                                            <Label
                                                Text="{Binding CertificateExpiryDisplay}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource BrandTitle}" />

                                            <Label
                                                Text="{Binding CertStatusInlineDisplay}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource BrandTitle}" />

                                        </VerticalStackLayout>
                                    </Border>

                                    <!-- ODOMETER -->
                                    <Border
                                        StrokeThickness="1"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12">

                                        <VerticalStackLayout Spacing="6">

                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                <Image
                                                    Source="odometer.svg"
                                                    HeightRequest="16"
                                                    WidthRequest="16"
                                                    VerticalOptions="Center" />

                                                <Label
                                                    Grid.Column="1"
                                                    Text="Odometer"
                                                    FontSize="13"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource BrandTitle}" />
                                            </Grid>

                                            <Label
                                                Text="{Binding OdometerFullDisplay, StringFormat='Current: {0}'}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource BrandInk}" />

                                        </VerticalStackLayout>
                                    </Border>

                                    <!-- RUC -->
                                    <Border
                                        StrokeThickness="1"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12"
                                        IsVisible="{Binding IsRucApplicable}">

                                        <VerticalStackLayout Spacing="8">

                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                <Image
                                                    Source="receipt.svg"
                                                    HeightRequest="16"
                                                    WidthRequest="16"
                                                    VerticalOptions="Center" />

                                                <Label
                                                    Grid.Column="1"
                                                    Text="RUC"
                                                    FontSize="13"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource BrandTitle}" />
                                            </Grid>

                                            <Label
                                                FontSize="14"
                                                TextColor="{StaticResource BrandInk}">

                                                <Label.Text>
                                                    <MultiBinding StringFormat="Licence: {0} to {1}">
                                                        <Binding Path="RucLicenceStartDisplay"/>
                                                        <Binding Path="RucLicenceEndDisplay"/>
                                                    </MultiBinding>
                                                </Label.Text>

                                            </Label>

                                            <Label
                                                Text="{Binding RucRemainingDisplay, StringFormat='Remaining: {0}'}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource BrandTitle}" />

                                            <Label
                                                Text="{Binding IsRucOverdueYesNo, StringFormat='Overdue: {0}'}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource BrandTitle}" />

                                        </VerticalStackLayout>
                                    </Border>

                                    <!-- edit button -->
                                    <Button
                                        Text="Edit vehicle"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditVehicleCommand}"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsMainUser}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HeightRequest="44" />

                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </RefreshView>

    </Grid>

</ContentPage>