<ContentPage
    x:Class="Haulory.Mobile.Views.DriverCollectionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="True" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*"
          Padding="20"
          RowSpacing="14"
          IsVisible="{Binding IsDriversVisible}">

        <!-- HEADER -->
        <Border
                Style="{StaticResource CardBorderStyle}"
                Stroke="{StaticResource Gray200}"
                StrokeShape="RoundRectangle 18"
                Padding="14">

            <VerticalStackLayout Spacing="12">

                <!-- INFO ROW -->
                <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">

                    <!-- Icon -->
                    <Border
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Stroke="{StaticResource Gray200}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="8"
                            VerticalOptions="Center">

                        <Image
                            Source="driver.svg"
                            HeightRequest="20"
                            WidthRequest="20" />
                    </Border>

                    <!-- Description -->
                    <Label
                        Grid.Column="1"
                        Text="Manage drivers, licences, and inductions."
                        FontSize="14"
                        TextColor="{StaticResource Gray600}"
                        VerticalTextAlignment="Center" />

                </Grid>

                <!-- DIVIDER -->
                <BoxView HeightRequest="1"
                 BackgroundColor="{StaticResource Gray200}" />

                <!-- ACTION BUTTONS -->
                <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="12">

                    <!-- Inductions -->
                    <Button
                            Grid.Column="0"
                            Text="Inductions"
                            Command="{Binding ManageInductionsCommand}"
                            IsVisible="{Binding IsInductionsVisible}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HeightRequest="44"
                            Padding="14,0" />

                    <!-- Add Driver -->
                    <Button
                            Grid.Column="1"
                            Text="Add Driver"
                            Command="{Binding AddDriverCommand}"
                            IsVisible="{Binding IsAddDriverVisible}"
                            IsEnabled="{Binding IsAddDriverEnabled}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HeightRequest="44"
                            Padding="14,0" />

                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- DRIVER LIST -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Drivers}"
                        SelectionMode="None"
                        Margin="0,2,0,0">

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="24"
                                     Spacing="10"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">

                    <Border
                        BackgroundColor="{StaticResource BrandTileFill}"
                        Stroke="{StaticResource Gray300}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="12">

                        <Image
                            Source="driver.svg"
                            HeightRequest="28"
                            WidthRequest="28" />
                    </Border>

                    <Label Text="No drivers added yet"
                           FontAttributes="Bold"
                           FontSize="17"
                           TextColor="{StaticResource BrandTitle}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorderStyle}"
                            Stroke="{StaticResource Gray300}"
                            StrokeShape="RoundRectangle 18"
                            Padding="14"
                            Margin="0,0,0,12">

                        <VerticalStackLayout Spacing="12">

                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="10"
                                  VerticalOptions="Center">


                                <Label Grid.Column="0"
                                       Text="{Binding DisplayName}"
                                       FontAttributes="Bold"
                                       FontSize="17"
                                       TextColor="{StaticResource BrandTitle}"
                                       LineBreakMode="TailTruncation"
                                       VerticalTextAlignment="Center" />

                                <Button Grid.Column="2"
                                        Text="Edit"
                                        FontSize="13"
                                        HeightRequest="36"
                                        Padding="12,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditDriverCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>

                            <!-- Show/Hide row -->
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding ExpandText}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" />

                                <Label Text="{Binding ExpandIcon}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Gray600}"
                                       VerticalTextAlignment="Center" />

                                <HorizontalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleDriverExpandedCommand}"
                                        CommandParameter="{Binding .}" />
                                </HorizontalStackLayout.GestureRecognizers>
                            </HorizontalStackLayout>

                            <!-- Expandable details -->
                            <VerticalStackLayout Spacing="12"
                                                 IsVisible="{Binding IsExpanded}">

                                <!-- Driver details -->
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12">

                                    <VerticalStackLayout Spacing="8">

                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Image
                                                Source="contact.svg"
                                                HeightRequest="16"
                                                WidthRequest="16"
                                                VerticalOptions="Center" />

                                            <Label Grid.Column="1"
                                                   Text="Driver details"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource BrandTitle}" />
                                        </Grid>

                                        <Label Text="{Binding Email, StringFormat='Email: {0}'}"
                                               FontSize="14"
                                               LineHeight="1.15"
                                               TextColor="{StaticResource BrandInk}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding Email}"
                                                             Value="{x:Null}">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding Email}"
                                                             Value="">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Label Text="{Binding PhoneNumber, StringFormat='Phone: {0}'}"
                                               FontSize="14"
                                               LineHeight="1.15"
                                               TextColor="{StaticResource BrandInk}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding PhoneNumber}"
                                                             Value="{x:Null}">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding PhoneNumber}"
                                                             Value="">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Label Text="{Binding DateOfBirthUtc, StringFormat='DOB: {0:yyyy-MM-dd}'}"
                                               FontSize="14"
                                               TextColor="{StaticResource BrandInk}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding DateOfBirthUtc}"
                                                             Value="{x:Null}">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Label Text="{Binding AddressSummary, StringFormat='Address: {0}'}"
                                               FontSize="14"
                                               LineHeight="1.15"
                                               TextColor="{StaticResource BrandInk}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding AddressSummary}"
                                                             Value="{x:Null}">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding AddressSummary}"
                                                             Value="">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                    </VerticalStackLayout>
                                </Border>

                                <!-- Licence details -->
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12">

                                    <VerticalStackLayout Spacing="8">

                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Image
                                                Source="license.svg"
                                                HeightRequest="16"
                                                WidthRequest="16"
                                                VerticalOptions="Center" />

                                            <Label Grid.Column="1"
                                                   Text="Licence details"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource BrandTitle}" />
                                        </Grid>

                                        <Label Text="{Binding LicenceNumber, StringFormat='Licence: {0}'}"
                                               FontSize="14"
                                               TextColor="{StaticResource BrandInk}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding LicenceNumber}"
                                                             Value="{x:Null}">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding LicenceNumber}"
                                                             Value="">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Label Text="{Binding LicenceClassOrEndorsements, StringFormat='Class/Endorsements: {0}'}"
                                               FontSize="14"
                                               LineHeight="1.15"
                                               TextColor="{StaticResource BrandInk}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding LicenceClassOrEndorsements}"
                                                             Value="{x:Null}">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding LicenceClassOrEndorsements}"
                                                             Value="">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Label Text="{Binding LicenceVersion, StringFormat='Version: {0}'}"
                                               FontSize="14"
                                               TextColor="{StaticResource BrandInk}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding LicenceVersion}"
                                                             Value="{x:Null}">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding LicenceVersion}"
                                                             Value="">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Label Text="{Binding LicenceIssuedOnUtc, StringFormat='Issued: {0:yyyy-MM-dd}'}"
                                               FontSize="14"
                                               TextColor="{StaticResource BrandInk}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding LicenceIssuedOnUtc}"
                                                             Value="{x:Null}">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Label Text="{Binding LicenceExpiresOnUtc, StringFormat='Licence expires: {0:yyyy-MM-dd}'}"
                                               FontSize="14"
                                               TextColor="{StaticResource BrandInk}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding LicenceExpiresOnUtc}"
                                                             Value="{x:Null}">
                                                    <Setter Property="IsVisible"
                                                            Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                    </VerticalStackLayout>
                                </Border>

                                <!-- Emergency contact -->
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray300}"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        StrokeShape="RoundRectangle 14"
                                        Padding="12"
                                        IsVisible="{Binding HasEmergencyContact}">

                                    <VerticalStackLayout Spacing="8">

                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Image
                                                Source="shield.svg"
                                                HeightRequest="16"
                                                WidthRequest="16"
                                                VerticalOptions="Center" />

                                            <Label Grid.Column="1"
                                                   Text="Emergency contact"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource BrandTitle}" />
                                        </Grid>

                                        <Label Text="{Binding EmergencyContactName, StringFormat='Name: {0}'}"
                                               FontSize="14"
                                               TextColor="{StaticResource BrandInk}" />

                                        <Label Text="{Binding EmergencyContactPhone, StringFormat='Phone: {0}'}"
                                               FontSize="14"
                                               TextColor="{StaticResource BrandInk}" />

                                        <Label Text="{Binding EmergencyContactEmail, StringFormat='Email: {0}'}"
                                               FontSize="14"
                                               TextColor="{StaticResource BrandInk}" />
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>