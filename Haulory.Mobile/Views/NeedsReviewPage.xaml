<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.NeedsReviewPage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="True" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*"
          Padding="20"
          RowSpacing="14">

        <!-- HEADER -->
        <VerticalStackLayout Grid.Row="0" Spacing="12">

            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="12"
                  VerticalOptions="Center">

                <Border
                    Grid.Column="0"
                    BackgroundColor="{StaticResource Gray100}"
                    Stroke="{StaticResource Gray300}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="10"
                    VerticalOptions="Center">

                    <Image
                        Source="warning.svg"
                        HeightRequest="22"
                        WidthRequest="22" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="3">
                    <Label Text="Needs Review"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Label Text="Review completed jobs with wait time or damage notes"
                           FontSize="14"
                           TextColor="{StaticResource Gray600}" />
                </VerticalStackLayout>
            </Grid>

            <Border Style="{StaticResource CardBorderStyle}"
                    Stroke="{StaticResource Gray300}"
                    Padding="14">
                <VerticalStackLayout Spacing="8">

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                        <Image Source="checklist.svg"
                               HeightRequest="16"
                               WidthRequest="16"
                               VerticalOptions="Center" />

                        <Label Grid.Column="1"
                               Text="Review queue"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />
                    </Grid>

                    <Label Text="Open any job below to review exceptions and approve the delivery outcome."
                           FontSize="14"
                           TextColor="{StaticResource BrandInk}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- LIST -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}">

            <CollectionView ItemsSource="{Binding Jobs}"
                            SelectionMode="None"
                            Margin="0,2,0,0">

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24"
                                         Spacing="8"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">

                        <Border
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Stroke="{StaticResource Gray300}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="12">

                            <Image Source="checklist.svg"
                                   HeightRequest="26"
                                   WidthRequest="26" />
                        </Border>

                        <Label Text="No jobs need review"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Exception deliveries will appear here"
                               FontSize="14"
                               TextColor="{StaticResource Gray600}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorderStyle}"
                                Stroke="{StaticResource Gray300}"
                                StrokeShape="RoundRectangle 18"
                                Padding="14"
                                Margin="0,0,0,12">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenReviewCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="12">

                                <!-- Job header -->
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10">

                                    <Border
                                        BackgroundColor="{StaticResource Gray100}"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="8"
                                        VerticalOptions="Start">

                                        <Image
                                            Source="warning.svg"
                                            HeightRequest="18"
                                            WidthRequest="18" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                        <Label Text="{Binding ReferenceNumber}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandTitle}" />

                                        <Label Text="{Binding DeliveryCompany}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandInk}" />

                                        <Label Text="{Binding LoadDescription}"
                                               FontSize="13"
                                               LineHeight="1.15"
                                               TextColor="{StaticResource Gray600}"
                                               LineBreakMode="WordWrap"
                                               MaxLines="2" />
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Action prompt -->
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="10,8">

                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="8">
                                        <Image Source="check.svg"
                                               HeightRequest="16"
                                               WidthRequest="16"
                                               VerticalOptions="Center" />

                                        <Label Grid.Column="1"
                                               Text="Tap to review and approve"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandAccent}" />
                                    </Grid>
                                </Border>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>