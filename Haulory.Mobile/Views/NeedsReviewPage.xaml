<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.NeedsReviewPage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="True" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*"
          Padding="20"
          RowSpacing="14">

        <!-- HEADER -->
        <VerticalStackLayout Grid.Row="0" Spacing="12">

            <Border Style="{StaticResource CardBorderStyle}"
                    Stroke="{StaticResource Gray300}"
                    Padding="14">
                <VerticalStackLayout Spacing="8">

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                        <Image Source="checklist.svg"
                               HeightRequest="16"
                               WidthRequest="16"
                               VerticalOptions="Center" />

                        <Label Grid.Column="1"
                               Text="Review queue"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />
                    </Grid>

                    <Label Text="Open any job below to review exceptions and approve the delivery outcome."
                           FontSize="14"
                           TextColor="{StaticResource BrandInk}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- LIST -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}">

            <CollectionView ItemsSource="{Binding Jobs}"
                            SelectionMode="None"
                            Margin="0,2,0,0">

                <CollectionView.EmptyView>
                    <Border
                            Style="{StaticResource CardBorderStyle}"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 20"
                            Padding="20"
                            Margin="0,12,0,0">

                        <VerticalStackLayout
                                        Spacing="10"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center">

                            <!-- Icon -->
                            <Border
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Stroke="{StaticResource Gray200}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18"
                                Padding="12"
                                HorizontalOptions="Center">

                                <Image
                                    Source="checklist.svg"
                                    HeightRequest="26"
                                    WidthRequest="26" />
                            </Border>

                            <!-- Title -->
                            <Label
                                Text="No jobs need review"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}"
                                HorizontalTextAlignment="Center" />

                            <!-- Subtitle -->
                            <Label
                                Text="Exception deliveries will appear here"
                                FontSize="13"
                                TextColor="{StaticResource Gray600}"
                                HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                    </Border>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorderStyle}"
                                Stroke="{StaticResource Gray300}"
                                StrokeShape="RoundRectangle 18"
                                Padding="14"
                                Margin="0,0,0,12">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenReviewCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="12">

                                <!-- Job header -->
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10">

                                    <Border
                                        BackgroundColor="{StaticResource Gray100}"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="8"
                                        VerticalOptions="Start">

                                        <Image
                                            Source="warning.svg"
                                            HeightRequest="18"
                                            WidthRequest="18" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                        <Label Text="{Binding ReferenceNumber}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandTitle}" />

                                        <Label Text="{Binding DeliveryCompany}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandInk}" />

                                        <Label Text="{Binding LoadDescription}"
                                               FontSize="13"
                                               LineHeight="1.15"
                                               TextColor="{StaticResource Gray600}"
                                               LineBreakMode="WordWrap"
                                               MaxLines="2" />
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Action prompt -->
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="10,8">

                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="8">
                                        <Image Source="check.svg"
                                               HeightRequest="16"
                                               WidthRequest="16"
                                               VerticalOptions="Center" />

                                        <Label Grid.Column="1"
                                               Text="Tap to review and approve"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource BrandAccent}" />
                                    </Grid>
                                </Border>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>