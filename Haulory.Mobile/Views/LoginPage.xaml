<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.LoginPage"
    BackgroundColor="{StaticResource BrandBackground}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <!-- Main content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout
                Padding="24,40,24,24"
                Spacing="24"
                VerticalOptions="Center">

                <!-- Brand Header -->
                <VerticalStackLayout
                    Spacing="8"
                    HorizontalOptions="Center">

                    <Label
                        Text="Haulory"
                        FontSize="34"
                        FontAttributes="Bold"
                        TextColor="{StaticResource BrandTitle}"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Transport and logistics management"
                        FontSize="14"
                        TextColor="{StaticResource Gray600}"
                        HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Login card -->
                <Border
                    Style="{StaticResource CardBorderStyle}"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 22"
                    Padding="22"
                    MaximumWidthRequest="460"
                    HorizontalOptions="Center">

                    <VerticalStackLayout Spacing="18">

                        <VerticalStackLayout Spacing="4">
                            <Label
                                Text="Welcome back"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}" />

                            <Label
                                Text="Sign in to manage jobs, vehicles, drivers, and compliance."
                                FontSize="13"
                                TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>

                        <!-- Email -->
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Email"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}" />

                            <Border
                                Style="{StaticResource InputBorderStyle}"
                                Stroke="{StaticResource Gray300}"
                                BackgroundColor="{StaticResource White}">

                                <Entry
                                    Placeholder="Enter your email address"
                                    Text="{Binding Email}"
                                    Keyboard="Email"
                                    ClearButtonVisibility="WhileEditing"
                                    HeightRequest="44"
                                    TextColor="{StaticResource BrandInk}"
                                    PlaceholderColor="{StaticResource Gray500}"
                                    BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Password"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}" />

                            <Border
                                Style="{StaticResource InputBorderStyle}"
                                Stroke="{StaticResource Gray300}"
                                BackgroundColor="{StaticResource White}">

                                <Entry
                                    Placeholder="Enter your password"
                                    Text="{Binding Password}"
                                    IsPassword="True"
                                    HeightRequest="44"
                                    TextColor="{StaticResource BrandInk}"
                                    PlaceholderColor="{StaticResource Gray500}"
                                    BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Optional helper row -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                            <Label
                                Text="Access your fleet dashboard securely"
                                FontSize="12"
                                TextColor="{StaticResource Gray600}"
                                VerticalOptions="Center" />

                            <Label
                                Grid.Column="1"
                                Text="Need help?"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="{StaticResource Primary}"
                                VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding HelpCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <!-- Login button -->
                        <Button
                            Text="Sign In"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />

                        <!-- Register link -->
                        <HorizontalStackLayout
                            HorizontalOptions="Center"
                            Spacing="6"
                            Margin="0,4,0,0">

                            <Label
                                Text="Need an account?"
                                FontSize="12"
                                TextColor="{StaticResource Gray600}" />

                            <Label
                                Text="Create one"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandAccent}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer -->
        <Border
            Grid.Row="1"
            BackgroundColor="{StaticResource BrandSurface}"
            StrokeThickness="1"
            Stroke="{StaticResource Gray200}"
            StrokeShape="RoundRectangle 18,18,0,0"
            Padding="18,12">

            <HorizontalStackLayout
                HorizontalOptions="Center"
                Spacing="6">

                <Label
                    Text="Secure transport, fleet, and compliance management"
                    FontSize="12"
                    TextColor="{StaticResource Gray600}"
                    VerticalOptions="Center" />

                <Label
                    Text="•"
                    FontSize="12"
                    TextColor="{StaticResource Gray500}"
                    VerticalOptions="Center" />

                <Label
                    Text="Haulory"
                    FontSize="12"
                    FontAttributes="Bold"
                    TextColor="{StaticResource BrandTitle}"
                    VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

    </Grid>
</ContentPage>