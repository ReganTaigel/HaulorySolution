<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.ReportsPage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="12"
                  IsVisible="{Binding IsReportsVisible}">

                <Border
                    BackgroundColor="{StaticResource Gray100}"
                    Stroke="{StaticResource Gray300}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="10">

                    <Image
                        Source="reports.svg"
                        HeightRequest="22"
                        WidthRequest="22" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="3">
                    <Label Text="Reports"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Label Text="Delivered jobs and totals for the selected date"
                           FontSize="14"
                           TextColor="{StaticResource Gray600}" />
                </VerticalStackLayout>

            </Grid>

            <!-- Stats row -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  IsVisible="{Binding IsReportsVisible}">

                <Border Grid.Column="0"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray300}"
                        StrokeShape="RoundRectangle 18"
                        BackgroundColor="{StaticResource BrandSurface}"
                        Padding="14">

                    <VerticalStackLayout Spacing="6">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Image Source="delivery.svg"
                                   HeightRequest="16"
                                   WidthRequest="16"
                                   VerticalOptions="Center"/>

                            <Label Grid.Column="1"
                                   Text="Delivered"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray600}" />
                        </Grid>

                        <Label Text="{Binding DeliveredCount}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />

                        <Label Text="Completed deliveries"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />

                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray300}"
                        StrokeShape="RoundRectangle 18"
                        BackgroundColor="{StaticResource BrandSurface}"
                        Padding="14">

                    <VerticalStackLayout Spacing="6">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Image Source="dollar.svg"
                                   HeightRequest="16"
                                   WidthRequest="16"
                                   VerticalOptions="Center"/>

                            <Label Grid.Column="1"
                                   Text="Revenue"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray600}" />
                        </Grid>

                        <Label Text="{Binding TotalRevenue, StringFormat='{0:N2}'}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandAccent}" />

                        <Label Text="Total for date"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />

                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- Controls card -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource BrandSurface}"
                    Padding="16"
                    IsVisible="{Binding IsReportsVisible}">

                <VerticalStackLayout Spacing="12">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Image Source="calendar.svg"
                               HeightRequest="16"
                               WidthRequest="16"
                               VerticalOptions="Center"/>

                        <Label Grid.Column="1"
                               Text="Report date"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />
                    </Grid>

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12,8">

                        <DatePicker Date="{Binding SelectedDate}"
                                    TextColor="{StaticResource BrandInk}"
                                    BackgroundColor="Transparent" />
                    </Border>

                    <Button Text="Refresh"
                            Command="{Binding RefreshCommand}"
                            IsEnabled="{Binding IsReportsEnabled}"
                            HeightRequest="46"
                            CornerRadius="14"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}" />

                </VerticalStackLayout>
            </Border>

            <!-- Receipts list -->
            <CollectionView ItemsSource="{Binding Receipts}"
                            SelectionMode="None"
                            Margin="0,2,0,0"
                            IsVisible="{Binding IsReportsVisible}">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="6"
                                         Margin="0,18,0,0">

                        <Border
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Stroke="{StaticResource Gray300}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="12">

                            <Image Source="receipt.svg"
                                   HeightRequest="26"
                                   WidthRequest="26"/>
                        </Border>

                        <Label Text="No delivery receipts yet"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />

                        <Label Text="Complete a delivery to see receipts here"
                               FontSize="13"
                               HorizontalTextAlignment="Center"
                               TextColor="{StaticResource Gray600}" />

                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <!-- Receipt item -->
                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray300}"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="{StaticResource BrandSurface}"
                                Padding="14"
                                Margin="0,0,0,12">

                            <VerticalStackLayout Spacing="10">

                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8">

                                    <Image Source="receipt.svg"
                                           HeightRequest="16"
                                           WidthRequest="16"
                                           VerticalOptions="Center"/>

                                    <Label Grid.Column="1"
                                           Text="{Binding ReferenceNumber}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BrandTitle}"
                                           LineBreakMode="TailTruncation" />

                                </Grid>

                                <Label Text="{Binding DeliveryCompany}"
                                       FontSize="14"
                                       TextColor="{StaticResource BrandInk}"
                                       LineBreakMode="TailTruncation" />

                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Gray200}"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{StaticResource BrandTileFill}"
                                        Padding="12">

                                    <VerticalStackLayout Spacing="6">

                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="8">

                                            <Image Source="signature.svg"
                                                   HeightRequest="16"
                                                   WidthRequest="16"
                                                   VerticalOptions="Center"/>

                                            <Label Grid.Column="1"
                                                   Text="{Binding ReceiverName, StringFormat='Signed by {0}'}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource BrandTitle}" />

                                        </Grid>

                                        <Label Text="{Binding DeliveredLocal, StringFormat='Delivered {0:dd MMM yyyy HH:mm}'}"
                                               FontSize="13"
                                               TextColor="{StaticResource BrandInk}" />

                                    </VerticalStackLayout>
                                    
                                </Border>
                                <!-- Export actions -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                                    <Button Grid.Column="0"
                                            Text="Export Invoice"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ExportInvoiceCommand}"
                                            CommandParameter="{Binding Id}"
                                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsExportInvoiceVisible}"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsExportInvoiceEnabled}"
                                            HeightRequest="42"
                                            CornerRadius="12"
                                            BackgroundColor="{StaticResource Secondary}"
                                            TextColor="{StaticResource White}"
                                            HorizontalOptions="Fill" />

                                    <Button Grid.Column="1"
                                            Text="Export POD"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ExportPodCommand}"
                                            CommandParameter="{Binding Id}"
                                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsExportPodVisible}"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsExportPodEnabled}"
                                            HeightRequest="42"
                                            CornerRadius="12"
                                            BackgroundColor="{StaticResource Secondary}"
                                            TextColor="{StaticResource White}"
                                            HorizontalOptions="Fill" />

                                </Grid>
                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>