<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.DashboardPage"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,28,20,24" Spacing="18">

                <!-- HEADER -->
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12"
                          VerticalOptions="Center">

                        <Border
                            Grid.Column="0"
                            BackgroundColor="{StaticResource Gray100}"
                            Stroke="{StaticResource Gray300}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="10"
                            VerticalOptions="Center">

                            <Image
                                Source="dashboard.svg"
                                HeightRequest="22"
                                WidthRequest="22" />
                        </Border>

                        <VerticalStackLayout
                            Grid.Column="1"
                            Spacing="2"
                            VerticalOptions="Center">

                            <Label
                                Text="Dashboard"
                                FontSize="30"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}" />

                            <Label
                                Text="Business overview"
                                FontSize="14"
                                TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>

                <!-- HERO SUMMARY -->
                <Border
                    Style="{StaticResource CardBorderStyle}"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 20"
                    Padding="18">

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Border
                                BackgroundColor="{StaticResource Gray100}"
                                Stroke="{StaticResource Gray300}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                Padding="8"
                                VerticalOptions="Start">

                                <Image
                                    Source="checklist.svg"
                                    HeightRequest="18"
                                    WidthRequest="18" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label
                                    Text="Today at a glance"
                                    FontSize="19"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource BrandTitle}" />

                                <Label
                                    Text="{Binding CurrentJobSummary}"
                                    FontSize="14"
                                    LineHeight="1.2"
                                    TextColor="{StaticResource BrandInk}"
                                    LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView
                            HeightRequest="1"
                            BackgroundColor="{StaticResource Gray200}" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Border
                                BackgroundColor="{StaticResource Gray100}"
                                Stroke="{StaticResource Gray300}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                Padding="8"
                                VerticalOptions="Start">

                                <Image
                                    Source="vehicle.svg"
                                    HeightRequest="18"
                                    WidthRequest="18" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label
                                    Text="Day status"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource BrandTitle}" />

                                <Label
                                    Text="{Binding AssignedVehicleDisplay}"
                                    FontSize="14"
                                    TextColor="{StaticResource BrandInk}" />

                                <Label
                                    Text="{Binding DayStatusText}"
                                    FontSize="14"
                                    LineHeight="1.15"
                                    TextColor="{StaticResource Gray600}" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="10">
                            <Button
                                Text="Start Day"
                                Command="{Binding StartDayCommand}"
                                IsVisible="{Binding IsStartDayVisible}"
                                IsEnabled="{Binding CanStartDayAction}"
                                Style="{StaticResource PrimaryButtonStyle}" />

                            <Button
                                Text="End Day"
                                Command="{Binding EndDayCommand}"
                                IsVisible="{Binding IsEndDayVisible}"
                                IsEnabled="{Binding CanEndDayAction}"
                                Style="{StaticResource AccentButtonStyle}" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- QUICK STATS -->
                <Border
                    Style="{StaticResource CardBorderStyle}"
                    IsVisible="{Binding IsMainUser}"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 20"
                    Padding="18">

                    <VerticalStackLayout Spacing="14">

                        <VerticalStackLayout Spacing="3">
                            <Label
                                Text="Quick stats"
                                FontSize="19"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}" />

                            <Label
                                Text="Track todays performance and items needing attention."
                                FontSize="13"
                                LineHeight="1.15"
                                TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>

                        <!-- Delivered -->
                        <Border
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray300}"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="14">

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border
                                    BackgroundColor="{StaticResource Gray100}"
                                    Stroke="{StaticResource Gray300}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="8"
                                    VerticalOptions="Center">

                                    <Image
                                        Source="delivery.svg"
                                        HeightRequest="18"
                                        WidthRequest="18" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label
                                        Text="Delivered"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />
                                    <Label
                                        Text="Jobs completed today"
                                        FontSize="13"
                                        TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <Label
                                    Grid.Column="2"
                                    Text="{Binding CompletedTodayCount}"
                                    FontSize="26"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource StatusCompleted}"
                                    VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Revenue -->
                        <Border
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray300}"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="14">

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border
                                    BackgroundColor="{StaticResource Gray100}"
                                    Stroke="{StaticResource Gray300}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="8"
                                    VerticalOptions="Center">

                                    <Image
                                        Source="dollar.svg"
                                        HeightRequest="18"
                                        WidthRequest="18" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label
                                        Text="Revenue today"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />
                                    <Label
                                        Text="Track earnings and trends"
                                        FontSize="13"
                                        TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <Label
                                    Grid.Column="2"
                                    Text="{Binding RevenueToday, StringFormat='{0:N2}'}"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource BrandAccent}"
                                    VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Needs review -->
                        <Border
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray300}"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="14">

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border
                                    BackgroundColor="{StaticResource Gray100}"
                                    Stroke="{StaticResource Gray300}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="8"
                                    VerticalOptions="Center">

                                    <Image
                                        Source="warning.svg"
                                        HeightRequest="18"
                                        WidthRequest="18" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label
                                        Text="Needs review"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />
                                    <Label
                                        Text="{Binding NeedsReviewSummary}"
                                        FontSize="13"
                                        LineHeight="1.15"
                                        TextColor="{StaticResource Gray600}"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="2" />
                                </VerticalStackLayout>

                                <Label
                                    Grid.Column="2"
                                    Text="{Binding NeedsReviewCount}"
                                    FontSize="26"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource BrandDanger}"
                                    VerticalTextAlignment="Center" />
                            </Grid>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToNeedsReviewCommand}" />
                            </Border.GestureRecognizers>
                        </Border>

                        <!-- Latest completed -->
                        <Border
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray300}"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="14">

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border
                                    BackgroundColor="{StaticResource Gray100}"
                                    Stroke="{StaticResource Gray300}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="8"
                                    VerticalOptions="Start">

                                    <Image
                                        Source="check.svg"
                                        HeightRequest="18"
                                        WidthRequest="18" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label
                                        Text="Latest completed"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />
                                    <Label
                                        Text="{Binding LatestCompletedSummary}"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        LineHeight="1.15"
                                        TextColor="{StaticResource BrandInk}"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="2" />
                                    <Label
                                        Text="Open Reports for details"
                                        FontSize="13"
                                        TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>
                            </Grid>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToReportsCommand}" />
                            </Border.GestureRecognizers>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- ACTIONS -->
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Manage"
                        FontSize="19"
                        FontAttributes="Bold"
                        Margin="2,2,0,0"
                        TextColor="{StaticResource BrandTitle}" />

                    <Label
                        Text="Open the areas you use every day."
                        FontSize="13"
                        TextColor="{StaticResource Gray600}"
                        Margin="2,0,0,0" />
                </VerticalStackLayout>

                <!-- Jobs -->
                <Border
                    Style="{StaticResource ActionCardBorderStyle}"
                    Padding="16"
                    IsVisible="{Binding IsJobsVisible}">

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border
                            BackgroundColor="{StaticResource Gray100}"
                            Stroke="{StaticResource Gray300}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="8"
                            VerticalOptions="Center">

                            <Image
                                Source="jobs.svg"
                                HeightRequest="18"
                                WidthRequest="18" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label
                                Text="Jobs"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}" />
                            <Label
                                Text="Create, allocate, and track deliveries"
                                FontSize="13"
                                LineHeight="1.15"
                                TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>

                        <Button
                            Grid.Column="2"
                            Text="Open"
                            Command="{Binding GoToJobsCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HeightRequest="44"
                            Padding="16,0"
                            IsEnabled="{Binding IsJobsEnabled}" />
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToJobsCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Vehicles -->
                <Border
                    Style="{StaticResource ActionCardBorderStyle}"
                    Padding="16"
                    IsVisible="{Binding IsVehiclesVisible}">

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border
                            BackgroundColor="{StaticResource Gray100}"
                            Stroke="{StaticResource Gray300}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="8"
                            VerticalOptions="Center">

                            <Image
                                Source="vehicle.svg"
                                HeightRequest="18"
                                WidthRequest="18" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label
                                Text="Vehicles"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}" />
                            <Label
                                Text="Manage units, configurations, and assets"
                                FontSize="13"
                                LineHeight="1.15"
                                TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>

                        <Button
                            Grid.Column="2"
                            Text="Open"
                            Command="{Binding GoToVehiclesCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HeightRequest="44"
                            Padding="16,0"
                            IsEnabled="{Binding IsVehiclesEnabled}" />
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToVehiclesCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Drivers -->
                <Border
                    Style="{StaticResource ActionCardBorderStyle}"
                    Padding="16"
                    IsVisible="{Binding IsDriversVisible}">

                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding IsMainUser}"
                                     Value="False">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Border.Triggers>

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border
                            BackgroundColor="{StaticResource Gray100}"
                            Stroke="{StaticResource Gray300}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="8"
                            VerticalOptions="Center">

                            <Image
                                Source="driver.svg"
                                HeightRequest="18"
                                WidthRequest="18" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label
                                Text="Drivers"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}" />
                            <Label
                                Text="Profiles, licences, compliance, and contacts"
                                FontSize="13"
                                LineHeight="1.15"
                                TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>

                        <Button
                            Grid.Column="2"
                            Text="Open"
                            Command="{Binding GoToDriversCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HeightRequest="44"
                            Padding="16,0"
                            IsEnabled="{Binding IsDriversEnabled}" />
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToDriversCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Reports -->
                <Border
                    Style="{StaticResource ActionCardBorderStyle}"
                    Padding="16"
                    IsVisible="{Binding IsReportsVisible}">

                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding IsMainUser}"
                                     Value="False">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Border.Triggers>

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border
                            BackgroundColor="{StaticResource Gray100}"
                            Stroke="{StaticResource Gray300}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="8"
                            VerticalOptions="Center">

                            <Image
                                Source="reports.svg"
                                HeightRequest="18"
                                WidthRequest="18" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label
                                Text="Reports"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}" />
                            <Label
                                Text="Revenue, delivered jobs, and performance"
                                FontSize="13"
                                LineHeight="1.15"
                                TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>

                        <Button
                            Grid.Column="2"
                            Text="Open"
                            Command="{Binding GoToReportsCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HeightRequest="44"
                            Padding="16,0"
                            IsEnabled="{Binding IsReportsEnabled}" />
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToReportsCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- LOGOUT -->
                <Border
                    StrokeThickness="1"
                    Stroke="{StaticResource BrandDanger}"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="{StaticResource BrandDeep}"
                    Padding="16"
                    Margin="0,8,0,6">

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border
                            BackgroundColor="#FFFFFF14"
                            Stroke="{StaticResource BrandDanger}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="8"
                            VerticalOptions="Center">

                            <Image
                                Source="close.svg"
                                HeightRequest="18"
                                WidthRequest="18" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                            <Label
                                Text="Logout"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="{StaticResource White}" />
                            <Label
                                Text="Sign out of Haulory on this device"
                                FontSize="13"
                                TextColor="{StaticResource Gray200}" />
                        </VerticalStackLayout>

                        <Button
                            Grid.Column="2"
                            Text="Sign out"
                            Command="{Binding LogoutCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            HeightRequest="44"
                            Padding="16,0" />
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                    </Border.GestureRecognizers>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer -->
        <Border
            Grid.Row="1"
            BackgroundColor="{StaticResource Gray100}"
            StrokeThickness="1"
            Stroke="{StaticResource Gray300}"
            StrokeShape="RoundRectangle 18,18,0,0"
            Padding="18,12">

            <HorizontalStackLayout
                HorizontalOptions="Center"
                Spacing="6">

                <Label
                    Text="Transport, fleet, and compliance management"
                    FontSize="13"
                    TextColor="{StaticResource Gray600}"
                    VerticalOptions="Center" />

                <Label
                    Text="Haulory"
                    FontSize="13"
                    FontAttributes="Bold"
                    TextColor="{StaticResource BrandTitle}"
                    VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

    </Grid>
</ContentPage>
   