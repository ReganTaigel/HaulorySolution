<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.DashboardPage"
    Title="Dashboard"
    BackgroundColor="{StaticResource BrandBackground}">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- HERO SUMMARY -->
                <Border
                    Style="{StaticResource CardBorderStyle}"
                    Stroke="{StaticResource Gray200}"
                    StrokeShape="RoundRectangle 20"
                    Padding="18">

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Border
                                BackgroundColor="{StaticResource White}"
                                Stroke="{StaticResource Gray200}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                Padding="8"
                                VerticalOptions="Start">

                                <Image
                                    Source="checklist.svg"
                                    HeightRequest="18"
                                    WidthRequest="18" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label
                                    Text="Today at a glance"
                                    FontSize="19"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource BrandTitle}" />

                                <Label
                                    Text="{Binding CurrentJobSummary}"
                                    FontSize="14"
                                    LineHeight="1.2"
                                    TextColor="{StaticResource BrandInk}"
                                    LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView
                            HeightRequest="1"
                            BackgroundColor="{StaticResource Gray200}" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Border
                                BackgroundColor="{StaticResource White}"
                                Stroke="{StaticResource Gray200}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                Padding="8"
                                VerticalOptions="Start">

                                <Image
                                    Source="vehicle.svg"
                                    HeightRequest="18"
                                    WidthRequest="18" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label
                                    Text="Day status"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource BrandTitle}" />

                                <Label
                                    Text="{Binding AssignedVehicleDisplay}"
                                    FontSize="14"
                                    TextColor="{StaticResource BrandInk}" />

                                <Label
                                    Text="{Binding DayStatusText}"
                                    FontSize="14"
                                    LineHeight="1.15"
                                    TextColor="{StaticResource Gray600}" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="10">
                            <Button
                                Text="Start Day"
                                Command="{Binding StartDayCommand}"
                                IsVisible="{Binding IsStartDayVisible}"
                                IsEnabled="{Binding CanStartDayAction}"
                                Style="{StaticResource PrimaryButtonStyle}" />

                            <Button
                                Text="End Day"
                                Command="{Binding EndDayCommand}"
                                IsVisible="{Binding IsEndDayVisible}"
                                IsEnabled="{Binding CanEndDayAction}"
                                Style="{StaticResource AccentButtonStyle}" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- QUICK STATS -->
                <Border
                    Style="{StaticResource CardBorderStyle}"
                    IsVisible="{Binding IsMainUser}"
                    Stroke="{StaticResource Gray200}"
                    StrokeShape="RoundRectangle 20"
                    Padding="18">

                    <VerticalStackLayout Spacing="14">

                        <VerticalStackLayout Spacing="4">
                            <Label
                                Text="Quick stats"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}" />

                            <Label
                                Text="Track todays performance and items needing attention."
                                FontSize="13"
                                LineHeight="1.15"
                                TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>

                        <!-- Delivered -->
                        <Border
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{StaticResource White}"
                            Padding="14">

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border
                                    BackgroundColor="{StaticResource Gray100}"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="8"
                                    VerticalOptions="Center">

                                    <Image
                                        Source="delivery.svg"
                                        HeightRequest="18"
                                        WidthRequest="18" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label
                                        Text="Delivered"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}"
                                        Opacity="0.9" />
                                    <Label
                                        Text="Jobs completed today"
                                        FontSize="13"
                                        TextColor="{StaticResource Gray600}"
                                        Opacity="0.8" />
                                </VerticalStackLayout>

                                <Label
                                    Grid.Column="2"
                                    Text="{Binding CompletedTodayCount}"
                                    FontSize="26"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource StatusCompleted}"
                                    VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Revenue -->
                        <Border
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{StaticResource White}"
                            Padding="14">

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border
                                    BackgroundColor="{StaticResource Gray100}"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="8"
                                    VerticalOptions="Center">

                                    <Image
                                        Source="dollar.svg"
                                        HeightRequest="18"
                                        WidthRequest="18" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label
                                        Text="Revenue today"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}"
                                        Opacity="0.9" />
                                    <Label
                                        Text="Track earnings and trends"
                                        FontSize="13"
                                        TextColor="{StaticResource Gray600}"
                                        Opacity="0.8" />
                                </VerticalStackLayout>

                                <Label
                                    Grid.Column="2"
                                    Text="{Binding RevenueToday, StringFormat='{0:N2}'}"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource StatusCompleted}"
                                    VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Needs review -->
                        <Border
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{StaticResource White}"
                            Padding="14">

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border
                                    BackgroundColor="{StaticResource Gray100}"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="8"
                                    VerticalOptions="Center">

                                    <Image
                                        Source="warning.svg"
                                        HeightRequest="18"
                                        WidthRequest="18" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label
                                        Text="Needs review"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}"
                                        Opacity="0.9" />
                                    <Label
                                        Text="{Binding NeedsReviewSummary}"
                                        FontSize="13"
                                        LineHeight="1.15"
                                        TextColor="{StaticResource Gray600}"
                                        Opacity="0.8"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="2" />
                                </VerticalStackLayout>

                                <Label
                                    Grid.Column="2"
                                    Text="{Binding NeedsReviewCount}"
                                    FontSize="26"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource BrandDanger}"
                                    VerticalTextAlignment="Center" />
                            </Grid>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToNeedsReviewCommand}" />
                            </Border.GestureRecognizers>
                        </Border>

                        <!-- Latest completed -->
                        <Border
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{StaticResource White}"
                            Padding="14">

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border
                                    BackgroundColor="{StaticResource Gray100}"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="8"
                                    VerticalOptions="Start">

                                    <Image
                                        Source="check.svg"
                                        HeightRequest="18"
                                        WidthRequest="18" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label
                                        Text="Latest completed"
                                        FontSize="13"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}"
                                        Opacity="0.9" />
                                    <Label
                                        Text="{Binding LatestCompletedSummary}"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        LineHeight="1.15"
                                        TextColor="{StaticResource BrandInk}"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="2" />
                                    <Label
                                        Text="Open Reports for details"
                                        FontSize="13"
                                        TextColor="{StaticResource Gray600}"
                                        Opacity="0.8" />
                                </VerticalStackLayout>
                            </Grid>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToReportsCommand}" />
                            </Border.GestureRecognizers>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- ACTIONS CARD -->
                <Border
                    Style="{StaticResource CardBorderStyle}"
                    Padding="18">

                    <VerticalStackLayout Spacing="12">

                        <!-- Header -->
                        <VerticalStackLayout Spacing="4">
                            <Label
                                Text="Manage"
                                FontSize="19"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}" />

                            <Label
                                Text="Open the areas you use every day."
                                FontSize="13"
                                TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>

                        <!-- Divider -->
                        <BoxView HeightRequest="1"
                                     BackgroundColor="{StaticResource Gray200}" />

                        <!-- Jobs -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12"
                              Padding="0,6">

                            <Image Source="jobs.svg"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   VerticalOptions="Center" />

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Jobs"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="{StaticResource BrandTitle}" />
                                <Label Text="Create and track deliveries"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray600}" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="›"
                                   FontSize="20"
                                   TextColor="{StaticResource Gray400}"
                                   VerticalOptions="Center" />

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToJobsCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="1"
                                    BackgroundColor="{StaticResource Gray200}" />

                        <!-- Vehicles -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12"
                              Padding="0,6">

                            <Image Source="vehicle.svg"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   VerticalOptions="Center" />

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Vehicles"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="{StaticResource BrandTitle}" />
                                <Label Text="Manage fleet and assets"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray600}" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="›"
                                   FontSize="20"
                                   TextColor="{StaticResource Gray400}"
                                   VerticalOptions="Center" />

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToVehiclesCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="1"
                                    BackgroundColor="{StaticResource Gray200}" />

                        <!-- Drivers -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12"
                              Padding="0,6"
                              IsVisible="{Binding IsDriversVisible}">

                            <Image Source="driver.svg"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   VerticalOptions="Center" />

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Drivers"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="{StaticResource BrandTitle}" />
                                <Label Text="Profiles and compliance"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray600}" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="›"
                                   FontSize="20"
                                   TextColor="{StaticResource Gray400}"
                                   VerticalOptions="Center" />

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToDriversCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="1"
                                    BackgroundColor="{StaticResource Gray200}" />

                        <!-- Reports -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12"
                              Padding="0,6"
                              IsVisible="{Binding IsReportsVisible}">

                            <Image Source="reports.svg"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   VerticalOptions="Center" />

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Reports"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="{StaticResource BrandTitle}" />
                                <Label Text="Revenue and performance"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray600}" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="›"
                                   FontSize="20"
                                   TextColor="{StaticResource Gray400}"
                                   VerticalOptions="Center" />

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToReportsCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>