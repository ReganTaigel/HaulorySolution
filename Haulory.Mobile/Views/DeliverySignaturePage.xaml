<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Haulory.Mobile.Views.DeliverySignaturePage"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="*,Auto"
          Padding="0"
          RowSpacing="0">

        <!-- SCROLLABLE DETAILS -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- Page header -->
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12"
                      VerticalOptions="Center">

                    <Border
                        Grid.Column="0"
                        BackgroundColor="{StaticResource Gray100}"
                        Stroke="{StaticResource Gray300}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="10"
                        VerticalOptions="Center">

                        <Image
                            Source="signature.svg"
                            HeightRequest="22"
                            WidthRequest="22" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="Delivery signature"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}" />
                        <Label Text="Confirm receiver and capture signature"
                               FontSize="14"
                               TextColor="{StaticResource Gray600}" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Job details card -->
                <Border StrokeThickness="1"
                        Stroke="{StaticResource Gray300}"
                        StrokeShape="RoundRectangle 18"
                        BackgroundColor="{StaticResource BrandSurface}"
                        Padding="16">

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="8">
                            <Image
                                Source="delivery.svg"
                                HeightRequest="16"
                                WidthRequest="16"
                                VerticalOptions="Center" />

                            <Label Grid.Column="1"
                                   Text="Delivery details"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandTitle}" />
                        </Grid>

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12">
                            <VerticalStackLayout Spacing="8">

                                <Label Text="{Binding ReferenceNumber}"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="{StaticResource BrandTitle}"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding PickupCompany}"
                                       FontSize="14"
                                       TextColor="{StaticResource BrandInk}"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding DeliveryCompany}"
                                       FontSize="14"
                                       TextColor="{StaticResource BrandInk}"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding DeliveryAddress}"
                                       FontSize="14"
                                       LineHeight="1.2"
                                       TextColor="{StaticResource BrandInk}"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2" />

                                <Label Text="{Binding LoadDescription}"
                                       FontSize="14"
                                       LineHeight="1.2"
                                       TextColor="{StaticResource BrandInk}"
                                       LineBreakMode="WordWrap"
                                       MaxLines="3" />

                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- Pre-delivery info card -->
                <Border StrokeThickness="1"
                        Stroke="{StaticResource Gray300}"
                        StrokeShape="RoundRectangle 18"
                        BackgroundColor="{StaticResource BrandSurface}"
                        Padding="16">

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="8">
                            <Image
                                Source="warning.svg"
                                HeightRequest="16"
                                WidthRequest="16"
                                VerticalOptions="Center" />

                            <Label Grid.Column="1"
                                   Text="Pre-delivery notes"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandTitle}" />
                        </Grid>

                        <Label Text="Any wait time or damage notes entered before delivery are shown below for review before signing."
                               FontSize="13"
                               LineHeight="1.2"
                               TextColor="{StaticResource Gray600}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12">
                            <Grid RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="12"
                                  RowSpacing="12">

                                <Label Text="Wait time"
                                       Grid.Row="0"
                                       Grid.Column="0"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource BrandTitle}" />

                                <Label Text="{Binding WaitTimeDisplay}"
                                       Grid.Row="0"
                                       Grid.Column="1"
                                       FontSize="14"
                                       LineHeight="1.15"
                                       TextColor="{StaticResource BrandInk}"
                                       LineBreakMode="WordWrap" />

                                <Label Text="Damage notes"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource BrandTitle}" />

                                <Label Text="{Binding DamageNotesDisplay}"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       FontSize="14"
                                       LineHeight="1.15"
                                       TextColor="{StaticResource BrandInk}"
                                       LineBreakMode="WordWrap" />
                            </Grid>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- Receiver card -->
                <Border StrokeThickness="1"
                        Stroke="{StaticResource Gray300}"
                        StrokeShape="RoundRectangle 18"
                        BackgroundColor="{StaticResource BrandSurface}"
                        Padding="16">

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="8">
                            <Image
                                Source="contact.svg"
                                HeightRequest="16"
                                WidthRequest="16"
                                VerticalOptions="Center" />

                            <Label Grid.Column="1"
                                   Text="Receiver"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandTitle}" />
                        </Grid>

                        <Label Text="Full name as shown on the delivery"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />

                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource BrandTileFill}"
                                Padding="12,10">

                            <Entry Placeholder="Receiver full name"
                                   Text="{Binding ReceiverName}"
                                   FontSize="14"
                                   HeightRequest="46"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray600}"
                                   BackgroundColor="Transparent" />
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- Breathing room -->
                <BoxView HeightRequest="10" Opacity="0" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- SIGNATURE FOOTER CARD -->
        <Border Grid.Row="1"
                StrokeThickness="1"
                Stroke="{StaticResource Gray300}"
                StrokeShape="RoundRectangle 20"
                BackgroundColor="{StaticResource BrandSurface}"
                Padding="14"
                Margin="12,8,12,12">

            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                  RowSpacing="10">

                <!-- Header -->
                <VerticalStackLayout Grid.Row="0"
                                     Spacing="4">

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                        <Image Source="signature.svg"
                               HeightRequest="16"
                               WidthRequest="16"
                               VerticalOptions="Center" />

                        <Label Grid.Column="1"
                               Text="Signature"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}"
                               LineBreakMode="NoWrap" />
                    </Grid>

                    <Label Text="Review details, collect signature, and save delivery."
                           FontSize="13"
                           LineHeight="1.15"
                           TextColor="{StaticResource Gray600}"
                           LineBreakMode="WordWrap" />

                    <Label Text="Sign in the area below"
                           FontSize="13"
                           TextColor="{StaticResource BrandInk}" />
                </VerticalStackLayout>

                <!-- Signature area -->
                <Border Grid.Row="1"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray200}"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="{StaticResource BrandTileFill}"
                        Padding="10">

                    <GraphicsView x:Name="SignatureView"
                                  HeightRequest="180"
                                  Drawable="{Binding SignatureDrawable}"
                                  StartInteraction="OnStartInteraction"
                                  DragInteraction="OnDragInteraction"
                                  EndInteraction="OnEndInteraction" />
                </Border>

                <!-- Buttons -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12">

                    <Button Grid.Column="0"
                            Text="Clear"
                            HeightRequest="46"
                            CornerRadius="14"
                            BackgroundColor="{StaticResource Gray200}"
                            TextColor="{StaticResource BrandInk}"
                            Command="{Binding ClearSignatureCommand}" />

                    <Button Grid.Column="1"
                            Text="Save delivery"
                            HeightRequest="46"
                            CornerRadius="14"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            Command="{Binding SaveCommand}" />
                </Grid>

                <!-- Status -->
                <Label Grid.Row="3"
                       Text="{Binding StatusMessage}"
                       FontSize="13"
                       LineHeight="1.15"
                       TextColor="{StaticResource Gray600}"
                       LineBreakMode="WordWrap"
                       MaxLines="2" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>