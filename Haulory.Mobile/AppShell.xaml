<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="Haulory.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Haulory.Mobile.Views"
    FlyoutBehavior="Flyout"
    Shell.NavBarHasShadow="False"
    Shell.BackgroundColor="#007BA7">

    <Shell.Resources>
        <DataTemplate x:Key="FlyoutItemTemplate">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="16"
                  Padding="18,14">
                <Image
                    Source="{Binding FlyoutIcon}"
                    HeightRequest="24"
                    WidthRequest="24"
                    VerticalOptions="Center" />

                <Label
                    Grid.Column="1"
                    Text="{Binding Title}"
                    FontSize="16"
                    TextColor="Black"
                    VerticalTextAlignment="Center" />
            </Grid>
        </DataTemplate>
    </Shell.Resources>

    <Shell.ItemTemplate>
        <StaticResource Key="FlyoutItemTemplate" />
    </Shell.ItemTemplate>

    <Shell.FlyoutHeader>
        <Grid HeightRequest="140"
              Padding="20,50,20,16"
              BackgroundColor="#007BA7">

            <VerticalStackLayout Spacing="6">
                <Label
                    Text="Haulory"
                    FontSize="24"
                    FontAttributes="Bold"
                    TextColor="#FFFFFF" />

                <Label
                    Text="Transport management"
                    FontSize="13"
                    TextColor="#FFFFFF" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <ShellContent
        Route="LoginPage"
        FlyoutItemIsVisible="False"
        ContentTemplate="{DataTemplate views:LoginPage}" />

    <ShellContent
        Route="RegisterPage"
        FlyoutItemIsVisible="False"
        ContentTemplate="{DataTemplate views:RegisterPage}" />

    <FlyoutItem Title="Dashboard"
                Icon="dashboard.png"
                FlyoutDisplayOptions="AsSingleItem">
        <ShellContent
            Title="Dashboard"
            Route="DashboardPage"
            ContentTemplate="{DataTemplate views:DashboardPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Jobs"
                Icon="jobs.png"
                FlyoutDisplayOptions="AsSingleItem">
        <ShellContent
            Title="Jobs"
            Route="JobsCollectionPage"
            ContentTemplate="{DataTemplate views:JobsCollectionPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Vehicles"
                Icon="vehicle.png"
                FlyoutDisplayOptions="AsSingleItem">
        <ShellContent
            Title="Vehicles"
            Route="VehicleCollectionPage"
            ContentTemplate="{DataTemplate views:VehicleCollectionPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="DriversFlyoutItem"
                Title="Drivers"
                Icon="driver.png"
                FlyoutDisplayOptions="AsSingleItem">
        <ShellContent
            Title="Drivers"
            Route="DriverCollectionPage"
            ContentTemplate="{DataTemplate views:DriverCollectionPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="ReportsFlyoutItem"
                Title="Reports"
                Icon="reports.png"
                FlyoutDisplayOptions="AsSingleItem">
        <ShellContent
            Title="Reports"
            Route="ReportsPage"
            ContentTemplate="{DataTemplate views:ReportsPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="NeedsReviewFlyoutItem"
                Title="Needs Review"
                Icon="warning.png"
                FlyoutDisplayOptions="AsSingleItem">
        <ShellContent
            Title="Needs Review"
            Route="NeedsReviewPage"
            ContentTemplate="{DataTemplate views:NeedsReviewPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="SettingsFlyoutItem"
                Title="Settings"
                Icon="settings.png"
                FlyoutDisplayOptions="AsSingleItem">
        <ShellContent
            Title="Settings"
            Route="SettingsPage"
            ContentTemplate="{DataTemplate views:SettingsPage}" />
    </FlyoutItem>

    <Shell.FlyoutFooter>
        <Grid Padding="18,10,18,24"
          BackgroundColor="Transparent">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnLogoutClicked" />
            </Grid.GestureRecognizers>

            <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="16">
                <Image
                Source="close.png"
                HeightRequest="24"
                WidthRequest="24"
                VerticalOptions="Center" />

                <Label
                Grid.Column="1"
                Text="Logout"
                FontSize="16"
                TextColor="Black"
                VerticalTextAlignment="Center" />
            </Grid>
        </Grid>
    </Shell.FlyoutFooter>
</Shell>