<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ========================================================= -->
    <!-- Transport & Logistics Brand Palette                       -->
    <!-- ========================================================= -->

    <!-- Core brand -->
    <Color x:Key="P_Cerulean">#007BA7</Color>
    <Color x:Key="P_CeruleanDark">#005F73</Color>
    <Color x:Key="P_CeruleanLight">#4FC3F7</Color>

    <!-- Action / CTA -->
    <Color x:Key="P_ActionOrange">#FF7A00</Color>
    <Color x:Key="P_ActionOrangeLight">#FFA64D</Color>

    <!-- Supporting color -->
    <Color x:Key="P_Teal">#009688</Color>

    <!-- Neutral system -->
    <Color x:Key="P_White">#FFFFFF</Color>
    <Color x:Key="P_LightSurface">#F5F7FA</Color>
    <Color x:Key="P_SurfaceAlt">#EEF3F8</Color>
    <Color x:Key="P_BorderSoft">#D1D5DB</Color>
    <Color x:Key="P_MutedText">#667085</Color>
    <Color x:Key="P_DeepInk">#1F2937</Color>
    <Color x:Key="P_Black">#111827</Color>

    <!-- Status colors -->
    <Color x:Key="P_Success">#22C55E</Color>
    <Color x:Key="P_Warning">#F59E0B</Color>
    <Color x:Key="P_Danger">#EF4444</Color>
    <Color x:Key="P_Info">#3B82F6</Color>

    <!-- Optional extras -->
    <Color x:Key="P_WhiteSmoke">#F5F5F5</Color>
    <Color x:Key="P_CarbonBlack">#1C1C1C</Color>

    <!-- ========================================================= -->
    <!-- Brand role mapping                                        -->
    <!-- ========================================================= -->

    <Color x:Key="BrandBackground">#007BA7</Color>
    <Color x:Key="BrandSurface">#FFFFFF</Color>
    <Color x:Key="BrandTileFill">#F5F7FA</Color>

    <Color x:Key="BrandInk">#1F2937</Color>
    <Color x:Key="BrandTitle">#1C1C1C</Color>
    <Color x:Key="BrandDeep">#111827</Color>

    <Color x:Key="BrandAccent">#FF7A00</Color>
    <Color x:Key="BrandAccentSoft">#FFA64D</Color>
    <Color x:Key="BrandSecondary">#009688</Color>

    <Color x:Key="BrandSuccess">#22C55E</Color>
    <Color x:Key="BrandWarning">#F59E0B</Color>
    <Color x:Key="BrandDanger">#EF4444</Color>
    <Color x:Key="BrandUrgent">#FF7A00</Color>
    <Color x:Key="BrandInfo">#3B82F6</Color>

    <!-- ========================================================= -->
    <!-- Default MAUI keys used by Styles.xaml                     -->
    <!-- ========================================================= -->

    <Color x:Key="Primary">#007BA7</Color>
    <Color x:Key="PrimaryDark">#005F73</Color>
    <Color x:Key="PrimaryDarkText">#1F2937</Color>

    <Color x:Key="Secondary">#009688</Color>
    <Color x:Key="SecondaryDarkText">#1F2937</Color>

    <Color x:Key="Tertiary">#FF7A00</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#111827</Color>
    <Color x:Key="Magenta">#FF7A00</Color>
    <Color x:Key="MidnightBlue">#3B82F6</Color>
    <Color x:Key="OffBlack">#1F2937</Color>

    <!-- ========================================================= -->
    <!-- Neutral gray system                                       -->
    <!-- ========================================================= -->

    <Color x:Key="Gray100">#FFFFFF</Color>
    <Color x:Key="Gray200">#F5F7FA</Color>
    <Color x:Key="Gray300">#E5E7EB</Color>
    <Color x:Key="Gray400">#D1D5DB</Color>
    <Color x:Key="Gray500">#9CA3AF</Color>
    <Color x:Key="Gray600">#667085</Color>
    <Color x:Key="Gray900">#374151</Color>
    <Color x:Key="Gray950">#111827</Color>

    <!-- ========================================================= -->
    <!-- Logistics status colours                                  -->
    <!-- ========================================================= -->

    <Color x:Key="StatusAvailable">#22C55E</Color>
    <Color x:Key="StatusInTransit">#3B82F6</Color>
    <Color x:Key="StatusScheduled">#009688</Color>
    <Color x:Key="StatusWarning">#F59E0B</Color>
    <Color x:Key="StatusDelayed">#FF7A00</Color>
    <Color x:Key="StatusError">#EF4444</Color>
    <Color x:Key="StatusCompleted">#22C55E</Color>
    <Color x:Key="StatusCancelled">#667085</Color>

    <!-- ========================================================= -->
    <!-- Brushes                                                   -->
    <!-- ========================================================= -->

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />

    <SolidColorBrush x:Key="BrandBackgroundBrush" Color="{StaticResource BrandBackground}" />
    <SolidColorBrush x:Key="BrandSurfaceBrush" Color="{StaticResource BrandSurface}" />
    <SolidColorBrush x:Key="BrandAccentBrush" Color="{StaticResource BrandAccent}" />
    <SolidColorBrush x:Key="BrandDangerBrush" Color="{StaticResource BrandDanger}" />
    <SolidColorBrush x:Key="BrandWarningBrush" Color="{StaticResource BrandWarning}" />
    <SolidColorBrush x:Key="BrandSuccessBrush" Color="{StaticResource BrandSuccess}" />
    <SolidColorBrush x:Key="BrandInfoBrush" Color="{StaticResource BrandInfo}" />

</ResourceDictionary>