<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HaulitCore.Mobile.Views.SettingsPage"
             Title="Settings"
             BackgroundColor="{StaticResource BrandBackground}"
             SafeAreaEdges="Container">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="True" />
    </Shell.BackButtonBehavior>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Border Style="{StaticResource CardBorderStyle}"
                    Stroke="{StaticResource Gray200}"
                    StrokeShape="RoundRectangle 18"
                    Padding="14">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">

                    <Border BackgroundColor="{StaticResource BrandTileFill}"
                            Stroke="{StaticResource Gray200}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="8">

                        <Image Source="settings.svg"
                               HeightRequest="20"
                               WidthRequest="20" />
                    </Border>

                    <Label Grid.Column="1"
                           Text="Manage invoice and proof of delivery settings for your transport workflow."
                           FontSize="14"
                           TextColor="{StaticResource Gray600}" />
                </Grid>
            </Border>

            <!-- Invoice Settings -->
            <Border Style="{StaticResource CardBorderStyle}"
                    Stroke="{StaticResource Gray200}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16">

                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <Label Text="{Binding InvoiceSection.Title}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}"
                               VerticalOptions="Center" />

                        <Label Grid.Column="1"
                               Text="{Binding InvoiceSection.ExpandCollapseGlyph}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gray600}"
                               VerticalOptions="Center" />

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding InvoiceSection.ToggleExpandedCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <VerticalStackLayout Spacing="14"
                                         IsVisible="{Binding InvoiceSection.IsExpanded}">

                        <!-- GST -->
                        <Border BackgroundColor="{StaticResource White}"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                Padding="14">

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Enable GST"
                                           FontAttributes="Bold"
                                           FontSize="14"
                                           TextColor="{StaticResource BrandInk}" />
                                    <Label Text="Apply GST to generated invoices."
                                           FontSize="12"
                                           TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        Padding="6"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeShape="RoundRectangle 12">

                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding GstEnabled}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor" Value="#007BA7"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding GstEnabled}"
                                                     Value="False">
                                            <Setter Property="BackgroundColor" Value="#F8FAFC"/>
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Switch IsToggled="{Binding GstEnabled}"
                                            OnColor="{StaticResource BrandAccent}" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- GST Rate -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="GST Rate (%)"
                                   TextColor="{StaticResource Gray600}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry
                                        Text="{Binding GstRatePercent, Mode=TwoWay}"
                                        Keyboard="Numeric"
                                        TextColor="#1F2937"
                                        Placeholder="e.g. 15"
                                        PlaceholderColor="#9CA3AF" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Fuel -->
                        <Border BackgroundColor="{StaticResource White}"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                Padding="14">

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Enable Fuel Surcharge"
                                           FontAttributes="Bold"
                                           FontSize="14"
                                           TextColor="{StaticResource BrandInk}" />
                                    <Label Text="Add a fuel surcharge percentage to invoices."
                                           FontSize="12"
                                           TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        Padding="6"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeShape="RoundRectangle 12">

                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding FuelSurchargeEnabled}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor" Value="#007BA7"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding FuelSurchargeEnabled}"
                                                     Value="False">
                                            <Setter Property="BackgroundColor" Value="#F8FAFC"/>
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Switch IsToggled="{Binding FuelSurchargeEnabled}"
                                            OnColor="{StaticResource BrandAccent}" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Fuel Rate -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Fuel Surcharge (%)"
                                   TextColor="{StaticResource Gray600}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry
                                    Text="{Binding FuelSurchargePercent, Mode=TwoWay}"
                                    Keyboard="Numeric"
                                    TextColor="#1F2937"
                                    Placeholder="e.g. 5"
                                    PlaceholderColor="#9CA3AF" />
                            </Border>
                        </VerticalStackLayout>
                        <Border BackgroundColor="{StaticResource White}"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                Padding="14">

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Enable Wait Time Charge"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       TextColor="{StaticResource BrandInk}" />
                                    <Label Text="Include wait time charge on invoices."
                                       FontSize="12"
                                       TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                    Padding="6"
                                    Stroke="{StaticResource Gray300}"
                                    StrokeShape="RoundRectangle 12">

                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                             Binding="{Binding WaitTimeChargeEnabled}"
                                             Value="True">
                                            <Setter Property="BackgroundColor" Value="#007BA7"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                             Binding="{Binding WaitTimeChargeEnabled}"
                                             Value="False">
                                            <Setter Property="BackgroundColor" Value="#F8FAFC"/>
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Switch IsToggled="{Binding WaitTimeChargeEnabled}"
                                        OnColor="{StaticResource BrandAccent}" />
                                </Border>
                            </Grid>
                        </Border>
                        
                        <!-- Wait Time Charge -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Wait Time Charge (Hourly)"
                                TextColor="{StaticResource Gray600}" />

                            <Border Style="{StaticResource InputBorderStyle}">

                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                         Binding="{Binding IsWaitTimeInvalid}"
                                         Value="True">
                                        <Setter Property="Stroke" Value="#EF4444"/>
                                    </DataTrigger>
                                </Border.Triggers>

                                <Entry
                                    Text="{Binding WaitTimeCharge}"
                                    Keyboard="Numeric"
                                    TextColor="#1F2937"
                                    Placeholder="e.g. 85"
                                    PlaceholderColor="#9CA3AF" />
                            </Border>
                        </VerticalStackLayout>

                        <Border BackgroundColor="{StaticResource White}"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                Padding="14">

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Enable hand-unload charge"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       TextColor="{StaticResource BrandInk}" />
                                    <Label Text="Include hand-unload charge on invoices."
                                       FontSize="12"
                                       TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        Padding="6"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeShape="RoundRectangle 12">

                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                             Binding="{Binding HandUnloadChargeEnabled}"
                                             Value="True">
                                            <Setter Property="BackgroundColor" Value="#007BA7"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                 Binding="{Binding HandUnloadChargeEnabled}"
                                                 Value="False">
                                            <Setter Property="BackgroundColor" Value="#F8FAFC"/>
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Switch IsToggled="{Binding HandUnloadChargeEnabled}"
                                        OnColor="{StaticResource BrandAccent}" />
                                </Border>
                            </Grid>
                        </Border>
                        <!-- Hand Unload Charge -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Hand Unload Charge (Flat rate)"
                                TextColor="{StaticResource Gray600}" />

                            <Border Style="{StaticResource InputBorderStyle}">

                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                         Binding="{Binding IsHandUnloadInvalid}"
                                         Value="True">
                                        <Setter Property="Stroke" Value="#EF4444"/>
                                    </DataTrigger>
                                </Border.Triggers>

                                <Entry
                                    Text="{Binding HandUnloadCharge}"
                                    Keyboard="Numeric"
                                    TextColor="#1F2937"
                                    Placeholder="e.g. 45"
                                    PlaceholderColor="#9CA3AF" />
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- POD Settings -->
            <Border Style="{StaticResource CardBorderStyle}"
                    Stroke="{StaticResource Gray200}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16">

                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <Label Text="{Binding PodSection.Title}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandTitle}"
                               VerticalOptions="Center" />

                        <Label Grid.Column="1"
                               Text="{Binding PodSection.ExpandCollapseGlyph}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gray600}"
                               VerticalOptions="Center" />

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PodSection.ToggleExpandedCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <VerticalStackLayout Spacing="14"
                                         IsVisible="{Binding PodSection.IsExpanded}">

                        <!-- Damage -->
                        <Border BackgroundColor="{StaticResource White}"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                Padding="14">

                            <Grid ColumnDefinitions="*,Auto">

                                <VerticalStackLayout>
                                    <Label Text="Show Damage Notes On POD"
                                           FontAttributes="Bold"
                                           FontSize="14"
                                           TextColor="{StaticResource BrandInk}" />
                                    <Label Text="Include recorded damage notes on the POD."
                                           FontSize="12"
                                           TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        Padding="6"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeShape="RoundRectangle 12">

                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding ShowDamageNotesOnPod}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor" Value="#007BA7"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding ShowDamageNotesOnPod}"
                                                     Value="False">
                                            <Setter Property="BackgroundColor" Value="#F8FAFC"/>
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Switch IsToggled="{Binding ShowDamageNotesOnPod}"
                                            OnColor="{StaticResource BrandAccent}" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Wait Time -->
                        <Border BackgroundColor="{StaticResource White}"
                                Stroke="{StaticResource Gray200}"
                                StrokeShape="RoundRectangle 14"
                                Padding="14">

                            <Grid ColumnDefinitions="*,Auto">

                                <VerticalStackLayout>
                                    <Label Text="Show Wait Time On POD"
                                           FontAttributes="Bold"
                                           FontSize="14"
                                           TextColor="{StaticResource BrandInk}" />
                                    <Label Text="Include wait time details on the POD."
                                           FontSize="12"
                                           TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        Padding="6"
                                        Stroke="{StaticResource Gray300}"
                                        StrokeShape="RoundRectangle 12">

                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding ShowWaitTimeOnPod}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor" Value="#007BA7"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding ShowWaitTimeOnPod}"
                                                     Value="False">
                                            <Setter Property="BackgroundColor" Value="#F8FAFC"/>
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Switch IsToggled="{Binding ShowWaitTimeOnPod}"
                                            OnColor="{StaticResource BrandAccent}" />
                                </Border>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
            
            <!-- Business & Tax Settings -->
            <Border Style="{StaticResource CardBorderStyle}"
                Stroke="{StaticResource Gray200}"
                StrokeShape="RoundRectangle 18"
                Padding="16">

                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="12">
                        <Label Text="{Binding BusinessTaxSection.Title}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}"
                           VerticalOptions="Center" />

                        <Label Grid.Column="1"
                           Text="{Binding BusinessTaxSection.ExpandCollapseGlyph}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray600}"
                           VerticalOptions="Center" />

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BusinessTaxSection.ToggleExpandedCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <VerticalStackLayout Spacing="14"
                             IsVisible="{Binding BusinessTaxSection.IsExpanded}">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Address"
                                TextColor="{StaticResource Gray600}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding BusinessAddress1}"
                                   Placeholder="e.g. 123 Totara Street"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray500}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Suburb"
                                TextColor="{StaticResource Gray600}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding BusinessSuburb}"
                                   Placeholder="e.g. Mount Maunganui"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray500}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="City"
                                TextColor="{StaticResource Gray600}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding BusinessCity}"
                                   Placeholder="e.g. Tauranga"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray500}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Region"
                                TextColor="{StaticResource Gray600}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding BusinessRegion}"
                                   Placeholder="e.g. Bay of Plenty"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray500}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Postcode"
                                TextColor="{StaticResource Gray600}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding BusinessPostcode}"
                                   Placeholder="e.g. 3116"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray500}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Country"
                                TextColor="{StaticResource Gray600}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding BusinessCountry}"
                                   Placeholder="e.g. New Zealand"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray500}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="GST Number"
                                TextColor="{StaticResource Gray600}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding SupplierGstNumber}"
                                   Placeholder="e.g. 123-456-789"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray500}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="NZBN"
                                TextColor="{StaticResource Gray600}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding SupplierNzbn}"
                                   Placeholder="e.g. 9429041234567"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray500}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Bank Account"
                                TextColor="{StaticResource Gray600}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Entry Text="{Binding BankAccountNumber}"
                                   Placeholder="e.g. 12-1234-1234567-00"
                                   TextColor="{StaticResource BrandInk}"
                                   PlaceholderColor="{StaticResource Gray500}" />
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
            
            <Border Style="{StaticResource CardBorderStyle}"
                    Stroke="{StaticResource Gray200}"
                    StrokeShape="RoundRectangle 18"
                    Padding="14"
                    Margin="0,4,0,20">

                <Button Text="Save Settings"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HeightRequest="48" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>