<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:HaulitCore.Mobile.Converters"
    x:Class="HaulitCore.Mobile.Views.RegisterPage"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource BrandBackground}"
    SafeAreaEdges="Container">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout
                Padding="24,36,24,24"
                Spacing="24">

                <Border
                        Style="{StaticResource CardBorderStyle}"
                        Stroke="{StaticResource Gray200}"
                        StrokeShape="RoundRectangle 20"
                        Padding="20"
                        Margin="0,0,0,12">

                    <VerticalStackLayout
                                    Spacing="10"
                                    HorizontalOptions="Center">


                        <!-- Title -->
                        <Label
                                Text="Create account"
                                FontSize="26"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}"
                                HorizontalTextAlignment="Center" />

                        <!-- Subtitle -->
                        <Label
                                Text="Set up your Haul it Core profile and business details"
                                FontSize="14"
                                TextColor="{StaticResource Gray600}"
                                HorizontalTextAlignment="Center"/>

                    </VerticalStackLayout>

                </Border>

                <!-- Main Register Card -->
                <Border
                    Style="{StaticResource CardBorderStyle}"
                    Stroke="{StaticResource Gray300}"
                    StrokeShape="RoundRectangle 22"
                    Padding="22"
                    MaximumWidthRequest="720"
                    HorizontalOptions="Center">

                    <VerticalStackLayout Spacing="18">

                        <!-- Intro -->
                        <VerticalStackLayout Spacing="4">
                            <Label
                                Text="Get started"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandTitle}" />

                            <Label
                                Text="Create your account to manage transport jobs, vehicles, drivers, and compliance."
                                FontSize="13"
                                TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>

                        <!-- ========================= -->
                        <!-- YOUR DETAILS CARD -->
                        <!-- ========================= -->
                        <Border
                            Style="{StaticResource CardBorderStyle}"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Stroke="{StaticResource Gray200}"
                            Padding="16">

                            <VerticalStackLayout Spacing="14">

                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="Your details"
                                        Style="{StaticResource SectionLabelStyle}" />

                                    <Label
                                        Text="Tell us who you are."
                                        FontSize="12"
                                        TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        Text="First name"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />

                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <Entry
                                            Placeholder="Jane / John"
                                            Text="{Binding FirstName}"
                                            HeightRequest="44"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource BrandInk}"
                                            PlaceholderColor="{StaticResource Gray500}" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        Text="Last name"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />

                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <Entry
                                            Placeholder="Doe"
                                            Text="{Binding LastName}"
                                            HeightRequest="44"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource BrandInk}"
                                            PlaceholderColor="{StaticResource Gray500}" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        Text="Login Email"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />

                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <Entry
                                            Placeholder="email@email.com"
                                            Text="{Binding Email}"
                                            Keyboard="Email"
                                            ClearButtonVisibility="WhileEditing"
                                            HeightRequest="44"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource BrandInk}"
                                            PlaceholderColor="{StaticResource Gray500}" />
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        Text="Password"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />

                                    <!-- Password -->
                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Entry
                                                Grid.Column="0"
                                                Placeholder="Password"
                                                Text="{Binding Password}"
                                                IsPassword="{Binding IsPasswordHidden}"
                                                HeightRequest="44"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource BrandInk}"
                                                PlaceholderColor="{StaticResource Gray500}" />

                                            <Button
                                                Grid.Column="1"
                                                Text="{Binding PasswordToggleText}"
                                                Command="{Binding TogglePasswordVisibilityCommand}"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource BrandAccent}"
                                                FontSize="12"
                                                Padding="10,0"
                                                HeightRequest="44" />
                                        </Grid>
                                    </Border>

                                    <!-- Confirm Password -->
                                    <Label
                                         Text="Confirm Password"
                                         FontSize="12"
                                         FontAttributes="Bold"
                                         TextColor="{StaticResource BrandTitle}" />
                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Entry
                                                Grid.Column="0"
                                                Placeholder="Confirm password"
                                                Text="{Binding ConfirmPassword}"
                                                IsPassword="{Binding IsConfirmPasswordHidden}"
                                                HeightRequest="44"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource BrandInk}"
                                                PlaceholderColor="{StaticResource Gray500}" />

                                            <Button
                                                Grid.Column="1"
                                                Text="{Binding ConfirmPasswordToggleText}"
                                                Command="{Binding ToggleConfirmPasswordVisibilityCommand}"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource BrandAccent}"
                                                FontSize="12"
                                                Padding="10,0"
                                                HeightRequest="44" />
                                        </Grid>
                                    </Border>

                                    <Label
                                        Text="{Binding PasswordsMatchMessage}"
                                        TextColor="{Binding PasswordsMatchColor}"
                                        FontSize="12"
                                        Margin="2,2,0,0"
                                        IsVisible="{Binding ConfirmPassword, Converter={StaticResource StringNotEmptyConverter}}" />
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>

                        <!-- ========================= -->
                        <!-- BUSINESS DETAILS CARD -->
                        <!-- ========================= -->
                        <Border
                            Style="{StaticResource CardBorderStyle}"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Stroke="{StaticResource Gray200}"
                            Padding="16">

                            <VerticalStackLayout Spacing="14">

                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="Business details"
                                        Style="{StaticResource SectionLabelStyle}" />

                                    <Label
                                        Text="Used for invoices, POD documents and company records."
                                        FontSize="12"
                                        TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        Text="Business name"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />

                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <Entry
                                            Placeholder="e.g. Haul it Core Logistics Ltd"
                                            Text="{Binding BusinessName}"
                                            HeightRequest="44"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource BrandInk}"
                                            PlaceholderColor="{StaticResource Gray500}" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        Text="Business email (optional)"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />

                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <Entry
                                            Placeholder="accounts@business.com"
                                            Text="{Binding BusinessEmail}"
                                            Keyboard="Email"
                                            HeightRequest="44"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource BrandInk}"
                                            PlaceholderColor="{StaticResource Gray500}" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        Text="Business phone (optional)"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />

                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <Entry
                                            Placeholder="+64..."
                                            Text="{Binding BusinessPhone}"
                                            Keyboard="Telephone"
                                            HeightRequest="44"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource BrandInk}"
                                            PlaceholderColor="{StaticResource Gray500}" />
                                    </Border>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>

                        <!-- ========================= -->
                        <!-- ADDRESS CARD -->
                        <!-- ========================= -->
                        <Border
                            Style="{StaticResource CardBorderStyle}"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Stroke="{StaticResource Gray200}"
                            Padding="16">

                            <VerticalStackLayout Spacing="14">
                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="Business address"
                                        Style="{StaticResource SectionLabelStyle}" />

                                    <Label
                                        Text="Optional address details for business documents."
                                        FontSize="12"
                                        TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="14">

                                    <VerticalStackLayout Spacing="6">
                                        <Label
                                            Text="Business address"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandTitle}" />

                                        <Border Style="{StaticResource InputBorderStyle}">
                                            <Entry
                                                Placeholder="12 Logistics Lane"
                                                Text="{Binding BusinessAddress1}"
                                                HeightRequest="44"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource BrandInk}"
                                                PlaceholderColor="{StaticResource Gray500}" />
                                        </Border>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Spacing="6">
                                        <Label
                                            Text="Suburb"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandTitle}" />

                                        <Border Style="{StaticResource InputBorderStyle}">
                                            <Entry
                                                Placeholder="Parkvale"
                                                Text="{Binding BusinessSuburb}"
                                                HeightRequest="44"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource BrandInk}"
                                                PlaceholderColor="{StaticResource Gray500}" />
                                        </Border>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Spacing="6">
                                        <Label
                                            Text="City"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandTitle}" />

                                        <Border Style="{StaticResource InputBorderStyle}">
                                            <Entry
                                                Placeholder="Tauranga"
                                                Text="{Binding BusinessCity}"
                                                HeightRequest="44"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource BrandInk}"
                                                PlaceholderColor="{StaticResource Gray500}" />
                                        </Border>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Spacing="6">
                                        <Label
                                            Text="Region"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandTitle}" />

                                        <Border Style="{StaticResource InputBorderStyle}">
                                            <Entry
                                                Placeholder="Bay of Plenty"
                                                Text="{Binding BusinessRegion}"
                                                HeightRequest="44"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource BrandInk}"
                                                PlaceholderColor="{StaticResource Gray500}" />
                                        </Border>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Spacing="6">
                                        <Label
                                            Text="Postcode"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandTitle}" />

                                        <Border Style="{StaticResource InputBorderStyle}">
                                            <Entry
                                                Placeholder="3112"
                                                Text="{Binding BusinessPostcode}"
                                                HeightRequest="44"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource BrandInk}"
                                                PlaceholderColor="{StaticResource Gray500}" />
                                        </Border>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Spacing="6">
                                        <Label
                                            Text="Country"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandTitle}" />

                                        <Border Style="{StaticResource InputBorderStyle}">
                                            <Entry
                                                Placeholder="New Zealand"
                                                Text="{Binding BusinessCountry}"
                                                HeightRequest="44"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource BrandInk}"
                                                PlaceholderColor="{StaticResource Gray500}" />
                                        </Border>
                                    </VerticalStackLayout>

                                </VerticalStackLayout>


                            </VerticalStackLayout>
                        </Border>

                        <!-- ========================= -->
                        <!-- TAX DETAILS CARD -->
                        <!-- ========================= -->
                        <Border
                            Style="{StaticResource CardBorderStyle}"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Stroke="{StaticResource Gray200}"
                            Padding="16">

                            <VerticalStackLayout Spacing="14">

                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="Tax details"
                                        Style="{StaticResource SectionLabelStyle}" />

                                    <Label
                                        Text="Optional identifiers for compliance and invoicing."
                                        FontSize="12"
                                        TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        Text="GST number (optional)"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />

                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <Entry
                                            Placeholder="e.g., 123-456-789"
                                            Text="{Binding SupplierGstNumber}"
                                            HeightRequest="44"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource BrandInk}"
                                            PlaceholderColor="{StaticResource Gray500}" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        Text="NZBN (optional)"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />

                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <Entry
                                            Placeholder="e.g., 942904..."
                                            Text="{Binding SupplierNzbn}"
                                            HeightRequest="44"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource BrandInk}"
                                            PlaceholderColor="{StaticResource Gray500}" />
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        Text="Bank account number"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource BrandTitle}" />

                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <Entry
                                            Placeholder="e.g. 12-1234-1234567-00"
                                            Text="{Binding BankAccountNumber}"
                                            HeightRequest="44"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource BrandInk}"
                                            PlaceholderColor="{StaticResource Gray500}" />
                                    </Border>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Action -->
                        <Button
                            Text="Create account"
                            Command="{Binding RegisterCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,6,0,0" />

                    </VerticalStackLayout>
                </Border>

                <Border
                        Style="{StaticResource CardBorderStyle}"
                        Stroke="{StaticResource Gray200}"
                        StrokeShape="RoundRectangle 18"
                        Padding="14"
                        Margin="0,12,0,0">

                    <VerticalStackLayout
                                    Spacing="6"
                                    HorizontalOptions="Center">

                        <Label
                                Text="By creating an account you agree to our terms"
                                FontSize="12"
                                HorizontalTextAlignment="Center"
                                TextColor="{StaticResource Gray600}" />

                        <HorizontalStackLayout
                                    HorizontalOptions="Center"
                                    Spacing="6">

                            <Label
                                Text="Already have an account?"
                                FontSize="12"
                                TextColor="{StaticResource Gray600}" />

                            <Label
                                Text="Sign in"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="{StaticResource BrandAccent}">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                                </Label.GestureRecognizers>

                            </Label>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>

                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>