<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="HaulitCore.Mobile.Views.InductionTemplatesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource BrandBackground}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid Padding="20" RowDefinitions="Auto,Auto,*" RowSpacing="14">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="Work site templates"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource BrandTitle}" />

            <Label Text="Create work sites and define induction requirements"
                   FontSize="13"
                   TextColor="{StaticResource BrandInk}" />
        </VerticalStackLayout>

        <!-- Selector and actions -->
        <Border Grid.Row="1"
                StrokeThickness="1"
                Stroke="{StaticResource Gray300}"
                StrokeShape="RoundRectangle 18"
                BackgroundColor="{StaticResource BrandSurface}"
                Padding="16">

            <VerticalStackLayout Spacing="12">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Work site"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BrandTitle}" />

                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{StaticResource BrandTileFill}"
                            Padding="12,10">
                        <Picker Title="Select work site"
                                ItemsSource="{Binding WorkSites}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedSite}"
                                TitleColor="{StaticResource Gray600}"
                                TextColor="{StaticResource BrandInk}" />
                    </Border>

                    <Label Text="Select a site to view and manage its requirements"
                           FontSize="12"
                           TextColor="{StaticResource BrandInk}"/>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Text="Add site"
                            Command="{Binding AddSiteCommand}"
                            HeightRequest="46"
                            CornerRadius="14"
                            BackgroundColor="{StaticResource Gray200}"
                            TextColor="{StaticResource BrandInk}" />
                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- Requirements list -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Requirements}"
                        EmptyView="No requirements for this site yet. Tap Add requirement."
                        Margin="0,2,0,0">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Stroke="{StaticResource Gray300}"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{StaticResource BrandSurface}"
                            Padding="14"
                            Margin="0,0,0,12">

                        <VerticalStackLayout Spacing="10">

                            <!-- Title -->
                            <Label Text="{Binding Title}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrandTitle}"
                                   LineBreakMode="TailTruncation" />

                            <!-- Details section -->
                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{StaticResource BrandTileFill}"
                                    Padding="12">

                                <VerticalStackLayout Spacing="6">

                                    <!-- PPE (hide if empty) -->
                                    <Label Text="{Binding PpeRequired, StringFormat='PPE required: {0}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}"
                                           LineBreakMode="WordWrap">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding PpeRequired}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding PpeRequired}" Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <!-- Validity -->
                                    <Label Text="{Binding ValidForDisplay}"
                                           FontSize="13"
                                           TextColor="{StaticResource BrandInk}"
                                           Opacity="0.92" />

                                </VerticalStackLayout>
                            </Border>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>